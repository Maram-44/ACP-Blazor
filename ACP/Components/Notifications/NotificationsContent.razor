@namespace ACP.Components.Notifications
@using ACP.Models.Account
@using ACP.Services

@inject NotificationClientService NotificationService

<div class="notifications-page animate-fadeIn">

    <!-- Header -->
    <div class="notifications-header">

        <div>

            <h1>Notifications</h1>

            <p>
                Stay updated with adoption, foster care,
                rehoming requests and platform updates.
            </p>

        </div>

        <div class="unread-badge">
            @UnreadCount New
        </div>

    </div>

    <!-- Tabs -->
    <div class="tabs">

        <button class="tab @(SelectedTab == "All" ? "active" : "")"
                @onclick='() => ChangeTab("All")'>
            All
        </button>

        <button class="tab @(SelectedTab == "Read" ? "active" : "")"
                @onclick='() => ChangeTab("Read")'>
            Read
        </button>

        <button class="tab @(SelectedTab == "Unread" ? "active" : "")"
                @onclick='() => ChangeTab("Unread")'>
            Unread
        </button>

    </div>

    <!-- Notifications -->
    <div class="notifications-list">

        @foreach (var item in FilteredNotifications)
        {
            <div class="notification-card @(item.IsRead ? "" : "unread")">

                <div class="notification-icon">
                    🔔
                </div>

                <div class="notification-content">

                    <div class="top-row">

                        <h3>@item.Title</h3>

                        <span class="time">
                            @item.CreatedAt.ToString("dd MMM yyyy")
                        </span>

                    </div>

                    <p>
                        @item.Message
                    </p>

                    <button class="view-btn"
                            @onclick="() => OpenPopup(item)">
                        View Details
                    </button>

                </div>

            </div>
        }

    </div>

</div>

<!-- POPUP -->
@if (SelectedNotification != null)
{
    <div class="popup-overlay">

        <div class="popup-card animate-popup">

            <button class="close-btn"
                    @onclick="ClosePopup">
                ✕
            </button>

            <div class="popup-icon">
                🔔
            </div>

            <h2>@SelectedNotification.Title</h2>

            <p class="popup-time">
                @SelectedNotification.CreatedAt.ToString("f")
            </p>

            <p class="popup-message">
                @SelectedNotification.Message
            </p>

        </div>

    </div>
}

@code {

    private string SelectedTab = "All";

    private Notification? SelectedNotification;

    private List<Notification> Notifications = new();

    protected override async Task OnInitializedAsync()
    {
        await NotificationService.InitializeAsync();

        Notifications = NotificationService.Notifications;

        NotificationService.OnNotificationsChanged += RefreshUI;
    }

    private void RefreshUI()
    {
        Notifications = NotificationService.Notifications;

        InvokeAsync(StateHasChanged);
    }

    private IEnumerable<Notification> FilteredNotifications =>
        SelectedTab switch
        {
            "Read" => Notifications.Where(x => x.IsRead),
            "Unread" => Notifications.Where(x => !x.IsRead),
            _ => Notifications
        };

    private int UnreadCount =>
        Notifications.Count(x => !x.IsRead);

    private void ChangeTab(string tab)
    {
        SelectedTab = tab;
    }

    private async Task OpenPopup(Notification item)
    {
        SelectedNotification = item;

        if (!item.IsRead && item.Id.HasValue)
        {
            await NotificationService.MarkAsReadAsync(item.Id.Value);
        }
    }

    private void ClosePopup()
    {
        SelectedNotification = null;
    }
}