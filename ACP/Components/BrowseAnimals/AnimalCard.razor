@namespace ACP.Components.BrowseAnimals

@* الحاوية الخارجية: خلفية Light Mist مع ظل ناعم وزوايا مستديرة *@
<div class="bg-[#F8FAFC] rounded-[2rem] shadow-md overflow-hidden w-full max-w-sm border border-slate-100 group hover:shadow-2xl transition-all duration-500">

    @* منطقة الصورة مع تأثير الـ Hover *@
    <div class="relative h-64 p-4 overflow-hidden">
        <div class="w-full h-full overflow-hidden rounded-[1.5rem]">
            @* تأثير الهوفر: scale-110 عند مرور الماوس على الكرت *@
            <img src="@GetDisplayImage()"
                 class="w-full h-full object-cover transition-transform duration-700 ease-in-out group-hover:scale-110"
                 alt="@AnimalItem.Name" />
        </div>

        @* نوع الحيوان: خلفية Orange-50 مع نص برتقالي *@
        <div class="absolute top-8 left-8">
            <span class="bg-[#FFF7ED] text-[#EA580C] px-4 py-1 rounded-full text-xs font-extrabold shadow-sm border border-orange-100">
                @GetAnimalTypeName()
            </span>
        </div>
    </div>

    @* تفاصيل الحيوان *@
    <div class="px-8 pb-8">
        <div class="flex justify-between items-baseline mb-6">
            @* الأسود الفخم للاسم *@
            <h3 class="text-2xl font-black text-[#0F172A]">@AnimalItem.Name</h3>
            @* رمادي النصوص للعمر *@
            <span class="text-[#64748B] text-sm font-bold">@GetAge()</span>
        </div>

        @* الزر: البرتقالي الحيوي مع تأثير هوفر وتفاعل *@
        <button @onclick="HandleClick"
                class="w-full bg-[#EA580C] text-white font-bold py-4 rounded-2xl hover:bg-[#C2410C] transition-all shadow-lg shadow-orange-600/20 active:scale-95 flex items-center justify-center gap-2">
            View Profile
            <i class="fas fa-arrow-right text-sm transition-transform group-hover:translate-x-1"></i>
        </button>
    </div>
</div>