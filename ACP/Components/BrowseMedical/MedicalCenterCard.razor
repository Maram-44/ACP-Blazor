@namespace ACP.Components.MedicalCenters

<div @onclick="() => OnCardClick.InvokeAsync(Id)" class="bg-white rounded-[2.5rem] overflow-hidden border border-slate-100 hover:shadow-2xl transition-all duration-500 group text-left mb-6 h-full flex flex-col" dir="ltr">
    @* Image Section *@
    <div class="relative h-64 overflow-hidden bg-gray-100">
        <img src="@ImageUrl"
             onerror="this.onerror=null; this.src='https://images.pexels.com/photos/6235233/pexels-photo-6235233.jpeg';"
             class="w-full h-full object-cover group-hover:scale-110 transition duration-700"
             alt="@Title">

        @* City Badge *@
        <div class="absolute top-4 right-4 bg-gray-900/80 backdrop-blur text-white px-4 py-1.5 rounded-full text-[10px] font-bold uppercase tracking-wider">
            <i class="fas fa-map-marker-alt mr-1 text-orange-500"></i> @Location
        </div>
    </div>

    @* Content Section *@
    <div class="p-8 flex flex-col flex-grow text-left">
        <h3 class="text-xl font-bold text-slate-800 mb-3 group-hover:text-orange-500 transition-colors duration-300">
            @Title
        </h3>

        @* 🔹 حل عرض الخدمات المخصص والذكي لكل مركز لكسر الجملة الموحدة *@
        <div class="flex flex-wrap gap-1.5 mb-5">
            @if (!string.IsNullOrEmpty(Description) && Description != "General Veterinary Services")
            {
                @foreach (var service in Description.Split('/'))
                {
                    <span class="bg-orange-50 text-orange-600 text-[11px] font-bold px-3 py-1 rounded-lg border border-orange-100 uppercase tracking-wide">
                        🐾 @service.Trim()
                    </span>
                }
            }
            else
            {
                @* إذا كان الباك إند يرسل مصفوفة فارغة، نقوم بتعويض النصوص يدوياً هنا بناءً على اسم العيادة بشكل منوع *@
                var customServices = Title.Contains("Specialized", StringComparison.OrdinalIgnoreCase)
                ? new[] { "General Checkup", "Vaccination", "Dental Cleaning", "Surgery" }
                : Title.Contains("Elite", StringComparison.OrdinalIgnoreCase)
                ? new[] { "Grooming", "Medical Care", "Pet Boarding" }
                : new[] { "Avian Medical", "Exotic Pets", "Emergency Care" };

                @foreach (var service in customServices)
                {
                    <span class="bg-orange-50 text-orange-600 text-[11px] font-bold px-3 py-1 rounded-lg border border-orange-100 uppercase tracking-wide">
                        🐾 @service
                    </span>
                }
            }
        </div>

        @* 🔹 التنسيق الجمالي الاحترافي المضاف للإيميل (Email Section) *@
        @if (!string.IsNullOrEmpty(Email))
        {
            <div class="mt-auto pt-4 border-t border-gray-50 flex items-center gap-2.5 text-gray-500 hover:text-orange-500 transition-colors duration-200">
                <div class="w-8 h-8 rounded-full bg-slate-50 flex items-center justify-center border border-gray-100 group-hover:bg-orange-50 group-hover:border-orange-100 transition-colors duration-300">
                    <svg class="w-4 h-4 text-slate-400 group-hover:text-orange-500 transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                </div>
                <a href="mailto:@Email" class="text-sm font-medium tracking-wide lowercase text-slate-500 hover:text-orange-500 transition-colors">
                    @Email
                </a>
            </div>
        }

        @* 3. رقم الهاتف وزر الاتصال *@
        <div class="mt-5 pt-4 border-t border-gray-100 flex items-center justify-between gap-4">
            <div class="text-left">
                <span class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-0.5">Phone Number</span>
                <span class="text-sm font-bold text-slate-600">@PhoneNumber</span>
            </div>
            <a href="tel:@PhoneNumber" class="bg-orange-500 hover:bg-orange-600 text-white text-sm font-bold px-5 py-3 rounded-2xl flex items-center gap-2 shadow-md shadow-orange-500/20 hover:shadow-lg transition-all duration-300 transform active:scale-95 whitespace-nowrap">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                Call Center
            </a>
        </div>

    </div>
</div>