@namespace ACP.Components.MedicalCenters

<section class="relative bg-white pt-32 lg:pt-45 pb-20 overflow-hidden" dir="ltr">
    @* PETS background text - positioned to the right now *@
    <div class="hidden lg:block lg:text-[180px] font-extrabold absolute top-0 right-10 text-gray-900 opacity-[0.03] z-0 pointer-events-none select-none tracking-tighter">
        PETS
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="grid lg:grid-cols-2 gap-12 items-center text-left">

            @* Text Content *@
            <div class="order-1 lg:order-1">
                <span class="inline-block px-4 py-1 bg-orange-100 text-orange-600 rounded-full text-xs font-bold mb-6 italic">
                    @BadgeText
                </span>

                <h1 class="text-5xl md:text-7xl font-black text-gray-900 leading-tight mb-6 border-none outline-none">
                    @TitlePart1 <br>
                    <span class="text-orange-500 relative inline-block">@TitlePart2</span>
                </h1>

                <p class="text-gray-500 text-lg mb-8 max-w-lg">
                    @Description
                </p>

                <div class="flex flex-wrap gap-4">
                    @* <button @onclick="HandleBooking" class="bg-orange-500 text-white px-10 py-4 rounded-2xl font-bold hover:shadow-xl hover:bg-orange-600 transition-all transform hover:-translate-y-1">
                        Book Now
                    </button> *@

                   
                </div>
            </div>

            @* Collage Images - order-2 *@
            <div class="flex items-center justify-center relative order-2 lg:order-2">
                <div class="absolute w-72 h-72 bg-accent/10 blur-[100px] rounded-full"></div>
                <div class="flex flex-col items-start px-3">
                    <img class="collage-img border-[6px] border-white object-cover mb-6 rounded-[2rem] shadow-2xl h-32 w-32 md:h-52 md:w-52 hover:-rotate-3 transition-transform"
                         src="https://images.pexels.com/photos/1170986/pexels-photo-1170986.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Cat">
                    <img class="collage-img border-[6px] border-white object-cover w-24 h-24 rounded-[1.5rem] shadow-2xl md:h-40 md:w-40 hover:rotate-3 transition-transform"
                         src="https://images.pexels.com/photos/1108099/pexels-photo-1108099.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Dog">
                </div>
                <div class="px-3 pt-12">
                    <img class="collage-img border-[6px] border-white object-cover w-44 h-56 rounded-[3rem] shadow-2xl md:h-80 md:w-80 hover:scale-105 transition-transform"
                         src="https://images.pexels.com/photos/1612846/pexels-photo-1612846.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Bird">
                </div>
            </div>
        </div>
    </div>
</section>