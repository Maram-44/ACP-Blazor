@namespace ACP.Components.HomeComponents
<section id="medical" class="py-24 bg-white">
    <div class="container mx-auto px-8 md:px-16 lg:px-24">
        <div class="bg-slate-900 rounded-[4rem] p-12 md:p-24 text-white flex flex-col lg:flex-row gap-16 items-center shadow-3xl">
            <div class="lg:w-1/2">
                <h2 class="text-orange-500 font-black mb-6 tracking-widest uppercase">Health Center</h2>
                <h3 class="text-4xl md:text-5xl font-black mb-8 leading-tight">Instant Medical <br> Bookings</h3>
                <p class="text-slate-400 text-lg leading-loose mb-10">We've partnered with top-tier clinics to provide instant access to verified vets.</p>
                <ul class="space-y-4 mb-10 text-slate-300">
                    <li class="flex items-center gap-3"><span class="text-orange-500 font-bold">✔</span> Routine Health Check-ups</li>
                    <li class="flex items-center gap-3"><span class="text-orange-500 font-bold">✔</span> Digitally Recorded Vaccinations</li>
                    <li class="flex items-center gap-3"><span class="text-orange-500 font-bold">✔</span> 24/7 Emergency Support</li>
                </ul>
                <button class="bg-white text-slate-900 px-10 py-4 rounded-2xl font-black hover:bg-orange-500 transition">Find a Vet</button>
            </div>
            <div class="lg:w-1/2 grid grid-cols-2 gap-4">
                <div class="bg-white/5 p-8 rounded-3xl border border-white/10 text-center hover:bg-white/10 transition"><span class="text-4xl block mb-4">🩺</span><p class="font-bold">Top Vets</p></div>
                <div class="bg-white/5 p-8 rounded-3xl border border-white/10 text-center translate-y-8 hover:bg-white/10 transition"><span class="text-4xl block mb-4">💉</span><p class="font-bold">Safe Vaccines</p></div>
                <div class="bg-white/5 p-8 rounded-3xl border border-white/10 text-center hover:bg-white/10 transition"><span class="text-4xl block mb-4">🚑</span><p class="font-bold">Emergency</p></div>
                <div class="bg-white/5 p-8 rounded-3xl border border-white/10 text-center translate-y-8 hover:bg-white/10 transition"><span class="text-4xl block mb-4">🦷</span><p class="font-bold">Dental Care</p></div>
            </div>
        </div>
    </div>
</section>
