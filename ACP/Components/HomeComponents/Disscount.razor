@namespace ACP.Components.HomeComponents

<section class="py-24 px-8 md:px-16 lg:px-24">
    <div class="max-w-6xl mx-auto bg-orange-600 rounded-[4rem] p-12 md:p-24 text-center text-white relative overflow-hidden shadow-2xl">

        @* عناصر ديكورية للحيوية *@
        <div class="absolute -left-20 top-0 w-80 h-80 bg-slate-900/10 rounded-full blur-[100px]"></div>
        <div class="absolute -right-10 -bottom-10 text-9xl opacity-10 rotate-12">💬</div>

        @* شارة "قريباً" *@
        <div class="inline-block px-6 py-2 bg-slate-900 text-white rounded-full text-xs font-black uppercase tracking-[0.3em] mb-8 animate-pulse">
            Coming Soon
        </div>

        <h2 class="text-4xl md:text-7xl font-black mb-8 tracking-tighter leading-tight">
            The <span class="text-slate-900 italic">Ultimate</span> <br> Pet Parents Forum
        </h2>

        <p class="text-orange-100 text-xl mb-12 max-w-2xl mx-auto font-medium">
            A dedicated space to share stories, ask experts, and connect with 50k+ pet lovers. Your community is almost here!
        </p>

        @* صندوق الاشتراك لانتظار الإطلاق *@
        <div class="bg-white p-3 rounded-[2.5rem] md:rounded-full flex flex-col md:flex-row gap-3 shadow-2xl max-w-2xl mx-auto relative z-10">
            <div class="flex-1 flex items-center px-6">
                <span class="text-slate-400 mr-2">✉️</span>
                <input type="email" placeholder="Get notified on launch"
                       class="w-full py-4 text-slate-900 outline-none font-bold bg-transparent placeholder:text-slate-300">
            </div>
            <button class="bg-slate-900 text-white px-12 py-4 rounded-[2rem] md:rounded-full font-[900] hover:bg-slate-800 transition-all active:scale-95">
                NOTIFY ME
            </button>
        </div>

        @* تلميحات عما سيكون في المنتدى *@
        <div class="mt-12 flex flex-wrap justify-center gap-8 text-orange-200 text-sm font-bold uppercase tracking-widest">
            <span class="flex items-center gap-2">✨ Story Sharing</span>
            <span class="flex items-center gap-2">🩺 Vet Q&A</span>
            <span class="flex items-center gap-2">🎁 Member Perks</span>
        </div>
    </div>
</section>

@code {
    // هذا القسم يعمل كإعلان تشويقي لجمع إيميلات المهتمين بالمنتدى
}