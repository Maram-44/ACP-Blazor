@namespace ACP.Components.HomeComponents
@inject NavigationManager NavigationManager

<section class="py-24 px-8 md:px-16 lg:px-24">
    <div class="max-w-6xl mx-auto bg-orange-600 rounded-[4rem] p-12 md:p-24 text-center text-white relative overflow-hidden shadow-2xl">

        @* عناصر ديكورية للحيوية *@
        <div class="absolute -left-20 top-0 w-80 h-80 bg-slate-900/10 rounded-full blur-[100px]"></div>
        <div class="absolute -right-10 -bottom-10 text-9xl opacity-10 rotate-12">📝</div>

        @* شارة المدوّنة *@
        <div class="inline-block px-6 py-2 bg-slate-900 text-white rounded-full text-xs font-black uppercase tracking-[0.3em] mb-8">
            Explore & Connect
        </div>

        <h2 class="text-4xl md:text-7xl font-black mb-8 tracking-tighter leading-tight">
            The <span class="text-slate-900 italic">Official</span> <br> Pet Parents Blog
        </h2>

        <p class="text-orange-100 text-xl mb-12 max-w-2xl mx-auto font-medium">
            Discover expert tips, inspiring stories, and valuable advice from our vibrant community of pet lovers.
        </p>

        @* زر الانتقال إلى المدوّنة بتصميم متناسق وجذّاب *@
        <div class="flex justify-center relative z-10">
            <button @onclick="NavigateToBlog" class="group bg-slate-900 text-white px-16 py-6 rounded-[2.5rem] font-[900] text-lg hover:bg-slate-800 transition-all duration-300 shadow-2xl active:scale-95 flex items-center gap-3">
                BROWSE ALL ARTICLES
                <span class="text-2xl group-hover:translate-x-2 transition-transform duration-300">📖</span>
            </button>
        </div>

        @* تلميحات عما بداخل المدوّنة *@
        <div class="mt-12 flex flex-wrap justify-center gap-8 text-orange-200 text-sm font-bold uppercase tracking-widest">
            <span class="flex items-center gap-2">🐱 Care Guides</span>
            <span class="flex items-center gap-2">🩺 Health Tips</span>
            <span class="flex items-center gap-2">💬 Owners Stories</span>
        </div>
    </div>
</section>

@code {
    private void NavigateToBlog()
    {
        // استبدلي الرابط أدناه بالرابط الحقيقي لصفحة المدوّنة لديكِ (مثال: "/blog" أو "/articles")
        NavigationManager.NavigateTo("/blog");
    }
}