@namespace ACP.Components.HomeComponents
<section id="animal-services" class="py-24 bg-white">
    <div class="container mx-auto px-8 md:px-16 lg:px-24">
        <div class="grid lg:grid-cols-12 gap-16 items-center">

            <div class="lg:col-span-5 lg:sticky lg:top-32">
                <div class="relative">
                    <div class="absolute -inset-3 bg-orange-100 rounded-[4rem] rotate-2 -z-10"></div>

                    <div class="bg-slate-900 aspect-square rounded-[3.5rem] overflow-hidden shadow-3xl relative flex items-end p-10 group">
                        <img src="https://images.unsplash.com/photo-1450778869180-41d0601e046e?q=80&w=1200&auto=format&fit=crop"
                             alt="New Beginnings"
                             class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">

                        <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-transparent to-transparent z-10"></div>

                        <div class="relative z-20 text-left">
                            <div class="inline-block px-5 py-1.5 bg-orange-600 rounded-full text-white font-black text-[10px] uppercase tracking-widest mb-4">Alef Vision</div>
                            <h4 class="text-3xl font-black text-white mb-2 leading-tight">
                                New Beginnings <br>
                                <span class="text-orange-500 italic">With a Loyal Touch</span>
                            </h4>
                        </div>
                    </div>
                </div>
            </div>

            <div class="lg:col-span-7">
                <div class="inline-flex items-center gap-3 mb-6">
                    <span class="w-10 h-1 bg-orange-500 rounded-full"></span>
                    <span class="text-slate-900 font-black tracking-widest uppercase text-xs">Our Compassionate Services</span>
                </div>

                <h3 class="text-5xl font-black mb-10 text-slate-900 tracking-tighter">
                    A Journey That Starts With <span class="text-orange-600">Kindness.</span>
                </h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="group bg-slate-50 p-6 rounded-[2.5rem] transition-all duration-500 hover:bg-white hover:shadow-xl hover:shadow-orange-200/40 border border-transparent hover:border-orange-100">
                        <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center text-3xl shadow-sm group-hover:bg-orange-600 group-hover:text-white transition-all mb-4">🏠</div>
                        <h4 class="text-xl font-black mb-2 text-slate-900">Adoption</h4>
                        <p class="text-slate-500 text-sm leading-relaxed">Connecting hearts through a smart platform that ensures your pet finds its perfect forever home.</p>
                    </div>

                    <div class="group bg-slate-50 p-6 rounded-[2.5rem] transition-all duration-500 hover:bg-white hover:shadow-xl hover:shadow-blue-200/40 border border-transparent hover:border-blue-100">
                        <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center text-3xl shadow-sm group-hover:bg-blue-600 group-hover:text-white transition-all mb-4">⏳</div>
                        <h4 class="text-xl font-black mb-2 text-slate-900">Fostering</h4>
                        <p class="text-slate-500 text-sm leading-relaxed">Provide a safe temporary space in your home, and we’ll handle all the associated costs.</p>
                    </div>

                    <div class="group md:col-span-2 bg-slate-50 p-6 rounded-[2.5rem] transition-all duration-500 hover:bg-white hover:shadow-xl hover:shadow-slate-300/40 border border-transparent hover:border-slate-200 flex flex-col md:flex-row items-start md:items-center gap-6">
                        <div class="w-16 h-16 shrink-0 bg-white rounded-2xl flex items-center justify-center text-3xl shadow-sm group-hover:bg-slate-900 group-hover:text-white transition-all">🤝</div>
                        <div>
                            <h4 class="text-xl font-black mb-1 text-slate-900">Secure Relinquishment</h4>
                            <p class="text-slate-500 text-sm leading-relaxed max-w-md">Helping you find the best alternative for your pet legally and humanely to secure their future.</p>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>


@code {

}
