@namespace ACP.Components.HomeComponents

<section id="pet-exchange" class="py-32 bg-slate-50">
    <div class="container mx-auto px-8 md:px-16 lg:px-24">
        @* العنوان الرئيسي *@
        <div class="text-center mb-20">
            <h3 class="text-6xl font-[1000] mb-6 text-slate-900 tracking-tighter">
                Alef <span class="text-orange-600">Exchange</span>
            </h3>
            <p class="text-xl text-slate-500 max-w-2xl mx-auto font-medium">
                A community-driven space where pets find new loving homes through direct member-to-member exchange.
            </p>
        </div>

        @* البطاقات الرئيسية *@
        <div class="grid lg:grid-cols-2 gap-8">

            @* البطاقة الأولى: البحث عن حيوان جديد *@
            <div class="bg-white p-12 rounded-[4rem] border-2 border-slate-100 shadow-sm text-left group hover:border-orange-500 transition-all duration-500 relative overflow-hidden">
                <div class="relative z-10">
                    <span class="text-4xl mb-6 block">🔍</span>
                    <h4 class="text-4xl font-[1000] mb-4 text-slate-900 tracking-tighter">Adopt from <br /> a Member</h4>
                    <p class="text-slate-500 mb-10 font-bold leading-relaxed max-w-xs">
                        Browse pets listed by other owners who are looking for a new family.
                    </p>
                    <button class="bg-slate-900 text-white px-10 py-5 rounded-[2rem] font-black group-hover:bg-orange-600 transition-all transform group-hover:-translate-y-1">
                        View Gallery
                    </button>
                </div>
                @* شكل ديكوري خلفي *@
                <div class="absolute -right-10 -bottom-10 text-[12rem] opacity-[0.03] rotate-12 pointer-events-none">🐕</div>
            </div>

            @* البطاقة الثانية: عرض حيوان للتبديل *@
            <div class="bg-orange-600 p-12 rounded-[4rem] text-white text-left group hover:shadow-[0_30px_60px_-15px_rgba(234,88,12,0.4)] transition-all duration-500 relative overflow-hidden">
                <div class="relative z-10">
                    <span class="text-4xl mb-6 block">🤝</span>
                    <h4 class="text-4xl font-[1000] mb-4 italic tracking-tighter leading-none">Find a New <br /> Guardian</h4>
                    <p class="text-orange-100 mb-10 font-bold leading-relaxed max-w-xs">
                        Can't look after your pet anymore? List them here to find a verified parent.
                    </p>
                    <button class="bg-white text-orange-600 px-10 py-5 rounded-[2rem] font-black group-hover:bg-slate-900 group-hover:text-white transition-all transform group-hover:-translate-y-1">
                        List My Pet
                    </button>
                </div>
                @* شكل ديكوري خلفي *@
                <div class="absolute -right-10 -bottom-10 text-[12rem] opacity-[15%] rotate-12 pointer-events-none">🐈</div>
            </div>

        </div>

        @* شريط الثقة السفلي *@
        <div class="mt-16 flex flex-wrap justify-center gap-12 opacity-40 grayscale">
            <div class="flex items-center gap-3 font-black text-slate-900">
                <span>🛡️</span> VERIFIED USERS
            </div>
            <div class="flex items-center gap-3 font-black text-slate-900">
                <span>📄</span> LEGAL HANDOVER
            </div>
            <div class="flex items-center gap-3 font-black text-slate-900">
                <span>💬</span> DIRECT CHAT
            </div>
        </div>
    </div>
</section>

@code {
    // القسم الآن جاهز لربطه بصفحة التبديل أو الإضافة
}