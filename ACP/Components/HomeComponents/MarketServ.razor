@namespace ACP.Components.HomeComponents
<section id="market" class="py-32 bg-slate-50">
    <div class="container mx-auto px-8 md:px-16 lg:px-24 text-center">
        <h3 class="text-5xl font-black mb-6 text-slate-900 tracking-tighter">Alef Marketplace</h3>
        <p class="text-lg text-slate-500 max-w-2xl mx-auto mb-20">Discover curated premium supplies or sell your pre-loved accessories.</p>
        <div class="grid lg:grid-cols-2 gap-12">
            <div class="bg-white p-12 rounded-[3.5rem] border border-slate-100 shadow-sm text-left group hover:shadow-2xl transition-all">
                <h4 class="text-3xl font-black mb-6">Shop <span class="text-orange-600 underline decoration-4">New</span> Arrivals</h4>
                <p class="text-slate-500 mb-8 font-medium italic">From organic kibble to smart toys.</p>
                <button class="bg-slate-900 text-white px-8 py-4 rounded-2xl font-black group-hover:bg-orange-600 transition">Enter Store</button>
            </div>
            <div class="bg-orange-600 p-12 rounded-[3.5rem] text-white text-left group hover:shadow-2xl transition-all">
                <h4 class="text-3xl font-black mb-6 italic">Community Market</h4>
                <p class="text-orange-100 mb-8 font-medium">Sell your used crates or clothes to other parents.</p>
                <button class="bg-white text-orange-600 px-8 py-4 rounded-2xl font-black group-hover:bg-slate-900 group-hover:text-white transition">Start Selling</button>
            </div>
        </div>
    </div>
</section>
@code {

}
