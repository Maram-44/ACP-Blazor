@namespace ACP.Components.BrowseProducts

<div class="group relative bg-white rounded-[2.5rem] p-4 transition-all duration-500 hover:shadow-[0_30px_60px_-15px_rgba(0,0,0,0.1)] flex flex-col h-full border border-slate-100">

    @* --- قسم الصورة مع معالجة الخطأ --- *@
    <div class="relative aspect-square overflow-hidden rounded-[2rem] bg-slate-50">
        @* أضفت سمة loading="lazy" و onerror لضمان عدم ظهور الصورة المكسورة *@
        <img src="@(string.IsNullOrEmpty(ProductImageUrl) ? "https://images.unsplash.com/photo-1583511655857-d19b40a7a54e?q=80&w=500" : ProductImageUrl)"
             onerror="this.src='https://images.unsplash.com/photo-1516734212186-a967f81ad0d7?q=80&w=500'"
             class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
             alt="@ProductName" />

        @* التاقات *@
        <div class="absolute top-4 left-4 flex flex-col gap-2">
            @if (IsPlatformProduct)
            {
                <span class="bg-[#0F172A] text-white text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-tighter shadow-xl">
                    Official
                </span>
            }
            @if (IsUsed)
            {
                <span class="bg-orange-500 text-white text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-tighter shadow-xl">
                    Pre-loved
                </span>
            }
        </div>
    </div>

    @* --- باقي المحتوى --- *@
    <div class="mt-6 px-2 flex-grow">
        <div class="flex items-center justify-between mb-2">
            <span class="text-[#EA580C] text-[10px] font-bold uppercase tracking-[0.2em]">@CategoryName</span>
            <div class="flex items-center gap-1 text-yellow-400 text-xs">
                <i class="fas fa-star"></i>
                <span class="text-slate-400 font-medium">4.8</span>
            </div>
        </div>

        <h3 class="text-[#0F172A] font-bold text-lg leading-tight group-hover:text-[#EA580C] transition-colors line-clamp-1">
            @ProductName
        </h3>

        <div class="mt-4 flex items-center justify-between">
            <div class="flex flex-col">
                <span class="text-slate-400 text-[10px] font-bold uppercase tracking-tighter">Price</span>
                <span class="text-[#0F172A] text-xl font-black">$@Price.ToString("N2")</span>
            </div>

            <button class="w-12 h-12 bg-[#0F172A] text-white rounded-2xl flex items-center justify-center transform transition-all duration-300 hover:bg-[#EA580C] hover:rotate-12 active:scale-90 shadow-lg">
                <i class="fas fa-plus"></i>
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public string ProductName { get; set; } = "";
    [Parameter] public decimal Price { get; set; }
    [Parameter] public bool IsUsed { get; set; }
    [Parameter] public bool IsPlatformProduct { get; set; }
    [Parameter] public string CategoryName { get; set; } = "";
    [Parameter] public string? ProductImageUrl { get; set; }
}