@namespace ACP.Components.BrowseProducts

<div class="relative max-w-5xl mx-auto">
    @* حاوية الفلتر الزجاجية *@
    <div class="bg-white/10 backdrop-blur-2xl border border-white/20 rounded-[2.5rem] p-4 shadow-[0_25px_50px_-12px_rgba(0,0,0,0.5)]">
        <div class="flex flex-col lg:flex-row items-center gap-4">

            @* 1. حقل البحث مع Two-way Binding *@
            <div class="relative w-full lg:flex-1 group">
                <i class="fas fa-search absolute left-5 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-[#EA580C] transition-colors"></i>
                <input type="text"
                       @bind="SearchTerm"
                       @bind:event="oninput"
                       placeholder="Search for products..."
                       class="w-full bg-white/5 border border-white/10 rounded-2xl py-4 pl-14 pr-4 text-white placeholder:text-slate-500 focus:outline-none focus:border-[#EA580C]/50 focus:bg-white/10 transition-all shadow-inner" />
            </div>

            @* 2. نوع الحيوان *@
            <div class="relative w-full lg:w-48">
                <select @bind="SelectedPetType" class="w-full bg-[#1e293b] lg:bg-transparent border border-white/10 rounded-2xl py-4 px-6 text-slate-300 appearance-none focus:outline-none focus:border-[#EA580C]/50 cursor-pointer">
                    <option value="">All Pets</option>
                    <option value="dogs">Dogs</option>
                    <option value="cats">Cats</option>
                    <option value="birds">Birds</option>
                </select>
                <i class="fas fa-chevron-down absolute right-5 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none text-xs"></i>
            </div>

            @* 3. الفئة *@
            <div class="relative w-full lg:w-48">
                <select @bind="SelectedCategory" class="w-full bg-[#1e293b] lg:bg-transparent border border-white/10 rounded-2xl py-4 px-6 text-slate-300 appearance-none focus:outline-none focus:border-[#EA580C]/50 cursor-pointer">
                    <option value="">Category</option>
                    <option value="food">Food</option>
                    <option value="toys">Toys</option>
                    <option value="accessories">Accessories</option>
                </select>
                <i class="fas fa-chevron-down absolute right-5 top-1/2 -translate-y-1/2 text-slate-500 pointer-events-none text-xs"></i>
            </div>

            @* 4. زر التطبيق *@
            <button @onclick="HandleFilterClick" class="w-full lg:w-auto px-10 py-4 bg-[#EA580C] hover:bg-[#fb923c] text-white font-black rounded-2xl shadow-lg transition-all active:scale-95 flex items-center justify-center gap-3">
                <i class="fas fa-sliders-h"></i>
                <span>FILTER</span>
            </button>

        </div>
    </div>

    @* تلميحات سريعة (Popular Tags) *@
    <div class="flex flex-wrap justify-center gap-6 mt-6">
        <span class="text-slate-500 text-xs font-bold tracking-widest uppercase">Popular:</span>
        <button @onclick='() => SetQuickFilter("Premium Food")' class="text-slate-400 hover:text-[#EA580C] text-xs font-medium transition-colors">#Premium_Food</button>
        <button @onclick='() => SetQuickFilter("Toys")' class="text-slate-400 hover:text-[#EA580C] text-xs font-medium transition-colors">#Used_Toys</button>
        <button @onclick='() => SetQuickFilter("Dog Beds")' class="text-slate-400 hover:text-[#EA580C] text-xs font-medium transition-colors">#Dog_Beds</button>
    </div>
</div>

@code {
    // معاملات الربط (Parameters for Data Binding)
    [Parameter] public string SearchTerm { get; set; } = "";
    [Parameter] public EventCallback<string> SearchTermChanged { get; set; }

    [Parameter] public string SelectedPetType { get; set; } = "";
    [Parameter] public string SelectedCategory { get; set; } = "";

    // حدث لإبلاغ الصفحة الرئيسية بوجوب تحديث القائمة
    [Parameter] public EventCallback OnFilterChanged { get; set; }

    // دالة التاقات السريعة
    private async Task SetQuickFilter(string tag)
    {
        SearchTerm = tag;
        await SearchTermChanged.InvokeAsync(SearchTerm); // تحديث القيمة في الصفحة الأب
        await OnFilterChanged.InvokeAsync(); // طلب إعادة الفلترة
    }

    private async Task HandleFilterClick()
    {
        await OnFilterChanged.InvokeAsync();
    }
}