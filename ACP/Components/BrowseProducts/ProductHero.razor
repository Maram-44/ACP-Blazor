@namespace ACP.Components.BrowseProducts

<section class="relative bg-[#0F172A] min-h-[85vh] flex items-center pt-32 pb-20 overflow-hidden font-sans" dir="ltr">

    @* --- الخلفية الفنية --- *@
    <div class="absolute top-[-10%] right-[-5%] w-[600px] h-[600px] bg-[#EA580C]/20 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-[-10%] left-[-5%] w-[500px] h-[500px] bg-blue-600/10 rounded-full blur-[100px] pointer-events-none"></div>

    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-white/[0.02] text-[15rem] lg:text-[25rem] font-black pointer-events-none select-none uppercase tracking-tighter z-0">
        BOUTIQUE
    </div>

    <div class="container mx-auto px-6 md:px-12 lg:px-24 relative z-10">
        <div class="flex flex-col lg:flex-row items-center gap-16 lg:gap-24">

            @* --- 1. قسم النصوص --- *@
            <div class="w-full lg:flex-1 text-left order-2 lg:order-1">
                <div class="inline-flex items-center gap-3 px-4 py-2 rounded-2xl bg-white/5 border border-white/10 mb-8 backdrop-blur-xl transform hover:scale-105 transition-all">
                    <span class="flex h-2 w-2 rounded-full bg-[#EA580C] animate-ping"></span>
                    <span class="text-orange-100/80 text-xs font-black uppercase tracking-[0.3em]">New Arrival 2026</span>
                </div>

                <h1 class="text-6xl md:text-7xl lg:text-[100px] font-black text-white leading-[0.85] mb-10 tracking-tighter">
                    Pure <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#EA580C] to-orange-300">Luxury</span> <br />
                    For Your Bestie
                </h1>

                <p class="text-slate-400 text-lg lg:text-xl mb-12 max-w-md leading-relaxed font-light italic">
                    "Because they aren't just pets, they are family." Explore our handcrafted premium collection.
                </p>

                <div class="flex flex-wrap gap-6 items-center">
                    <button class="px-12 py-5 bg-[#EA580C] text-white font-extrabold rounded-2xl shadow-[0_20px_40px_-10px_rgba(234,88,12,0.5)] hover:bg-[#fb923c] hover:-translate-y-1 transition-all active:scale-95 uppercase tracking-widest text-sm">
                        SHOP NOW
                    </button>

                    <a href="#used" class="group flex items-center gap-3 text-white font-bold hover:text-[#EA580C] transition-colors">
                        <span class="w-12 h-12 rounded-full border border-white/20 flex items-center justify-center group-hover:border-[#EA580C] bg-white/5 transition-all">
                            <i class="fas fa-redo-alt text-xs"></i>
                        </span>
                        View Pre-loved
                    </a>
                </div>
            </div>

            @* --- 2. قسم الصور التفاعلي (الطبقة التي يلمسها الماوس تصبح في المقدمة) --- *@
            <div class="w-full lg:flex-1 order-1 lg:order-2">
                <div class="relative h-[450px] md:h-[550px] w-full max-w-lg mx-auto">

                    @* الصورة 1: يسار أسفل *@
                    <div class="absolute bottom-10 left-0 z-10 transform -rotate-12 hover:z-50 hover:rotate-0 hover:scale-110 transition-all duration-500 cursor-pointer group">
                        <div class="w-44 h-56 md:w-56 md:h-72 p-2 rounded-[3rem] bg-white/10 backdrop-blur-xl border border-white/20 shadow-2xl overflow-hidden">
                            <img src="https://images.unsplash.com/photo-1516734212186-a967f81ad0d7?q=80&w=2071&auto=format&fit=crop"
                                 class="w-full h-full object-cover rounded-[2.5rem]" alt="Cat" />
                        </div>
                    </div>

                    @* الصورة 2: المنتصف *@
                    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-20 transform rotate-3 hover:z-50 hover:rotate-0 hover:scale-110 transition-all duration-500 cursor-pointer">
                        <div class="w-60 h-76 md:w-64 md:h-80 p-2 rounded-[3.5rem] bg-gradient-to-br from-white/20 to-transparent backdrop-blur-2xl border border-white/30 shadow-[0_50px_100px_-20px_rgba(0,0,0,0.6)] overflow-hidden">
                            <img src="https://images.unsplash.com/photo-1583511655857-d19b40a7a54e?q=80&w=2069&auto=format&fit=crop"
                                 class="w-full h-full object-cover rounded-[3rem]" alt="Dog" />
                        </div>
                    </div>

                    @* الصورة 3: يمين أعلى (تأثير Grayscale) *@
                    <div class="absolute top-0 right-0 z-30 transform rotate-12 hover:z-50 hover:rotate-0 hover:scale-110 transition-all duration-500 cursor-pointer group">
                        <div class="w-48 h-60 md:w-56 md:h-72 p-2 rounded-[3rem] bg-white/10 backdrop-blur-xl border border-white/20 shadow-2xl overflow-hidden">
                            <img src="https://images.unsplash.com/photo-1548199973-03cce0bbc87b?q=80&w=2069&auto=format&fit=crop"
                                 class="w-full h-full object-cover rounded-[2.5rem] grayscale group-hover:grayscale-0 transition-all duration-500 shadow-inner" alt="Puppies" />
                        </div>

                        @* تاق الخصم *@
                        <div class="absolute -top-4 -right-4 w-20 h-20 bg-[#EA580C] rounded-full flex flex-col items-center justify-center text-white shadow-2xl animate-bounce-slow border-4 border-[#0F172A] pointer-events-none">
                            <span class="text-xl font-black">15%</span>
                            <span class="text-[8px] uppercase font-bold">OFF</span>
                        </div>
                    </div>

                    @* تاق التقييم *@
                    <div class="absolute bottom-0 right-4 z-40 animate-float-delayed pointer-events-none">
                        <div class="bg-white/95 backdrop-blur-md p-4 rounded-3xl shadow-2xl flex items-center gap-3 border border-white/20">
                            <div class="w-10 h-10 bg-[#FFF7ED] rounded-xl flex items-center justify-center text-[#EA580C]">
                                <i class="fas fa-star text-sm"></i>
                            </div>
                            <div>
                                <p class="text-[10px] text-slate-400 font-bold uppercase tracking-tighter">Rating</p>
                                <p class="text-lg font-black text-[#0F172A]">4.9/5</p>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <div class="mt-24 relative z-50">
            @ChildContent
        </div>
    </div>
</section>

<style>
    .animate-bounce-slow {
        animation: bounce 3s infinite;
    }

    .animate-float-delayed {
        animation: float 5s ease-in-out infinite 2s;
    }

    @@keyframes bounce {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-15px);
        }
    }

    @@keyframes float {
        0%, 100% {
            transform: translate(0, 0);
        }

        50% {
            transform: translate(-15px, -25px);
        }
    }
</style>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
}