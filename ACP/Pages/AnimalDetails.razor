@page "/animal-details/{AnimalId:int}"

<style>
    /* خلفية دافئة وحيوية */
    body {
        background-color: #fffaf5;
        background-image: radial-gradient(circle at 0% 0%, rgba(249, 115, 22, 0.08) 0%, transparent 40%), radial-gradient(circle at 100% 100%, rgba(249, 115, 22, 0.05) 0%, transparent 40%);
        background-attachment: fixed;
    }

    /* تعديل ألوان الكاردات لتطابق كارد الوصف */
    .vibrant-card {
        background: linear-gradient(135deg, #ffffff 0%, #ffffff 70%, #fff7ed 100%);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 237, 213, 0.8);
        border-radius: 2.5rem;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

        .vibrant-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px -15px rgba(234, 88, 12, 0.15);
        }

    /* تأثيرات الزر */
    .btn-adopt {
        transition: all 0.3s ease;
    }

        .btn-adopt:active {
            transform: scale(0.95);
        }
</style>

<main class="container mx-auto px-6 py-12 mt-20 text-left" dir="ltr">
    @if (isLoading)
    {
        <div class="flex flex-col items-center justify-center py-40">
            <div class="w-16 h-16 border-4 border-orange-200 border-t-orange-600 rounded-full animate-spin"></div>
            <p class="mt-6 text-orange-600 font-bold animate-pulse tracking-widest">LOADING DATA...</p>
        </div>
    }
    else if (AnimalItem == null)
    {
        <div class="text-center p-20 vibrant-card max-w-2xl mx-auto border-dashed">
            <i class="fas fa-search text-5xl text-orange-200 mb-6 block"></i>
            <h2 class="text-2xl font-bold text-slate-800">Animal not found!</h2>
        </div>
    }
    else
    {
        @* إضافة items-stretch لضمان تناسق الطول بصرياً *@
        <div class="flex flex-col lg:flex-row gap-12 mb-10 items-stretch">
            @* الجانب الأيسر: الصورة والبيانات الأساسية *@
            <div class="lg:w-2/5 group flex flex-col relative">
                <div class="relative rounded-[3rem] overflow-hidden bg-slate-900 border-4 border-white shadow-xl flex-grow">

                    @* تعديل عرض الصور واستخدام نظام الـ Index والأسهم *@
                    @if (AnimalItem.animalImages != null && AnimalItem.animalImages.Any())
                    {
                        @* تم استخدام ElementAt لحل مشكلة الـ ICollection *@
                        <img src="@(AnimalItem.animalImages.ElementAt(currentImageIndex).Image)"
                             class="w-full h-[500px] object-cover transition-transform duration-1000 group-hover:scale-110" />

                        @* أزرار التنقل بين الصور *@
                        @if (AnimalItem.animalImages.Count > 1)
                        {
                            <button type="button" @onclick="PrevImg" class="absolute left-4 top-1/2 -translate-y-1/2 z-20 bg-black/40 hover:bg-orange-600 p-4 rounded-full text-white transition-all shadow-lg border border-white/10">
                                <i class="fas fa-chevron-left"></i>
                            </button>

                            <button type="button" @onclick="NextImg" class="absolute right-4 top-1/2 -translate-y-1/2 z-20 bg-black/40 hover:bg-orange-600 p-4 rounded-full text-white transition-all shadow-lg border border-white/10">
                                <i class="fas fa-chevron-right"></i>
                            </button>

                            @* عداد الصور الصغير في الأعلى *@
                            <div class="absolute top-6 right-6 z-20 bg-orange-600/90 backdrop-blur-md px-4 py-1.5 rounded-full text-[11px] text-white font-black tracking-widest shadow-lg">
                                <i class="fas fa-images mr-1"></i> @(currentImageIndex + 1) / @AnimalItem.animalImages.Count
                            </div>
                        }
                    }
                    else
                    {
                        <img src="e.png" class="w-full h-[500px] object-cover" />
                    }

                    @* شريط البيانات السريع على الصورة - تم تصحيح الكلاس bg-gradient-to-t *@
                    <div class="absolute bottom-0 left-0 w-full p-8 bg-gradient-to-t from-black/90 via-black/40 to-transparent text-white z-10">
                        <div class="grid grid-cols-3 gap-4 text-center">
                            <div>
                                <p class="text-xl font-black uppercase">@AnimalItem.Gender</p>
                                <p class="text-[9px] tracking-widest opacity-60">GENDER</p>
                            </div>
                            <div class="border-x border-white/20">
                                <p class="text-xl font-black text-orange-400 uppercase">@breedName</p>
                                <p class="text-[9px] tracking-widest opacity-60">BREED</p>
                            </div>
                            <div>
                                <p class="text-xl font-black uppercase">@typeName</p>
                                <p class="text-[9px] tracking-widest opacity-60">TYPE</p>
                            </div>
                        </div>
                    </div>
                </div>

                @* ربط الزر بحدث HandleAdoptionClick وتعديل النص للـ Upper *@
                <button type="button" @onclick="HandleAdoptionClick" class="btn-adopt w-full mt-8 bg-orange-600 hover:bg-orange-700 text-white font-black py-6 rounded-[2rem] flex items-center justify-center gap-3 shadow-lg shadow-orange-600/20">
                    <i class="fas fa-heart group-hover:animate-ping"></i>
                    <span>ADOPT @(AnimalItem.Name?.ToUpper() ?? "PET")</span>
                </button>
            </div>
            @* الجانب الأيمن: تفاصيل البيانات الكاملة *@
            <div class="lg:w-3/5 flex flex-col justify-between space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

                    @* بطاقة المعلومات الأساسية *@
                    <div class="vibrant-card p-8 shadow-sm">
                        <h3 class="text-lg font-black text-slate-800 mb-6 flex items-center gap-3">
                            <i class="fas fa-info-circle text-orange-500"></i> Basic Info
                        </h3>
                        <div class="space-y-4 text-sm">
                            <div class="flex justify-between items-center">
                                <span class="text-slate-400">Full Name</span>
                                <span class="font-bold text-slate-800">@AnimalItem.Name</span>
                            </div>
                            <div class="flex justify-between items-center border-t border-orange-100/30 pt-4">
                                <span class="text-slate-400">Primary Color</span>
                                <span class="font-bold text-slate-800">@AnimalItem.Color</span>
                            </div>
                            <div class="flex justify-between items-center border-t border-orange-100/30 pt-4">
                                <span class="text-slate-400">Age</span>
                                <span class="font-black text-orange-600">
                                    @{
                                        var currentAge = DateTime.Now.Year - AnimalItem.BirthDate.Year;
                                        if (AnimalItem.BirthDate.Date > DateTime.Now.AddYears(-currentAge)) currentAge--;
                                        <span>@(currentAge <= 0 ? "Less than a year" : $"{currentAge} Year(s)")</span>
                                    }
                                </span>
                            </div>
                            <div class="flex justify-between items-center border-t border-orange-100/30 pt-4">
                                <span class="text-slate-400">Status</span>
                                @{
                                    string sText = "No Data"; // نص أولي للكشف فقط
                                    string sClass = "text-slate-400";

                                    if (AnimalItem != null && AnimalItem.Status != null)
                                    {
                                        // محاولة التحويل لرقم
                                        bool isNumber = int.TryParse(AnimalItem.Status.ToString(), out int statusValue);

                                        if (isNumber)
                                        {
                                            switch (statusValue)
                                            {
                                                case 1: sText = "AvailableForAdoption"; sClass = "text-green-600"; break;
                                                case 2: sText = "FosterCare"; sClass = "text-blue-500"; break;
                                                case 3: sText = "Adopted"; sClass = "text-red-500"; break;
                                                case 4: sText = "UnAvailableForAdoption"; sClass = "text-orange-500"; break;
                                                default: sText = "Status Number: " + statusValue; sClass = "text-purple-600"; break;
                                            }
                                        }
                                        else
                                        {
                                            // إذا كانت الحالة نصية وليست رقماً
                                            sText = " " + AnimalItem.Status.ToString();
                                        }
                                    }
                                }
                                <span class="font-black uppercase text-xs @sClass">@sText</span>
                            </div>
                        </div>
                    </div>

                    @* بطاقة الموقع والطبيعة *@
                    <div class="vibrant-card p-8 shadow-sm">
                        <h3 class="text-lg font-black text-slate-800 mb-6 flex items-center gap-3">
                            <i class="fas fa-map-marked-alt text-slate-600"></i> Location
                        </h3>
                        <div class="space-y-4 text-sm">
                            <div class="flex justify-between items-center">
                                <span class="text-slate-400">Country</span>
                                <span class="font-bold text-slate-800">@AnimalItem.Country</span>
                            </div>
                            <div class="flex justify-between items-center border-t border-orange-100/30 pt-4">
                                <span class="text-slate-400">City</span>
                                <span class="font-bold text-slate-800">@AnimalItem.City</span>
                            </div>
                            <div class="flex justify-between items-center border-t border-orange-100/30 pt-4">
                                <span class="text-slate-400">Is Pet</span>
                                <span class="font-bold text-slate-800">@(AnimalItem.IsPet ? "Yes" : "No")</span>
                            </div>
                            <div class="flex justify-between items-center border-t border-orange-100/30 pt-4">
                                <span class="text-slate-400">Is Tame</span>
                                <span class="font-bold text-slate-800">@(AnimalItem.IsAnimalTame ? "Yes" : "No")</span>
                            </div>
                        </div>
                    </div>
                </div>

                @* بطاقة السجل الصحي *@
                <div class="vibrant-card p-10 flex-grow shadow-sm">
                    <h3 class="text-xl font-black text-slate-800 mb-8 flex items-center gap-3">
                        <i class="fas fa-notes-medical text-orange-600"></i> Health & Medical
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                        @* التطعيمات *@
                        <div>
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Vaccinations</p>
                            @if (AnimalItem.AnimalVaccination?.Any() == true)
                            {
                                <div class="flex flex-wrap gap-2">
                                    @foreach (var vac in AnimalItem.AnimalVaccination)
                                    {
                                        <span class="px-3 py-1 bg-white text-orange-700 rounded-lg text-[11px] font-bold border border-orange-100 shadow-sm">@vac.Vaccination</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-xs text-slate-300 italic">No records.</p>
                            }
                        </div>
                        @* العمليات *@
                        <div>
                            <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-4">Surgical Operations</p>
                            @if (AnimalItem.animalSurgicalOperations?.Any() == true)
                            {
                                <div class="space-y-3">
                                    @foreach (var op in AnimalItem.animalSurgicalOperations)
                                    {
                                        <div class="p-3 bg-white/60 rounded-2xl border border-orange-50 shadow-sm">
                                            <div class="flex justify-between items-center mb-1">
                                                <span class="font-bold text-slate-800 text-[12px]">@op.SurgicalOperation</span>
                                                <span class="text-[9px] text-slate-400">@(op.Date?.ToString("yyyy-MM-dd") ?? "No Date")</span>
                                            </div>
                                            <p class="text-[10px] font-black uppercase @(op.OperationStatus == "Success" ? "text-green-600" : "text-orange-500")">@op.OperationStatus</p>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="text-xs text-slate-300 italic">No records.</p>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @* قسم الوصف كامل العرض *@
        <div class="w-full mb-20 group">
            <div class="vibrant-card p-12 relative overflow-hidden">
                <div class="absolute -right-10 -bottom-10 text-orange-500/5 text-[15rem] transform rotate-12 transition-transform duration-1000 group-hover:rotate-0">
                    <i class="fas fa-paw"></i>
                </div>
                <h3 class="text-2xl font-black text-slate-800 mb-6 flex items-center gap-3">
                    <i class="fas fa-quote-left text-orange-500 animate-pulse"></i> Full Description
                </h3>
                <p class="text-slate-500 leading-relaxed font-medium italic text-xl max-w-5xl relative z-10">
                    "@(string.IsNullOrEmpty(AnimalItem.Description) ? "No description available for this animal yet." : AnimalItem.Description)"
                </p>
            </div>
        </div>
    }
</main>