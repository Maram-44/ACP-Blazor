@page "/ResetPassword"
@layout Empty
@using System.ComponentModel.DataAnnotations
@inject AccountService accountService
@inject NavigationManager NavigationManager

<div class="w-full h-full flex bg-white h-screen overflow-hidden">
    <!-- القسم الجانبي (الأيسر) مثل صفحة نسيان الباسوورد -->
    <div class="hidden lg:flex w-5/12 relative bg-slate-900 flex-col justify-between overflow-hidden">
        <div class="absolute inset-0 z-0">
            <img src="https://images.unsplash.com/photo-1534361960057-19889db9621e?ixlib=rb-4.0.3&auto=format&fit=crop&w=1950&q=80"
                 class="w-full h-full object-cover opacity-70" alt="Dog waiting patiently">
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/50 to-transparent"></div>
        </div>
        <div class="relative z-10 p-12">
            <span class="text-xl font-bold tracking-tight text-white">Alef Care Systems</span>
        </div>
        <div class="relative z-10 p-12">
            <div class="bg-white/10 backdrop-blur-md border border-white/20 p-6 rounded-3xl max-w-sm">
                <p class="text-white text-lg font-medium leading-relaxed mb-2">"Secure your account with a strong password."</p>
            </div>
        </div>
    </div>

    <!-- القسم الأيمن (الفورم) -->
    <div class="w-full lg:w-7/12 overflow-y-auto bg-white relative">
        <div class="flex flex-col items-center justify-start min-h-full px-4 sm:px-12 pt-0 pb-10">
            <div class="w-full max-w-[500px]">

                <div class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm py-6 mb-20">
                    <div class="flex items-center gap-2">
                        <span class="text-4xl font-extrabold tracking-tighter text-slate-900">Alef</span>
                        <span class="text-3xl transform rotate-12 inline-block">🐾</span>
                    </div>
                </div>

                <div class="mb-8">
                    <h1 class="text-3xl font-bold text-slate-900 mb-3">Reset Password</h1>
                    <p class="text-slate-500 text-base leading-relaxed">Enter your new strong password below.</p>
                </div>

                @if (isSuccess)
                {
                    <div class="bg-green-50 border border-green-200 text-green-700 p-6 rounded-2xl mb-6 text-center">
                        <h3 class="text-xl font-bold mb-2">Success!</h3>
                        <p class="text-sm text-green-600 mb-4">Your password has been reset successfully.</p>
                        <a href="/login" class="inline-block bg-green-600 text-white px-6 py-2 rounded-xl font-bold">Go to Sign In</a>
                    </div>
                }
                else
                {
                    <EditForm Model="@resetModel" OnValidSubmit="HandleResetPassword" class="space-y-6">
                        <DataAnnotationsValidator />

                        @if (errorMessages.Any())
                        {
                            <div class="p-4 bg-red-50 border border-red-200 text-red-600 rounded-2xl text-sm space-y-1">
                                @foreach (var err in errorMessages)
                                {
                                    <p>• @err</p>
                                }
                            </div>
                        }

                        <!-- حقل كلمة المرور الجديدة -->
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-slate-900 ml-1">New Password</label>
                            <InputText type="password" @bind-Value="resetModel.NewPassword"
                                       class="w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-2xl text-slate-900 focus:bg-white focus:ring-4 focus:ring-orange-100 focus:border-orange-600 outline-none font-medium transition-all" />
                            <ValidationMessage For="@(() => resetModel.NewPassword)" class="text-red-500 text-xs" />
                        </div>

                        <!-- حقل تأكيد كلمة المرور -->
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-slate-900 ml-1">Confirm Password</label>
                            <InputText type="password" @bind-Value="resetModel.ConfirmPassword"
                                       class="w-full px-5 py-4 bg-slate-50 border border-slate-200 rounded-2xl text-slate-900 focus:bg-white focus:ring-4 focus:ring-orange-100 focus:border-orange-600 outline-none font-medium transition-all" />
                            <ValidationMessage For="@(() => resetModel.ConfirmPassword)" class="text-red-500 text-xs" />
                        </div>

                        <button type="submit" disabled="@isSubmitting"
                                class="w-full py-4 bg-orange-600 hover:bg-orange-700 text-white font-bold rounded-2xl shadow-lg transform hover:-translate-y-0.5 transition-all text-lg flex justify-center items-center disabled:opacity-50">
                            @(isSubmitting ? "Updating..." : "Reset Password")
                        </button>
                    </EditForm>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private ResetPasswordFormModel resetModel = new();
    private bool isSubmitting = false;
    private bool isSuccess = false;
    private List<string> errorMessages = new();

    // التقاط الـ Token والـ Email تلقائياً من الرابط (Query Strings)
    [Parameter]
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    [Parameter]
    [SupplyParameterFromQuery(Name = "email")]
    public string? Email { get; set; }

    protected override void OnInitialized()
    {
        // نقل القيم مباشرة إلى الـ resetModel
        if (!string.IsNullOrEmpty(Token)) resetModel.Token = Token;
        if (!string.IsNullOrEmpty(Email)) resetModel.Email = Email;

        // حماية: إذا كانت القيم مفقودة يتم التنبيه
        if (string.IsNullOrEmpty(resetModel.Token) || string.IsNullOrEmpty(resetModel.Email))
        {
            errorMessages.Add("Invalid or expired password reset link. Please request a new one.");
        }
    }

    private async Task HandleResetPassword()
    {
        if (errorMessages.Any() && (string.IsNullOrEmpty(resetModel.Token) || string.IsNullOrEmpty(resetModel.Email))) return;

        isSubmitting = true;
        errorMessages.Clear();

        var result = await accountService.ResetPasswordAsync(resetModel);

        if (result.IsSuccess)
        {
            isSuccess = true;
            isSubmitting = false; // نوقف حالة التحميل ليظهر التصميم بشكل صحيح

            // إجبار الواجهة على التحديث لإظهار رسالة النجاح
            StateHasChanged();

            // انتظر 3 ثوانٍ ليقرأ المستخدم رسالة النجاح
            await Task.Delay(3000);

            // الانتقال إلى صفحة تسجيل الدخول (قم بتعديل المسار "/login" حسب اسم صفحتك)
            NavigationManager.NavigateTo("/login");
        }
        else
        {
            errorMessages = result.Errors ?? new List<string> { "Failed to reset password." };
        }

        isSubmitting = false;
    }

    public class ResetPasswordFormModel
    {
        public string Token { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required")]
        [MinLength(8, ErrorMessage = "Minimum 8 characters")]
        // التحقق من: حرف كبير، حرف صغير، رقم، ورمز خاص
        [RegularExpression(@"^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&])[A-Za-z\d@$!%*?&]{8,}$",
            ErrorMessage = "Password must have: Uppercase, Lowercase, Number, and Special Character (@$!%*?&).")]
        public string NewPassword { get; set; } = string.Empty;

        [Required(ErrorMessage = "Please confirm your password.")]
        [Compare("NewPassword", ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}