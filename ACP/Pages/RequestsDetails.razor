@page "/requests-details/{AnimalId:int}"
@using ACP.Models.Customers
@using ACP.Models.Animals
@inject IJSRuntime JS

@* --- الواجهة الرئيسية --- *@
<div class="min-h-screen bg-white font-sans text-slate-900 pb-20" dir="ltr">

    <main class="container mx-auto px-4 lg:px-6 pt-10">

        @* --- 1. كارد الحيوان (Hero Section) --- *@
        <section class="relative overflow-hidden bg-[#1e293b] rounded-[2rem] lg:rounded-[3rem] p-8 lg:p-16 flex flex-col lg:flex-row items-center justify-between gap-10 shadow-2xl mt-16 mb-12 w-full mx-auto">

            @* أيقونة طبعة القدم الخلفية *@
            <i class="fas fa-paw absolute -right-8 -bottom-12 text-[15rem] text-white/[0.03] -rotate-12 pointer-events-none z-0"></i>

            <div class="relative z-10 text-center lg:text-left flex-1">
                <span class="bg-[#ea580c] text-white px-4 py-1.5 rounded-lg text-[10px] font-black uppercase tracking-wider">
                    Pet Case Study
                </span>
                <h1 class="text-4xl lg:text-6xl font-bold mt-4 text-white">@animalItem?.Name</h1>
                <p class="text-slate-400 mt-4 text-base lg:text-lg max-w-md italic mx-auto lg:mx-0">
                    "@animalItem?.Description"
                </p>
            </div>

            @* الإحصائيات (تترتب 2x2 في الجوال) *@
            <div class="relative z-10 grid grid-cols-2 md:grid-cols-4 lg:flex items-center gap-6 lg:gap-0 w-full lg:w-auto">
                <div class="lg:border-r lg:border-white/10 lg:px-10 text-center">
                    <p class="text-[#ea580c] text-[10px] font-black uppercase mb-1">Breed</p>
                    <p class="text-white text-lg lg:text-2xl font-semibold">@animalItem?.Color</p>
                </div>
                <div class="lg:border-r lg:border-white/10 lg:px-10 text-center">
                    <p class="text-[#ea580c] text-[10px] font-black uppercase mb-1">Gender</p>
                    <p class="text-white text-lg lg:text-2xl font-semibold">@animalItem?.Gender</p>
                </div>
                <div class="lg:border-r lg:border-white/10 lg:px-10 text-center">
                    <p class="text-[#ea580c] text-[10px] font-black uppercase mb-1">City</p>
                    <p class="text-white text-lg lg:text-2xl font-semibold">@animalItem?.City</p>
                </div>
                <div class="lg:px-10 text-center">
                    <p class="text-[#ea580c] text-[10px] font-black uppercase mb-1">Age</p>
                    <p class="text-white text-lg lg:text-2xl font-semibold">@CalculateAge(animalItem?.BirthDate)</p>
                </div>
            </div>
        </section>

        @if (isAcceptedState)
        {
            @* --- كارد المتقدم المقبول (البيانات كاملة) --- *@
            <div class="bg-white rounded-[2rem] lg:rounded-[3rem] p-6 lg:p-16 shadow-[0_10px_40px_rgba(0,0,0,0.04)] mx-auto max-w-[1200px] border border-slate-50 animate-in fade-in slide-in-from-bottom-5 duration-700">

                @* الهيدر: الاسم وزر الاتصال *@
                <div class="flex flex-col lg:flex-row justify-between items-center border-b border-slate-100 pb-8 gap-6">
                    <div class="flex items-center gap-6">
                        <div class="w-20 h-20 bg-orange-100 text-[#ea580c] rounded-[1.5rem] flex items-center justify-center text-4xl font-black shadow-inner">
                            @selectedApplicant?.FirstName[0]
                        </div>
                        <div class="text-center lg:text-left">
                            <h2 class="text-3xl lg:text-4xl font-bold text-slate-900">@selectedApplicant?.FirstName @selectedApplicant?.LastName</h2>
                            <p class="text-green-500 font-bold text-sm mt-1 flex items-center justify-center lg:justify-start gap-2">
                                <i class="fas fa-check-circle"></i> Identity Verified • Handover Active
                            </p>
                        </div>
                    </div>
                    <a href="tel:@selectedApplicant?.PhoneNumber" class="w-full lg:w-auto px-10 py-4 bg-slate-900 text-white rounded-2xl font-bold hover:bg-black transition-all flex items-center justify-center gap-3 shadow-lg">
                        <i class="fas fa-phone-alt"></i> Call Adopter
                    </a>
                </div>

                @* شبكة البيانات التفصيلية (تأكد من وجود الـ 5 صناديق هنا) *@
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 mt-10">

                    @* 1. نوع الهوية *@
                    <div class="bg-slate-50/50 border border-slate-100 rounded-2xl p-6 flex items-center gap-4">
                        <div class="w-12 h-12 bg-white text-[#ea580c] rounded-xl flex items-center justify-center shadow-sm"><i class="fas fa-id-card"></i></div>
                        <div><p class="text-[#ea580c] text-[10px] font-black uppercase tracking-wider">Identity Type</p><p class="font-bold text-slate-700 text-lg">@selectedApplicant?.TypeOfIdentity</p></div>
                    </div>

                    @* 2. رقم الهوية *@
                    <div class="bg-slate-50/50 border border-slate-100 rounded-2xl p-6 flex items-center gap-4">
                        <div class="w-12 h-12 bg-white text-[#ea580c] rounded-xl flex items-center justify-center shadow-sm"><i class="fas fa-fingerprint"></i></div>
                        <div><p class="text-[#ea580c] text-[10px] font-black uppercase tracking-wider">ID Number</p><p class="font-bold text-slate-700 text-lg">@selectedApplicant?.IdentityNumber</p></div>
                    </div>

                    @* 3. الجنسية *@
                    <div class="bg-slate-50/50 border border-slate-100 rounded-2xl p-6 flex items-center gap-4">
                        <div class="w-12 h-12 bg-white text-[#ea580c] rounded-xl flex items-center justify-center shadow-sm"><i class="fas fa-globe"></i></div>
                        <div><p class="text-[#ea580c] text-[10px] font-black uppercase tracking-wider">Nationality</p><p class="font-bold text-slate-700 text-lg">@selectedApplicant?.Nationality</p></div>
                    </div>

                    @* 4. رقم الجوال *@
                    <div class="bg-slate-50/50 border border-slate-100 rounded-2xl p-6 flex items-center gap-4">
                        <div class="w-12 h-12 bg-white text-[#ea580c] rounded-xl flex items-center justify-center shadow-sm"><i class="fas fa-mobile-alt"></i></div>
                        <div><p class="text-[#ea580c] text-[10px] font-black uppercase tracking-wider">Phone Number</p><p class="font-bold text-slate-700 text-lg">@selectedApplicant?.PhoneNumber</p></div>
                    </div>

                    @* 5. البريد الإلكتروني (يأخذ مساحتين في الشاشات الكبيرة ليملأ الفراغ) *@
                    <div class="bg-slate-50/50 border border-slate-100 rounded-2xl p-6 flex items-center gap-4 lg:col-span-2">
                        <div class="w-12 h-12 bg-white text-[#ea580c] rounded-xl flex items-center justify-center shadow-sm"><i class="fas fa-envelope"></i></div>
                        <div><p class="text-[#ea580c] text-[10px] font-black uppercase tracking-wider">Email Address</p><p class="font-bold text-slate-700 text-lg">@selectedApplicant?.Email</p></div>
                    </div>

                </div>

                @* منطقة الـ OTP تبقى كما هي *@
                <div class="bg-[#0f172a] rounded-[2rem] p-8 lg:p-12 mt-10 text-center relative z-20">
                    <p class="text-white/60 text-[10px] font-black uppercase mb-2 tracking-widest">Final Verification</p>
                    <p class="text-white text-sm">Enter the code provided by @selectedApplicant?.FirstName to finish delivery</p>
                    <div class="flex justify-center gap-2 md:gap-4 mt-8">
                        @for (int i = 0; i < 6; i++)
                        {
                            var index = i;
                            <input id="otp-@index" type="text" inputmode="numeric" maxlength="1" class="w-11 h-16 md:w-16 md:h-20 rounded-xl border-none bg-white text-center text-2xl lg:text-3xl font-black focus:ring-4 focus:ring-[#ea580c] transition-all outline-none text-slate-900 shadow-xl" oninput="moveNext(this, @index)" onkeydown="moveBack(event, @index)" />
                        }
                    </div>
                </div>
            </div>
        }
        else
        {
            @* --- 3. قائمة المتقدمين (قبل الموافقة) --- *@
            <div class="max-w-[1200px] mx-auto">
                <div class="mb-8 flex flex-col md:flex-row items-center justify-between px-4 gap-4">
                    <h3 class="text-3xl font-bold text-slate-800 tracking-tight">Interested Adopters</h3>
                    <span class="bg-orange-50 text-[#ea580c] px-6 py-2 rounded-full font-black text-xs border border-orange-100">@applicants.Count REQUESTS</span>
                </div>

                <div class="grid gap-6">
                    @foreach (var app in applicants)
                    {
                        <div class="bg-white rounded-[2rem] p-6 lg:p-10 flex flex-col lg:flex-row items-center gap-8 border border-slate-100 shadow-sm hover:shadow-md transition-all">
                            <div class="w-20 h-20 bg-slate-50 border-2 border-dashed border-slate-200 rounded-2xl flex items-center justify-center text-3xl text-slate-300 font-bold">@app.FirstName[0]</div>
                            <div class="flex-grow text-center lg:text-left space-y-2">
                                <h4 class="text-2xl font-bold text-slate-800">@app.FirstName @app.LastName</h4>
                                <div class="flex justify-center lg:justify-start gap-6">
                                    <div class="flex items-center gap-2 text-slate-500">
                                        <i class="fas fa-id-card text-[#ea580c]"></i>
                                        <span class="text-sm font-semibold">@app.TypeOfIdentity</span>
                                    </div>
                                    <div class="flex items-center gap-2 text-slate-500">
                                        <i class="fas fa-globe text-[#ea580c]"></i>
                                        <span class="text-sm font-semibold">@app.Nationality</span>
                                    </div>
                                </div>
                            </div>
                            <div class="flex gap-3 w-full lg:w-auto">
                                <button class="flex-1 lg:flex-none bg-[#ea580c] text-white px-8 py-4 rounded-xl font-bold hover:bg-[#d44d0b] transition-colors shadow-lg shadow-orange-100" @onclick="() => RequestAcceptance(app)">Accept Request</button>
                                <button class="flex-1 lg:flex-none bg-white border-2 border-slate-100 text-slate-400 px-8 py-4 rounded-xl font-bold hover:bg-slate-50 transition-colors" @onclick="() => applicants.Remove(app)">Decline</button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </main>

    @* --- بوب أب التأكيد (Confirm Modal) --- *@
    @if (showConfirmModal)
    {
        <div class="fixed inset-0 z-[2000] flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm">
            <div class="bg-white p-8 lg:p-12 rounded-[2.5rem] text-center max-w-md w-full shadow-2xl">
                <div class="w-20 h-20 bg-orange-50 text-[#ea580c] rounded-full flex items-center justify-center mx-auto mb-6 text-3xl">
                    <i class="fas fa-question-circle"></i>
                </div>
                <h3 class="text-2xl font-bold text-slate-900 mb-2">Are you sure?</h3>
                <p class="text-slate-500 mb-10 text-sm leading-relaxed px-4">Accepting @appToAccept?.FirstName's request will share contact information.</p>
                <div class="flex gap-4">
                    <button class="flex-1 py-4 text-slate-400 font-bold hover:text-slate-600" @onclick="CancelAcceptance">Cancel</button>
                    <button class="flex-1 py-4 bg-[#ea580c] text-white rounded-2xl font-bold shadow-lg hover:bg-[#d44d0b]" @onclick="ConfirmAcceptance">Yes, Accept</button>
                </div>
            </div>
        </div>
    }

</div>

@* --- كود الجافاسكريبت للـ OTP --- *@
<script>
    function moveNext(el, index) {
        if (el.value.length === 1 && index < 5) {
            const next = document.getElementById('otp-' + (index + 1));
            if (next) next.focus();
        }
    }
    function moveBack(event, index) {
        if (event.key === "Backspace" && !event.target.value && index > 0) {
            const prev = document.getElementById('otp-' + (index - 1));
            if (prev) prev.focus();
        }
    }
</script>

@code {
    [Parameter] public int AnimalId { get; set; }
    private Animal? animalItem;
    private List<Customer> applicants = new();
    private Customer? selectedApplicant;
    private Customer? appToAccept;
    private bool isAcceptedState = false;
    private bool showConfirmModal = false;

    protected override void OnInitialized()
    {
        // بيانات تجريبية (يتم استبدالها لاحقاً بـ API)
        animalItem = new Animal { Name = "Milo", Description = "Friendly companion looking for a home.", City = "Jeddah", Gender = "Male", Color = "Golden Retriever", BirthDate = new DateTime(2021, 1, 1) };
        applicants = new List<Customer> {
            new Customer { CustomerId = 1, FirstName = "Ahmad", LastName = "Al-Ali", Nationality = "Saudi", TypeOfIdentity = "National ID", IdentityNumber = "1092837465", PhoneNumber = "+966 50 123 4567", Email = "ahmed.ali@example.com" },
            new Customer { CustomerId = 2, FirstName = "Sara", LastName = "Al-Khaledi", Nationality = "Saudi", TypeOfIdentity = "Passport", IdentityNumber = "L12345678", PhoneNumber = "+966 55 987 6543", Email = "sara.kh@example.com" }
        };
    }

    private void RequestAcceptance(Customer app) { appToAccept = app; showConfirmModal = true; }
    private void CancelAcceptance() { appToAccept = null; showConfirmModal = false; }
    private void ConfirmAcceptance() { selectedApplicant = appToAccept; isAcceptedState = true; showConfirmModal = false; }
    private string CalculateAge(DateTime? birthDate) => "3 Years";
}