@page "/cart"
@namespace ACP.Pages
@using ACP.Models.Products

<main class="flex flex-col justify-center min-h-[80vh] container mx-auto px-6 lg:px-20 py-24">

    @if (CartItems == null)
    {
        <div class="flex justify-center items-center font-bold text-slate-400">
            <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-orange-600 mr-3"></div>
            Loading...
        </div>
    }
    else if (!CartItems.Any())
    {
        <div class="flex flex-col items-center justify-center animate-fade-in">
            <div class="mb-6 opacity-20">
                <svg class="w-32 h-32 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
                </svg>
            </div>
            <h2 class="text-3xl font-extrabold text-[#0f172a] mb-2">Your cart is empty</h2>
            <p class="text-slate-400 font-medium mb-8">Add some products to get started!</p>
            <button @onclick='() => Navigation.NavigateTo("/browse-products")'
                    class="bg-[#ff4f00] text-white px-10 py-4 rounded-2xl font-extrabold text-lg hover:shadow-2xl hover:bg-orange-700 transition-all">
                Start Shopping
            </button>
        </div>
    }
    else
    {
        <div class="grid lg:grid-cols-12 gap-8 items-start animate-fade-in">
            <div class="lg:col-span-8">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-xl font-extrabold text-slate-900">Cart Items (@CartItems.Count)</h2>
                    <button @onclick="ClearAll" class="text-red-500 font-bold hover:underline">Clear All</button>
                </div>

                @foreach (var item in CartItems)
                {
                    <div class="bg-white p-6 rounded-[2rem] shadow-sm border border-slate-50 flex flex-col md:flex-row items-center gap-6 relative mb-4">
                        <button @onclick="() => RemoveItem(item)" class="absolute top-6 right-6 text-slate-300 hover:text-red-500">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                        </button>

                        <div class="w-24 h-24 rounded-2xl overflow-hidden shadow-md bg-slate-50 flex items-center justify-center">
                            <span class="text-xs text-slate-400">Item #@item.ItemId</span>
                        </div>

                        <div class="flex-1 text-center md:text-left">
                            <span class="bg-orange-50 text-orange-600 px-3 py-1 rounded-full text-[10px] font-black uppercase mb-2 inline-block">Product</span>
                            <h3 class="text-lg font-bold text-slate-900 mb-4">Product ID: @item.ItemId</h3>

                            <div class="flex items-center justify-center md:justify-start gap-4">
                                <div class="flex items-center border border-slate-200 rounded-xl px-2 py-1 bg-slate-50">
                                    <button @onclick="() => UpdateQuantity(item, item.QTY - 1)" class="w-8 h-8 flex items-center justify-center text-slate-400 font-bold">-</button>
                                    <span class="px-4 font-bold text-slate-800">@item.QTY</span>
                                    <button @onclick="() => UpdateQuantity(item, item.QTY + 1)" class="w-8 h-8 flex items-center justify-center text-slate-400 font-bold">+</button>
                                </div>
                            </div>
                        </div>

                        <div class="text-right">
                            <p class="text-[#00b987] text-2xl font-black">$26.00</p>
                        </div>
                    </div>
                }
            </div>

            <div class="lg:col-span-4 space-y-6">
                <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-50">
                    <h2 class="text-xl font-extrabold text-slate-900 mb-8 tracking-tight">Order Summary</h2>
                    <div class="space-y-4 mb-8">
                        <div class="flex justify-between text-slate-500 font-semibold">
                            <span>Subtotal</span>
                            <span>$@subtotal.ToString("F2")</span>
                        </div>
                        <div class="flex justify-between text-slate-500 font-semibold">
                            <span>Shipping</span>
                            <span>$@shipping.ToString("F2")</span>
                        </div>
                    </div>
                    <div class="border-t border-slate-100 pt-6 mb-8 flex justify-between items-center">
                        <span class="text-lg font-bold text-slate-800 tracking-tight">Total</span>
                        <span class="text-2xl font-black text-[#ff4f00]">$@((subtotal + shipping).ToString("F2"))</span>
                    </div>
                </div>

                <div class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-50 animate-fade-in">
                    <h2 class="text-xl font-extrabold text-slate-900 mb-6 tracking-tight">Payment & Shipping</h2>

                    <div class="space-y-4">
                        <div>
                            <label class="text-xs font-bold text-slate-400 uppercase ml-1">Shipping Address</label>
                            <input type="text" placeholder="Street, City, Country"
                                   class="w-full mt-1 px-5 py-3 rounded-xl border border-slate-100 bg-slate-50 focus:outline-none focus:border-orange-300 transition-all text-sm" />
                        </div>

                        <div>
                            <label class="text-xs font-bold text-slate-400 uppercase ml-1">Card Number</label>
                            <div class="relative">
                                <input type="text" placeholder="0000 0000 0000 0000"
                                       class="w-full mt-1 px-5 py-3 rounded-xl border border-slate-100 bg-slate-50 focus:outline-none focus:border-orange-300 transition-all text-sm" />
                                <div class="absolute right-4 top-1/2 -translate-y-1/2 opacity-30">
                                    <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M20 4H4c-1.11 0-1.99.89-1.99 2L2 18c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z" /></svg>
                                </div>
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="text-xs font-bold text-slate-400 uppercase ml-1">Expiry</label>
                                <input type="text" placeholder="MM/YY"
                                       class="w-full mt-1 px-5 py-3 rounded-xl border border-slate-100 bg-slate-50 focus:outline-none focus:border-orange-300 transition-all text-sm" />
                            </div>
                            <div>
                                <label class="text-xs font-bold text-slate-400 uppercase ml-1">CVV</label>
                                <input type="password" placeholder="***"
                                       class="w-full mt-1 px-5 py-3 rounded-xl border border-slate-100 bg-slate-50 focus:outline-none focus:border-orange-300 transition-all text-sm" />
                            </div>
                        </div>
                    </div>

                    <button @onclick="ProceedToCheckout"
                            class="w-full mt-8 bg-[#0f172a] text-white py-5 rounded-[1.5rem] font-extrabold text-lg shadow-xl hover:bg-slate-800 transition-all flex items-center justify-center gap-2">
                        <span>Place Order Now</span>
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                    </button>
                </div>
            </div>
        </div>
    }
</main>