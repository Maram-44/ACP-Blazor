@page "/my-animals"
@using ACP.Models.Animals

<main class="container mx-auto px-6 py-24 max-w-7xl font-sans text-right" dir="ltr">
    <div class="flex flex-col lg:flex-row gap-10">

        @* لوحة التحكم *@
        <div class="lg:w-1/3 space-y-8 text-left">
            <div class="bg-slate-900 p-10 rounded-[3.5rem] text-white shadow-2xl relative border border-slate-800 overflow-hidden">
                <div class="relative z-10">
                    <h2 class="text-3xl font-black tracking-tight mb-3">Control Panel</h2>
                    <p class="text-slate-400 text-sm leading-relaxed mb-8">Manage your pets and track their status efficiently.</p>

                    <div class="space-y-4">
                        <button @onclick='() => ChangeTab("RequestCareForm")' class="w-full bg-[#ff4f00] hover:bg-orange-600 p-5 rounded-[1.5rem] font-extrabold flex items-center justify-between transition-all transform hover:-translate-y-1 shadow-lg shadow-orange-500/20">
                            <span>Request Foster Care</span>
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
                        </button>

                        <button @onclick="OpenRelinquishConfirmation" class="w-full bg-slate-800 hover:bg-slate-700 p-5 rounded-[1.5rem] font-extrabold flex items-center justify-between transition-all border border-slate-700">
                            <span>Relinquish Animal</span>
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                        </button>
                    </div>
                </div>
                <div class="absolute -right-16 -bottom-16 w-48 h-48 bg-orange-500/20 rounded-full blur-[60px]"></div>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div class="bg-white p-6 rounded-[2.5rem] border border-slate-100 shadow-sm text-center">
                    <span class="block text-3xl font-black text-slate-800">@AnimalsList.Count</span>
                    <span class="text-[10px] text-slate-400 uppercase font-black tracking-widest mt-1 block">Total Animals</span>
                </div>
                <div class="bg-orange-50 p-6 rounded-[2.5rem] border border-orange-100 shadow-sm text-center">
                    <span class="block text-3xl font-black text-orange-600">@AnimalsList.Count(a => a.Status == "Pending")</span>
                    <span class="text-[10px] text-orange-400 uppercase font-black tracking-widest mt-1 block">Pending Requests</span>
                </div>
            </div>
        </div>

        @* القائمة *@
        <div class="lg:w-2/3">
            <div class="bg-white p-5 rounded-[4rem] shadow-sm border border-slate-50 min-h-[600px]">

                <div class="flex p-2 bg-slate-100/50 rounded-[2.5rem] mb-10">
                    <button @onclick='() => ChangeTab("Adoption")' class="flex-1 py-4 px-6 rounded-[2rem] text-xs font-black transition-all @(selectedTab == "Adoption" ? "bg-white shadow-sm text-orange-600" : "text-slate-500")">ADOPTION</button>
                    <button @onclick='() => ChangeTab("Foster")' class="flex-1 py-4 px-6 rounded-[2rem] text-xs font-black transition-all @(selectedTab == "Foster" ? "bg-white shadow-sm text-green-600" : "text-slate-500")">FOSTER</button>
                    <button @onclick='() => ChangeTab("AllAnimals")' class="flex-1 py-4 px-6 rounded-[2rem] text-xs font-black transition-all @(selectedTab == "AllAnimals" ? "bg-white shadow-sm text-slate-900" : "text-slate-500")">ALL ANIMALS</button>
                </div>

                <div class="space-y-6 px-2">
                    @{
                        var filtered = GetFilteredAnimals();
                    }
                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="p-10 text-center bg-slate-50 rounded-[3rem] border border-dashed border-slate-200">
                            <p class="text-slate-400 font-bold">@ErrorMessage</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var animal in filtered)
                        {
                            // تعريف متغير int صريح داخل الحلقة التكرارية لمنع خطأ تحويل المعرفات تماماً
                            int currentAnimalId = animal.AnimalId.HasValue ? animal.AnimalId.Value : 0;
                            <div class="flex flex-col md:flex-row items-center p-6 bg-white rounded-[2.5rem] border border-slate-100 hover:border-orange-200 transition-all mb-4 group shadow-sm">

                                <div class="relative">
                                    @{
                                        var firstImg = animal.animalImages?.FirstOrDefault()?.Image ?? "https://via.placeholder.com/300";
                                    }
                                    <img src="@firstImg" class="w-32 h-32 rounded-[2rem] object-cover border-4 border-white shadow-xl">
                                </div>

                                <div class="flex-1 md:px-8 text-left">
                                    <div class="flex items-center gap-2 mb-2">
                                        <h3 class="text-xl font-black text-slate-800">@animal.Name</h3>
                                        <span class="px-3 py-1 text-[9px] font-black rounded-full uppercase @GetTagClass(animal.Status)">
                                            @animal.Status
                                        </span>
                                    </div>
                                    <p class="text-sm text-slate-400">Date of Birth: @animal.BirthDate.ToShortDateString()</p>
                                </div>

                                @if (selectedTab == "Foster" || animal.Status == "Foster")
                                {
                                    <div class="mt-4 md:mt-0 flex flex-col items-end gap-2 border-l border-slate-100 pl-6">
                                        <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Handover Code</span>

                                        <div class="flex gap-2 bg-slate-50 p-2 rounded-2xl border border-slate-200 shadow-inner">
                                            @* استخدام الـ currentAnimalId الصريح والمعزول *@
                                            <input type="text" placeholder="Enter Code"
                                                   @bind="InputCodes[currentAnimalId]"
                                                   class="bg-transparent w-28 px-2 py-1 text-sm font-bold text-slate-700 outline-none text-center" maxlength="6" />

                                            <button type="button"
                                                    @onclick="() => HandleReturnCode(currentAnimalId)"
                                                    class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-xl text-[10px] font-black shadow-lg transition-colors">
                                                SUBMIT
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</main>

@if (isRelinquishModalOpen)
{
    <div class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm flex items-center justify-center z-50 p-4 transition-all">
        <div class="bg-white rounded-[3rem] max-w-md w-full p-8 shadow-2xl border border-slate-100 text-center">
            <div class="w-16 h-16 bg-red-50 text-red-500 rounded-full flex items-center justify-center mx-auto mb-5 border border-red-100">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                </svg>
            </div>
            <h3 class="text-2xl font-black text-slate-800 mb-2">Are you sure?</h3>
            <p class="text-sm text-slate-500 leading-relaxed mb-8">This action will open the relinquishment process. Are you sure you want to abandon or surrender the pet profile management?</p>
            <div class="flex gap-4">
                <button @onclick="CloseRelinquishConfirmation" class="flex-1 bg-slate-100 hover:bg-slate-200 text-slate-600 py-4 rounded-[1.5rem] font-black transition text-sm">Cancel</button>
                <button @onclick="ConfirmRelinquish" class="flex-1 bg-red-600 hover:bg-red-700 text-white py-4 rounded-[1.5rem] font-black shadow-lg transition text-sm">Yes, Proceed</button>
            </div>
        </div>
    </div>
}