@page "/my-requests"
@using ACP.Models.Animals

<div class="min-h-screen bg-[#FFF7ED] pt-32 pb-20 px-6">
    <div class="max-w-4xl mx-auto">

        @* --- Header Section --- *@
        <div class="mb-12 relative">
            <h1 class="text-6xl font-[900] text-slate-900 tracking-tighter leading-none mb-4">
                My <span class="text-orange-500">Happy</span><br />Requests!
            </h1>
            <p class="text-slate-500 text-xl font-bold ml-1 flex items-center gap-2">
                <span class="w-8 h-1 bg-orange-200 rounded-full"></span>
                Where the magic happens
            </p>
            <div class="absolute -top-6 -right-4 text-6xl animate-bounce">✨</div>
        </div>

        @* --- Alert Section --- *@
        @{
            var approvedAdoptions = AdoptionRequests.Count(a => a.Status == "Approved");
            var approvedFosters = FosterRequests.Count(a => a.Status == "Approved");
            var totalApproved = approvedAdoptions + approvedFosters;
        }

        @if (totalApproved > 0)
        {
            <div class="mb-8 w-full bg-white border-2 border-green-400 rounded-[2.5rem] p-6 shadow-[8px_8px_0px_0px_rgba(74,222,128,0.1)] flex flex-col md:flex-row items-center gap-6 relative overflow-hidden">
                <div class="bg-green-400 w-16 h-16 rounded-[1.5rem] flex items-center justify-center text-4xl shadow-lg rotate-3 shrink-0 z-10 animate-bounce">
                    🎊
                </div>

                <div class="flex-1 relative z-10 text-center md:text-left">
                    <h2 class="text-2xl font-black text-slate-900 uppercase italic tracking-tighter mb-1">Great News!</h2>
                    <div class="flex flex-wrap justify-center md:justify-start gap-4 mt-2">
                        @if (approvedAdoptions > 0)
                        {
                            <div class="bg-orange-50 px-4 py-2 rounded-2xl border border-orange-100 flex items-center gap-2">
                                <span class="text-lg">🐾</span>
                                <span class="text-slate-700 font-black text-sm">@approvedAdoptions Approved Adoptions</span>
                            </div>
                        }
                        @if (approvedFosters > 0)
                        {
                            <div class="bg-blue-50 px-4 py-2 rounded-2xl border border-blue-100 flex items-center gap-2">
                                <span class="text-lg">🏠</span>
                                <span class="text-slate-700 font-black text-sm">@approvedFosters Approved Fosters</span>
                            </div>
                        }
                    </div>
                </div>
                <div class="absolute -right-6 -bottom-6 w-32 h-32 bg-green-50 rounded-full opacity-50 z-0"></div>
            </div>
        }

        @* --- Tabs Section --- *@
        <div class="flex gap-6 mb-12">
            <button @onclick='() => ChangeTab("Adoption")'
                    class='px-10 py-5 rounded-[2.5rem] font-black text-lg transition-all duration-300 transform @(ActiveTab == "Adoption" ? "bg-orange-500 text-white shadow-[0_10px_20px_rgba(249,115,22,0.4)] -translate-y-2" : "bg-white text-slate-400 hover:bg-orange-50")'>
                🏠 Adoption (@AdoptionRequests.Count)
            </button>
            <button @onclick='() => ChangeTab("Foster")'
                    class='px-10 py-5 rounded-[2.5rem] font-black text-lg transition-all duration-300 transform @(ActiveTab == "Foster" ? "bg-blue-500 text-white shadow-[0_10px_20px_rgba(59,130,246,0.4)] -translate-y-2" : "bg-white text-slate-400 hover:bg-blue-50")'>
                ⏳ Foster (@FosterRequests.Count)
            </button>
        </div>

        @* --- Main Content Section --- *@
        @if (IsLoading)
        {
            <div class="flex justify-center py-24">
                <div class="w-20 h-20 border-[8px] border-slate-200 border-t-orange-500 rounded-full animate-spin"></div>
            </div>
        }
        else
        {
            <div class="grid gap-8">
                @{
                    var currentList = ActiveTab == "Adoption" ? AdoptionRequests : FosterRequests;
                }

                @if (!currentList.Any())
                {
                    <div class="bg-white rounded-[4rem] py-24 text-center border-[4px] border-dashed border-slate-200">
                        <div class="text-8xl mb-6">🏜️</div>
                        <h3 class="text-3xl font-black text-slate-800">So Quiet Here...</h3>
                        <p class="text-slate-400 font-bold mt-4">Time to fill this place with some paws!</p>
                    </div>
                }
                else
                {
                    @foreach (var app in currentList)
                    {
                        <div class="group bg-white rounded-3xl p-6 shadow-sm hover:shadow-xl border-2 border-transparent hover:border-orange-200 transition-all duration-500 flex flex-col lg:flex-row items-center justify-between gap-6">

                            <div class="flex items-center gap-6 w-full lg:w-auto">
                                @* Pet Image using animalImages from your Model *@
                                <div class="relative shrink-0">
                                    <div class="w-24 h-24 overflow-hidden rounded-2xl shadow-inner border-2 border-slate-50 bg-slate-100">
                                        @{
                                            var firstImg = app.animalImages?.FirstOrDefault()?.Image ?? "https://via.placeholder.com/300";
                                        }
                                        <img src="@firstImg"
                                             onerror="this.src='https://via.placeholder.com/300';this.onerror=null;"
                                             class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                                    </div>
                                    <div class="absolute -bottom-2 -right-2 bg-white px-2 py-1 rounded-lg shadow-sm font-black text-[10px] uppercase text-orange-500 border border-orange-50">
                                        @app.Gender
                                    </div>
                                </div>

                                <div>
                                    @* Using Name from your Model *@
                                    <h3 class="text-3xl font-[1000] text-slate-900 tracking-tighter group-hover:text-orange-500 transition-colors">@app.Name</h3>
                                    <div class="flex items-center gap-3 mt-2 bg-slate-50 px-4 py-2 rounded-xl w-fit">
                                        <span class="w-2 h-2 bg-slate-300 rounded-full"></span>
                                        @* Using BirthDate or Nationality from your Model *@
                                        <span class="text-sm font-black text-slate-400 uppercase tracking-widest">@app.Nationality • ID: @app.AnimalId</span>
                                    </div>
                                </div>
                            </div>

                            @* Status & Actions *@
                            <div class="w-full lg:w-auto text-center">
                                @if (app.Status == "Approved")
                                {
                                    <div class="flex flex-col md:flex-row items-center gap-4 p-3 bg-slate-50/80 rounded-[2rem] border border-slate-100">
                                        <div class="flex items-center gap-3 px-6 py-3 bg-green-500 text-white rounded-full shadow-lg shrink-0">
                                            <span class="relative flex h-2 w-2">
                                                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white opacity-75"></span>
                                                <span class="relative inline-flex rounded-full h-2 w-2 bg-white"></span>
                                            </span>
                                            <span class="text-[11px] font-black uppercase tracking-wider">Approved</span>
                                        </div>

                                        <div class="flex flex-col items-center md:items-start px-4">
                                            <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Handover Code</span>
                                            <div class="flex items-center bg-white p-1.5 rounded-2xl border border-slate-200 shadow-inner">
                                                <input type="text" placeholder="••••••" maxlength="6"
                                                       class="bg-transparent w-24 px-2 py-1 text-sm font-bold text-slate-700 outline-none text-center tracking-widest" />
                                                <button class="bg-slate-900 hover:bg-blue-600 text-white px-5 py-2 rounded-xl text-[10px] font-black transition-all active:scale-95">
                                                    SUBMIT
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                }
                                else if (app.Status == "Rejected")
                                {
                                    <div class="bg-slate-100 text-slate-400 px-10 py-4 rounded-full font-black text-sm uppercase tracking-widest">
                                        Closed
                                    </div>
                                }
                                else
                                {
                                    <div class="bg-white border-4 border-orange-500 text-orange-500 px-10 py-4 rounded-full font-black text-sm uppercase tracking-widest shadow-lg animate-pulse">
                                        Pending...
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        }
    </div>
</div>