@page "/clinic-details/{Id:int}"
@inherits ClinicDetailsBase

<style>
    .animal-app {
        font-family: 'Plus Jakarta Sans', sans-serif;
        background-color: #fffaf5;
        min-height: 100vh;
        background-image: radial-gradient(#ea580c05 1px, transparent 1px);
        background-size: 20px 20px;
    }

    .content-container {
        padding-top: 130px;
    }

    .info-tile {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(8px);
        border: 1px solid rgba(234, 88, 12, 0.1);
        border-radius: 1.5rem;
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

        .info-tile:hover {
            transform: translateY(-5px);
            background: white;
            border-color: #EA580C;
            box-shadow: 0 15px 30px rgba(234, 88, 12, 0.1);
        }

    .services-magic-card {
        background: white;
        border-radius: 3rem;
        border: 1px solid #fff1e2;
        padding: 3rem;
        position: relative;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0,0,0,0.03);
    }

    .magic-bg-icon {
        position: absolute;
        right: -2%;
        bottom: -10%;
        font-size: 18rem;
        color: rgba(234, 88, 12, 0.03);
        transform: rotate(-15deg);
        pointer-events: none;
        transition: all 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .services-magic-card:hover .magic-bg-icon {
        transform: rotate(0deg) scale(1.1);
        color: rgba(234, 88, 12, 0.07);
    }

    .service-tag {
        background: white;
        border: 1px solid #fff1e2;
        padding: 1rem 1.5rem;
        border-radius: 1.2rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        transition: all 0.3s;
        cursor: default;
        position: relative;
        z-index: 10;
    }

        .service-tag:hover {
            background: #EA580C;
            color: white !important;
            transform: scale(1.05);
        }

    .img-main-wrapper {
        border-radius: 3rem;
        overflow: hidden;
        border: 6px solid white;
        box-shadow: 0 25px 50px rgba(0,0,0,0.1);
        height: 480px;
    }

    .clinic-main-title {
        font-size: 2.8rem;
        font-weight: 900;
        color: #0F172A;
        letter-spacing: -0.02em;
        line-height: 1.1;
    }
</style>

<div class="animal-app pb-20">
    <div class="container mx-auto px-6 lg:px-20 content-container">
        @if (isLoading)
        {
            <div class="flex flex-col items-center justify-center py-40">
                <div class="w-12 h-12 border-4 border-orange-100 border-t-orange-600 rounded-full animate-spin"></div>
                <p class="mt-4 text-orange-600 font-bold animate-pulse">Loading Clinic Details...</p>
            </div>
        }
        else if (currentCenter != null)
        {
            <div class="flex flex-col lg:flex-row gap-16 items-start mb-16">

                @* اليسار: الصور والحالة *@
                <div class="lg:w-2/5 w-full space-y-8">
                    <div class="img-main-wrapper relative group">
                        @if (currentCenter.medicalCenterServices?.Any() == true)
                        {
                            <img src="/@currentCenter.medicalCenterServices.ElementAt(currentImageIndex).Image" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" />
                        }

                        @* كارد الحالة: يظهر دائماً ويقرأ من IsDirectBooking *@
                        <div class="absolute top-6 right-6 backdrop-blur-md px-5 py-2 rounded-2xl font-black text-[9px] tracking-[0.2em] shadow-lg transition-all duration-500
                                         @(currentCenter.IsDirectBooking ? "bg-emerald-500/90 text-white border border-emerald-400" : "bg-slate-800/80 text-slate-200 border border-slate-700")">
                            <i class="fas @(currentCenter.IsDirectBooking ? "fa-bolt" : "fa-clock") mr-1"></i>
                            @(currentCenter.IsDirectBooking ? "DIRECT BOOKING" : "INDIRECT BOOKING")
                        </div>
                    </div>

                    @* التحكم بالصور *@
                    <div class="flex items-center justify-center gap-4">
                        <button type="button" @onclick="PrevImage" class="w-12 h-12 rounded-full bg-white shadow-sm border border-orange-50 text-orange-600 hover:bg-orange-600 hover:text-white transition-all">
                            <i class="fas fa-chevron-left"></i>
                        </button>
                        <div class="flex gap-3">
                            @foreach (var (s, index) in currentCenter.medicalCenterServices.Select((v, i) => (v, i)))
                            {
                                <div @onclick="() => currentImageIndex = index" class="w-14 h-14 rounded-2xl overflow-hidden cursor-pointer border-2 transition-all @(currentImageIndex == index ? "border-orange-500 scale-110 shadow-lg" : "border-transparent opacity-40 hover:opacity-100")">
                                    <img src="/@s.Image" class="w-full h-full object-cover" />
                                </div>
                            }
                        </div>
                        <button type="button" @onclick="NextImage" class="w-12 h-12 rounded-full bg-white shadow-sm border border-orange-50 text-orange-600 hover:bg-orange-600 hover:text-white transition-all">
                            <i class="fas fa-chevron-right"></i>
                        </button>
                    </div>
                </div>

                @* اليمين: البيانات *@
                <div class="lg:w-3/5 w-full">
                    <div class="mb-10">
                        <span class="text-orange-600 font-black text-[10px] tracking-[0.3em] uppercase mb-3 block">Medical Center Profile</span>
                        <h1 class="clinic-main-title uppercase mb-6">@currentCenter.Name</h1>

                        @* الزر يظهر فقط إذا كان الحجز مباشراً *@
                        @if (currentCenter.IsDirectBooking)
                        {
                            <button class="bg-[#EA580C] text-white font-black px-10 py-4 rounded-2xl shadow-xl shadow-orange-600/20 hover:scale-105 active:scale-95 transition-all flex items-center gap-3">
                                <i class="fas fa-calendar-check"></i> BOOKING NOW
                            </button>
                        }
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                        <div class="info-tile">
                            <div class="flex items-center gap-3">
                                <div class="w-9 h-9 bg-orange-50 rounded-lg flex items-center justify-center text-orange-600"><i class="fas fa-id-badge"></i></div>
                                <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Official Name</span>
                            </div>
                            <div class="text-[1rem] font-extrabold text-slate-800">@currentCenter.Name</div>
                        </div>

                        <div class="info-tile">
                            <div class="flex items-center gap-3">
                                <div class="w-9 h-9 bg-orange-50 rounded-lg flex items-center justify-center text-orange-600"><i class="fas fa-phone-alt"></i></div>
                                <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Support Line</span>
                            </div>
                            <div class="text-[1rem] font-extrabold text-slate-800">@currentCenter.Phone</div>
                        </div>

                        <div class="info-tile">
                            <div class="flex items-center gap-3">
                                <div class="w-9 h-9 bg-orange-50 rounded-lg flex items-center justify-center text-orange-600"><i class="fas fa-envelope-open-text"></i></div>
                                <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Email Inquiry</span>
                            </div>
                            <div class="text-[0.95rem] font-extrabold text-orange-600 break-all">@currentCenter.Email</div>
                        </div>

                        <div class="info-tile">
                            <div class="flex items-center gap-3">
                                <div class="w-9 h-9 bg-orange-50 rounded-lg flex items-center justify-center text-orange-600"><i class="fas fa-map-marker-alt"></i></div>
                                <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest">City & Country</span>
                            </div>
                            <div class="text-[1rem] font-extrabold text-slate-800">@currentCenter.City, @currentCenter.Country</div>
                        </div>

                        <div class="info-tile sm:col-span-2">
                            <div class="flex items-center gap-3">
                                <div class="w-9 h-9 bg-orange-50 rounded-lg flex items-center justify-center text-orange-600"><i class="fas fa-directions"></i></div>
                                <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Full Address</span>
                            </div>
                            <div class="text-[1rem] font-extrabold text-slate-800">@currentCenter.Street</div>
                        </div>
                    </div>
                </div>
            </div>

            @* كارد الخدمات *@
            <div class="services-magic-card">
                <i class="fas fa-paw magic-bg-icon"></i>
                <div class="relative z-10">
                    <div class="flex items-center gap-4 mb-10">
                        <div class="w-12 h-2 bg-orange-600 rounded-full"></div>
                        <h2 class="text-3xl font-black text-slate-900 tracking-tight">Our Services</h2>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                        @if (currentCenter.medicalCenterServices != null)
                        {
                            @foreach (var s in currentCenter.medicalCenterServices)
                            {
                                <div class="service-tag group">
                                    <div class="w-8 h-8 rounded-lg bg-orange-50 flex items-center justify-center text-orange-600 group-hover:bg-white/20 group-hover:text-white transition-colors">
                                        <i class="fas fa-check text-[10px]"></i>
                                    </div>
                                    <span class="font-bold text-slate-700 text-xs uppercase tracking-wide">@s.ServiceName</span>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="text-center py-20">
                <h2 class="text-2xl font-bold text-slate-800">Clinic information could not be found.</h2>
                <button @onclick='() => Navigation.NavigateTo("medical-centers")' class="mt-4 bg-orange-600 text-white px-6 py-2 rounded-xl">Back to Centers</button>
            </div>
        }
    </div>
</div>