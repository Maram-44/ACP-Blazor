@page "/ForgetPassword"
@layout Empty
@using System.ComponentModel.DataAnnotations
@inject NavigationManager NavigationManager
@inject AccountService accountService


<div class="w-full h-full flex bg-white h-screen overflow-hidden">

    <div class="hidden lg:flex w-5/12 relative bg-slate-900 flex-col justify-between overflow-hidden">
        <div class="absolute inset-0 z-0">
            <img src="https://images.unsplash.com/photo-1534361960057-19889db9621e?ixlib=rb-4.0.3&auto=format&fit=crop&w=1950&q=80"
                 class="w-full h-full object-cover opacity-70"
                 alt="Dog waiting patiently">
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/50 to-transparent"></div>
        </div>

        <div class="relative z-10 p-12">
            <span class="text-xl font-bold tracking-tight text-white">Alef Care Systems</span>
        </div>

        <div class="relative z-10 p-12">
            <div class="bg-white/10 backdrop-blur-md border border-white/20 p-6 rounded-3xl max-w-sm">
                <div class="mb-3 text-orange-400">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                </div>
                <p class="text-white text-lg font-medium leading-relaxed mb-4">
                    "Don't worry, we've got your back. Account recovery is secure and instant."
                </p>
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-lg">🎧</div>
                    <div>
                        <p class="text-white font-bold text-sm">Alef Support</p>
                        <p class="text-white/60 text-xs">Always here to help</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="w-full lg:w-7/12 overflow-y-auto bg-white relative">

        <div class="flex flex-col items-center justify-start min-h-full px-4 sm:px-12 pt-0 pb-10">

            <div class="w-full max-w-[500px]">

                <div class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm py-6 mb-20 border-b border-transparent transition-all">
                    <div class="flex items-center gap-2">
                        <span class="text-4xl font-extrabold tracking-tighter text-slate-900">Alef</span>
                        <span class="text-3xl transform rotate-12 inline-block">🐾</span>
                    </div>
                </div>

                <div class="mb-8">
                    
                    <h1 class="text-3xl font-bold text-slate-900 mb-3">Forgot Password?</h1>
                    <p class="text-slate-500 text-base leading-relaxed">
                        No worries! Enter the email address associated with your account, and we'll send you a link to reset your password.
                    </p>
                </div>

                @if (isSuccess)
                {
                    <!-- رسالة نجاح الإرسال -->
                    <div class="bg-green-50 border border-green-200 text-green-700 p-6 rounded-2xl mb-6 text-center">
                        <svg class="w-12 h-12 text-green-500 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        <h3 class="text-xl font-bold mb-2">تفقد بريدك الإلكتروني!</h3>
                        <p class="text-sm text-green-600">لقد أرسلنا رابط إعادة تعيين كلمة المرور إلى @forgotPasswordModel.Email</p>
                    </div>
                }
                else
                {
                    <EditForm Model="@forgotPasswordModel" OnValidSubmit="HandleResetPassword" class="space-y-6">
                        <DataAnnotationsValidator />

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <!-- رسالة الخطأ إن وجدت -->
                            <div class="p-4 bg-red-50 border border-red-200 text-red-600 rounded-2xl text-sm font-medium">
                                @errorMessage
                            </div>
                        }

                        <div class="space-y-2">
                            <label class="text-sm font-bold text-slate-900 ml-1">Email Address</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-5 flex items-center pointer-events-none">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                    </svg>
                                </div>
                                <!-- ربط المدخل بالـ Model عن طريق @bind-value -->
                                <InputText type="email" placeholder="name@example.com" @bind-Value="forgotPasswordModel.Email"
                                           class="w-full pl-14 pr-5 py-4 bg-slate-50 border border-slate-200 rounded-2xl text-slate-900 focus:bg-white focus:ring-4 focus:ring-orange-100 focus:border-orange-600 outline-none font-medium transition-all shadow-sm" />
                            </div>
                            <!-- إظهار رسالة الخطأ الخاصة بالبريد الإلكتروني إن وجدت -->
                            <ValidationMessage For="@(() => forgotPasswordModel.Email)" class="text-red-500 text-xs mt-1 ml-1" />
                        </div>

                        <!-- زر الإرسال مع تفعيل تأثير الانتظار (Loading) -->
                        <button type="submit" disabled="@isSubmitting"
                                class="w-full py-4 bg-orange-600 hover:bg-orange-700 text-white font-bold rounded-2xl shadow-lg shadow-orange-200 transform hover:-translate-y-0.5 transition-all duration-200 text-lg flex justify-center items-center gap-2 disabled:opacity-50 disabled:transform-none">
                            @if (isSubmitting)
                            {
                                <span>جاري الإرسال...</span>
                                <!-- يمكنك وضع أي Spinner هنا -->
                            }
                            else
                            {
                                <span>Send Reset Link</span>
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                            }
                        </button>

                    </EditForm>
                }

                <!-- زر العودة لصفحة تسجيل الدخول -->
                <div class="mt-10 text-center">
                    <a href="/login" class="inline-flex items-center gap-2 text-slate-500 font-bold hover:text-slate-900 transition-colors">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
                        Back to Sign in
                    </a>
                </div>

            </div>
        </div>
    </div>
</div>
@code {
    private ForgotPasswordModel forgotPasswordModel = new();
    private bool isSubmitting = false;
    private string? errorMessage;
    private bool isSuccess = false;

    private async Task HandleResetPassword()
    {
        isSubmitting = true;
        errorMessage = null;
        isSuccess = false;

        try
        {
            // استدعاء الخدمة الحقيقية وإرسال الإيميل
            var result = await accountService.SendForgotPasswordLinkAsync(forgotPasswordModel.Email);

            if (result)
            {
                isSuccess = true;
            }
            else
            {
                errorMessage = "Something went wrong. Please try again later.";
            }
        }
        catch (Exception)
        {
            errorMessage = "Unable to connect to the server. Please check your internet connection.";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public class ForgotPasswordModel
    {
        [Required(ErrorMessage = "Email address is required.")]
        [EmailAddress(ErrorMessage = "Invalid email address format.")]
        public string Email { get; set; } = string.Empty;
    }
}