@page "/SignUp"
@layout Empty
<div class="w-full h-full flex">

    <div class="hidden lg:flex w-5/12 relative bg-slate-900 flex-col justify-between overflow-hidden">
        <div class="absolute inset-0 z-0">
            <img src="https://images.unsplash.com/photo-1514888286974-6c03e2ca1dba?ixlib=rb-4.0.3&auto=format&fit=crop&w=1927&q=80"
                 class="w-full h-full object-cover opacity-80"
                 alt="Cute cat">
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/40 to-transparent"></div>
        </div>

        <div class="relative z-10 p-12">
            <span class="text-xl font-bold tracking-tight text-white">Alef Care Systems</span>
        </div>

        <div class="relative z-10 p-12">
            <div class="bg-white/10 backdrop-blur-md border border-white/20 p-6 rounded-3xl max-w-sm">
                <div class="flex items-center gap-1 mb-3 text-yellow-400">
                    <span>★★★★★</span>
                </div>
                <p class="text-white text-lg font-medium leading-relaxed mb-4">
                    "Finally, a modern app for pet parents!"
                </p>
                <div class="flex items-center gap-3">
                    <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?ixlib=rb-4.0.3&auto=format&fit=crop&w=100&q=80"
                         class="w-10 h-10 rounded-full border-2 border-white/30 object-cover"
                         alt="David Chen">
                    <div>
                        <p class="text-white font-bold text-sm">David Chen</p>
                        <p class="text-white/60 text-xs">New User</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="w-full lg:w-7/12 overflow-y-auto bg-white relative">

        <div class="flex flex-col items-center justify-start min-h-full px-4 sm:px-12 pt-0 pb-10">

            <div class="w-full max-w-[550px]">

                <div class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm py-6 mb-4 border-b border-transparent transition-all">
                    <div class="flex items-center gap-2">
                        <span class="text-4xl font-extrabold tracking-tighter text-slate-900">Alef</span>
                        <span class="text-3xl transform rotate-12 inline-block">🐾</span>
                    </div>
                </div>

                <div class="mb-8">
                    <h1 class="text-3xl font-bold text-slate-900 mb-2">Create Account</h1>
                    <p class="text-slate-500 text-base">Join the community and start caring smarter.</p>
                </div>

                <form class="space-y-5">

                    <div class="space-y-2">
                        <label class="text-sm font-bold text-slate-900 ml-1">Full Name</label>
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                            <input type="text" placeholder="First" class="w-full px-4 py-4 bg-slate-50 border border-slate-200 rounded-2xl text-slate-900 focus:bg-white focus:ring-4 focus:ring-orange-100 focus:border-orange-600 outline-none font-medium transition-all">
                            <input type="text" placeholder="Middle" class="w-full px-4 py-4 bg-slate-50 border border-slate-200 rounded-2xl text-slate-900 focus:bg-white focus:ring-4 focus:ring-orange-100 focus:border-orange-600 outline-none font-medium transition-all">
                            <input type="text" placeholder="Family" class="w-full px-4 py-4 bg-slate-50 border border-slate-200 rounded-2xl text-slate-900 focus:bg-white focus:ring-4 focus:ring-orange-100 focus:border-orange-600 outline-none font-medium transition-all">
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label class="text-sm font-bold text-slate-900 ml-1">Mobile Number</label>
                        <div class="flex gap-3">
                            <div class="relative w-1/3 sm:w-1/4">
                                <select class="w-full h-full px-3 py-4 bg-slate-50 border border-slate-200 rounded-2xl text-slate-900 font-bold focus:ring-4 focus:ring-orange-100 focus:border-orange-600 outline-none appearance-none cursor-pointer">
                                    <option value="+966">🇸🇦 +966</option>
                                    <option value="+971">🇦🇪 +971</option>
                                    <option value="+20">🇪🇬 +20</option>
                                    <option value="+1">🇺🇸 +1</option>
                                </select>
                            </div>
                            <input type="tel" placeholder="5X XXX XXXX" class="w-full flex-1 px-4 py-4 bg-slate-50 border border-slate-200 rounded-2xl text-slate-900 focus:bg-white focus:ring-4 focus:ring-orange-100 focus:border-orange-600 outline-none font-medium transition-all">
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label class="text-sm font-bold text-slate-900 ml-1">Email</label>
                        <input type="email" placeholder="hello@alef.com" class="w-full px-4 py-4 bg-slate-50 border border-slate-200 rounded-2xl text-slate-900 focus:bg-white focus:ring-4 focus:ring-orange-100 focus:border-orange-600 outline-none font-medium transition-all">
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-slate-900 ml-1">Password</label>
                            <input type="password" placeholder="••••••••" class="w-full px-4 py-4 bg-slate-50 border border-slate-200 rounded-2xl text-slate-900 focus:bg-white focus:ring-4 focus:ring-orange-100 focus:border-orange-600 outline-none font-medium transition-all">
                        </div>
                        <div class="space-y-2">
                            <label class="text-sm font-bold text-slate-900 ml-1">Confirm</label>
                            <input type="password" placeholder="••••••••" class="w-full px-4 py-4 bg-slate-50 border border-slate-200 rounded-2xl text-slate-900 focus:bg-white focus:ring-4 focus:ring-orange-100 focus:border-orange-600 outline-none font-medium transition-all">
                        </div>
                    </div>

                    <div class="flex items-center ml-1 mt-2">
                        <input id="terms" type="checkbox" class="h-4 w-4 text-orange-600 border-slate-300 rounded focus:ring-orange-500 cursor-pointer">
                        <label for="terms" class="ml-2 text-sm font-medium text-slate-600">
                            I agree to the <a href="#" class="text-orange-600 hover:underline">Terms & Privacy</a>.
                        </label>
                    </div>

                    <button class="w-full py-4 bg-orange-600 hover:bg-orange-700 text-white font-bold rounded-2xl shadow-lg shadow-orange-200 transform hover:-translate-y-0.5 transition-all duration-200 text-lg">
                        Create Account
                    </button>

                </form>

                <p class="mt-8 mb-4 text-center text-slate-500 font-medium">
                    Already have an account? <a href="#" class="text-orange-600 font-bold hover:underline">Sign in</a>
                </p>
            </div>
        </div>
    </div>
</div>

