@page "/products"
@using ACP.Components.BrowseProducts

<ProductHero>
    <ProductFilters @bind-SearchTerm="filterModel.SearchTerm"
                    OnFilterChanged="ApplyFilters" />
</ProductHero>

<div class="bg-[#F8FAFC] min-h-screen">
    <div class="container mx-auto px-6 py-16">

        <div class="flex items-center justify-between mb-10 border-b border-slate-200 pb-6">
            <div>
                <h3 class="text-[#0F172A] text-2xl font-black">Latest Products</h3>
                <p class="text-[#64748B] text-sm">Showing @FilteredProducts.Count items</p>
            </div>

            <div class="flex items-center gap-3">
                <span class="text-slate-400 text-xs font-bold uppercase">Sort by:</span>
                <select @onchange="HandleSort" class="bg-white border border-slate-200 rounded-xl px-4 py-2 text-sm text-[#0F172A] outline-none focus:border-[#EA580C] cursor-pointer">
                    <option value="newest">Newest</option>
                    <option value="price-low">Price: Low to High</option>
                    <option value="price-high">Price: High to Low</option>
                </select>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
            @foreach (var product in FilteredProducts)
            {
                <ProductCard ProductName="@product.Name"
                             Price="@product.Price"
                             IsUsed="@product.IsUsed"
                             IsPlatformProduct="@product.IsOfficial"
                             CategoryName="@product.Category"
                             ProductImageUrl="@product.ImageUrl" />
            }
        </div>
    </div>
</div>

@code {
    private List<Product> AllProducts = new List<Product>();
    private List<Product> FilteredProducts = new List<Product>();
    private FilterCriteria filterModel = new FilterCriteria();

    protected override void OnInitialized()
    {
        // تعبئة بيانات تجريبية فور تشغيل الصفحة
        AllProducts = new List<Product>
        {
            new Product { Id = 1, Name = "Premium Cat Food", Price = 45.00m, IsOfficial = true, Category = "Food", ImageUrl = "https://images.unsplash.com/photo-1589924691106-073b19f5538d" },
            new Product { Id = 2, Name = "Dog Bed Luxury", Price = 89.99m, IsOfficial = true, Category = "Comfort", ImageUrl = "https://images.unsplash.com/photo-1541599540903-21b1576d8683" }
        };
        FilteredProducts = AllProducts.ToList();
    }

    private void ApplyFilters()
    {
        FilteredProducts = AllProducts
            .Where(p => string.IsNullOrWhiteSpace(filterModel.SearchTerm) ||
                        p.Name.Contains(filterModel.SearchTerm, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private void HandleSort(ChangeEventArgs e)
    {
        var sortValue = e.Value?.ToString();
        FilteredProducts = sortValue switch
        {
            "price-low" => FilteredProducts.OrderBy(p => p.Price).ToList(),
            "price-high" => FilteredProducts.OrderByDescending(p => p.Price).ToList(),
            _ => FilteredProducts.OrderByDescending(p => p.Id).ToList()
        };
    }

    // تعريف الكلاسات اللازمة
    public class Product
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public decimal Price { get; set; }
        public bool IsUsed { get; set; }
        public bool IsOfficial { get; set; }
        public string Category { get; set; } = "";
        public string ImageUrl { get; set; } = "";
    }

    public class FilterCriteria
    {
        public string SearchTerm { get; set; } = "";
    }


}