
@page "/blog"
@using ACP.Models.Blogs
@using ACP.Services
@using System.ComponentModel.DataAnnotations
@inject BlogHttpService BlogService
@inject NavigationManager Navigation

<main class="pt-32 pb-24 px-4 sm:px-6 bg-[#fafafa] min-h-screen antialiased font-sans text-slate-900 selection:bg-orange-500/10 selection:text-orange-600">
    <div class="max-w-5xl mx-auto">

        <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-20 pb-8 border-b border-slate-200/60">
            <div class="space-y-4 max-w-2xl">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-slate-100 border border-slate-200/80 text-slate-600 text-xs font-semibold tracking-wider uppercase">
                    <span class="w-1.5 h-1.5 rounded-full bg-orange-500 animate-pulse"></span>
                    Knowledge Hub
                </div>
                <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-950">
                    The Animal <span class="underline decoration-orange-500 decoration-4 underline-offset-4 font-serif italic font-normal text-slate-900">Journal</span>
                </h1>
                <p class="text-slate-500 text-base sm:text-lg font-normal leading-relaxed">
                    Thoughtful perspectives, expert advice, and evidence-based care guides curated for dedicated pet owners.
                </p>
            </div>

            <button @onclick="OpenModal" class="inline-flex items-center justify-center gap-2.5 px-6 py-3.5 bg-slate-950 text-white font-semibold text-sm rounded-xl shadow-sm hover:bg-orange-600 transition-all duration-300 group self-start md:self-end">
                <span>Write an Article</span>
                <svg class="w-4 h-4 group-hover:transform group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"></path>
                </svg>
            </button>
        </div>

        <div class="space-y-12">
            @if (BlogPosts == null)
            {
                <div class="flex flex-col items-center justify-center py-12 space-y-3">
                    <div class="w-8 h-8 border-4 border-orange-500 border-t-transparent rounded-full animate-spin"></div>
                    <p class="text-slate-400 text-sm">Loading articles...</p>
                </div>
            }
            else if (!BlogPosts.Any())
            {
                <div class="text-center py-12 text-slate-400">
                    No articles found. Be the first to share an insight!
                </div>
            }
            else
            {
                @foreach (var post in BlogPosts)
                {
                    <article class="grid grid-cols-1 md:grid-cols-12 gap-8 pt-2 first:pt-0 group">

                        <div class="md:col-span-4 flex flex-col justify-start">
                            <div class="space-y-3">
                                <time datetime="@post.CreatedDate.ToString("yyyy-MM-dd")" class="text-xs font-semibold tracking-wider text-slate-400 uppercase block">
                                    @post.CreatedDate.ToString("MMMM dd, yyyy")
                                </time>

                                <div class="w-full h-48 md:h-40 rounded-2xl border border-slate-200/60 flex items-center justify-center relative overflow-hidden bg-slate-100 shadow-sm">
                                    @if (!string.IsNullOrEmpty(post.ImageUrl))
                                    {
                                        <img src="@post.ImageUrl" alt="@post.Title" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                                    }
                                    else
                                    {
                                        <div class="absolute -right-4 -bottom-4 w-24 h-24 rounded-full bg-orange-500/5 blur-xl"></div>
                                        <svg class="w-8 h-8 text-slate-300 group-hover:text-orange-500/40 transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
                                        </svg>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="md:col-span-8 space-y-4 flex flex-col justify-center">
                            <h2 class="text-2xl font-bold tracking-tight text-slate-900 group-hover:text-orange-600 transition-colors duration-200 leading-tight">
                                @post.Title
                            </h2>

                            <div class="text-slate-600 font-normal text-sm sm:text-base leading-relaxed max-w-none break-words whitespace-pre-wrap line-clamp-3">
                                @post.Content
                            </div>

                            <div class="pt-2">
                                <button @onclick="() => NavigateToDetails(post.Id)" class="inline-flex items-center gap-1.5 text-slate-950 hover:text-orange-600 font-semibold text-xs tracking-wider uppercase transition-colors duration-200">
                                    <span>Continue Reading</span>
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
                                    </svg>
                                </button>
                            </div>
                        </div>
                    </article>

                    <div class="h-px bg-slate-200/60 w-full last:hidden"></div>
                }
            }
        </div>
    </div>
</main>

@if (isModalOpen)
{
    <div class="fixed inset-0 bg-slate-950/20 backdrop-blur-sm z-50 flex items-center justify-center p-4 animate-fade-in">
        <div class="bg-white p-6 sm:p-10 rounded-2xl max-w-xl w-full shadow-xl border border-slate-200/50 space-y-6 relative max-h-[90vh] overflow-y-auto">

            <div class="flex justify-between items-start">
                <div class="space-y-1">
                    <h3 class="text-xl font-bold text-slate-900">Create New Article</h3>
                    <p class="text-slate-400 text-xs font-normal">Contribute verified insights to the knowledge base.</p>
                </div>
                <button @onclick="CloseModal" class="text-slate-400 hover:text-slate-600 p-1 rounded-lg hover:bg-slate-50 transition-colors">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>

            <EditForm Model="newPost" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />

                <div class="space-y-5">
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-2">Article Title</label>
                        <InputText @bind-Value="newPost.Title" maxlength="100" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl font-medium text-sm text-slate-800 focus:outline-none focus:border-slate-900 focus:ring-1 focus:ring-slate-900 placeholder-slate-300 transition-all" placeholder="e.g., Nutritional Guidelines for Senior Felines" />
                        <ValidationMessage For="() => newPost.Title" class="text-rose-500 text-xs mt-1 block" />
                    </div>

                    <div>
                        <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-2">Content / Body (Min 250 chars)</label>
                        <InputTextArea @bind-Value="newPost.Content" rows="6" class="w-full px-4 py-3 bg-white border border-slate-200 rounded-xl font-normal text-sm text-slate-800 focus:outline-none focus:border-slate-900 focus:ring-1 focus:ring-slate-900 placeholder-slate-300 transition-all leading-relaxed" placeholder="Write the detailed guide here (At least 250 characters)..." />
                        <ValidationMessage For="() => newPost.Content" class="text-rose-500 text-xs mt-1 block" />
                    </div>

                    <div>
                        <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-2">Article Image</label>
                        <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-slate-200 border-dashed rounded-xl hover:border-slate-400 transition-colors bg-slate-50/50">
                            <div class="space-y-1 text-center">
                                <svg class="mx-auto h-10 w-10 text-slate-400" stroke="currentColor" fill="none" viewBox="0 0 48 48" aria-hidden="true">
                                    <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                </svg>
                                <div class="flex text-sm text-slate-600">
                                    <label class="relative cursor-pointer bg-transparent rounded-md font-semibold text-orange-600 hover:text-orange-500">
                                        <span>Upload a file</span>
                                        <InputFile OnChange="OnInputFileChange" class="sr-only" accept="image/*" />
                                    </label>
                                </div>
                                <p class="text-xs text-slate-400">@((selectedFile != null) ? selectedFile.Name : "PNG, JPG up to 5MB")</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="flex items-center gap-3 pt-6 border-t border-slate-100 mt-6">
                    <button type="button" @onclick="CloseModal" class="flex-1 py-3 bg-slate-50 text-slate-600 border border-slate-200 font-semibold rounded-xl hover:bg-slate-100 transition-all text-xs">
                        Cancel
                    </button>
                    <button type="submit" class="flex-1 py-3 bg-slate-950 text-white font-semibold rounded-xl hover:bg-orange-600 transition-all text-xs shadow-sm">
                        Publish Post
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private bool isModalOpen = false;
    private UIAddBlogModel newPost = new();
    private IBrowserFile? selectedFile;
    private List<UIReadBlogModel> BlogPosts = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadBlogsFromServer();
    }

    private void NavigateToDetails(int blogId)
    {
        Navigation.NavigateTo($"/blog/{blogId}");
    }

    private async Task LoadBlogsFromServer()
    {
        var apiBlogs = await BlogService.GetAllBlogsAsync();

        BlogPosts = apiBlogs.Select(b => new UIReadBlogModel
        {
            Id = b.Id,
            Title = b.Title,
            Content = b.Content,
            ImageUrl = b.ImagePath,
            CreatedDate = b.PublicationDate
        }).ToList();
    }

    private void OpenModal()
    {
        newPost = new UIAddBlogModel();
        selectedFile = null;
        isModalOpen = true;
    }

    private void CloseModal() => isModalOpen = false;

    private void OnInputFileChange(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
    }

    private async Task HandleSubmit()
    {
        var dto = new AddBlogDTO
        {
            Title = newPost.Title,
            Content = newPost.Content
        };

        var success = await BlogService.CreateBlogAsync(dto, selectedFile);

        if (success)
        {
            CloseModal();
            await LoadBlogsFromServer();
        }
    }

    public class UIAddBlogModel
    {
        [Required(ErrorMessage = "Title is required")]
        [MaxLength(70, ErrorMessage = "Title cannot exceed 70 characters")]
        public string Title { get; set; } = string.Empty;

        [Required(ErrorMessage = "Content is required")]
        [MinLength(250, ErrorMessage = "Content must be at least 250 characters long")]
        public string Content { get; set; } = string.Empty;
    }

    public class UIReadBlogModel
    {
        public int Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public string Content { get; set; } = string.Empty;
        public string? ImageUrl { get; set; }
        public DateTime CreatedDate { get; set; }
    }
}

