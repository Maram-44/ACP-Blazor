@page "/browse-animals"
@namespace ACP.Pages
@using ACP.Models.Animals
@using ACP.Components.BrowseAnimals

<div class="bg-[#F8FAFC] min-h-screen relative">

    @* 1. Hero Section *@
    <AnimalHero>
        <AnimalFilter SearchText="@searchText"
                      SelectedTypeId="@selectedTypeId"
                      SelectedAgeRange="@selectedAgeRange"
                      OnSearchChanged="HandleSearch"
                      OnTypeChanged="HandleTypeChange"
                      OnAgeChanged="HandleAgeChange" />
    </AnimalHero>

    @* 2. Main Content Section *@
    <div id="browse" class="container mx-auto px-6 md:px-20 lg:px-32 py-16">

        @* Results Header *@
        <div class="flex flex-col md:flex-row justify-between items-center mb-12 gap-4">
            <h3 class="text-3xl font-black text-slate-800 tracking-tight">Available Pets</h3>
            <span class="bg-white shadow-md text-slate-700 px-6 py-2 rounded-full font-bold border border-slate-100 text-sm">
                Found: <span class="text-[#EA580C]">@(FilteredAnimals?.Count() ?? 0)</span> Results
            </span>
        </div>

        @* Data Rendering Logic *@
        @if (AnimalsList == null)
        {
            @* Loading State *@
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                @for (int i = 0; i < 4; i++)
                {
                    <div class="h-80 bg-slate-200 animate-pulse rounded-[2rem]"></div>
                }
            </div>
            <div class="flex flex-col items-center justify-center py-10">
                <p class="text-slate-500 font-medium">Fetching pets data...</p>
            </div>
        }
        else if (!FilteredAnimals.Any())
        {
            @* No results state *@
            <div class="text-center py-20 bg-white rounded-[3rem] shadow-sm border border-slate-100">
                <div class="mb-4 text-slate-200">
                    <i class="fas fa-search fa-4x"></i>
                </div>
                <p class="text-slate-400 text-xl font-bold mb-6">No pets found matching your search.</p>

                <button @onclick="ClearFilters"
                        class="px-8 py-3 bg-[#EA580C] text-white rounded-2xl font-bold shadow-lg shadow-orange-600/20 hover:scale-105 transition-all">
                    Reset All Filters
                </button>
            </div>
        }
        else
        {
            @* Animals Grid *@
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
                @foreach (var animal in FilteredAnimals.Take(currentPageSize))
                {
                    <AnimalCard AnimalItem="animal" OnViewProfile="HandleViewAnimalProfile" />
                }
            </div>

            @* 3. Load More Section *@
            @if (FilteredAnimals.Count() > currentPageSize)
            {
                <div class="flex flex-col items-center justify-center mt-20 mb-10">
                    <p class="text-slate-400 text-sm mb-4 font-medium italic">
                        Showing @(FilteredAnimals.Take(currentPageSize).Count()) of @FilteredAnimals.Count() pets
                    </p>

                    <button @onclick="LoadMore"
                            class="group relative px-12 py-4 bg-white border-2 border-slate-200 text-slate-700 font-black rounded-2xl overflow-hidden transition-all hover:text-white hover:border-[#EA580C] shadow-lg shadow-slate-200/50">
                        <div class="absolute inset-0 w-0 bg-[#EA580C] transition-all duration-300 ease-out group-hover:w-full"></div>
                        <span class="relative z-10 flex items-center gap-2">
                            View More Animals
                            <i class="fas fa-plus group-hover:rotate-90 transition-transform duration-300"></i>
                        </span>
                    </button>
                </div>
            }
        }
    </div>

    @* 4. Back to Top Floating Button *@
    <button x-data="{ show: false }"
            x-on:scroll.window="show = (window.pageYOffset > 400)"
            x-show="show"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0 translate-y-10"
            x-transition:enter-end="opacity-100 translate-y-0"
            x-transition:leave="transition ease-in duration-300"
            x-transition:leave-start="opacity-100 translate-y-0"
            x-transition:leave-end="opacity-0 translate-y-10"
            onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
            class="fixed bottom-10 right-6 md:right-10 z-[100] bg-slate-900 text-white p-5 rounded-[1.5rem] shadow-2xl hover:bg-[#EA580C] hover:-translate-y-2 transition-all active:scale-95 group">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 group-hover:animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 10l7-7m0 0l7 7m-7-7v18" />
        </svg>
    </button>
</div>