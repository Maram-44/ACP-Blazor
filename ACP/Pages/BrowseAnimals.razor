@page "/browse-animals"
@namespace ACP.Pages
@using ACP.Models.Animals
@using ACP.Components.BrowseAnimals
@inject NavigationManager NavigationManager
@inject ACP.Services.AnimalServices AnimalServices
@inject IJSRuntime JSRuntime 

<div class="bg-[#F8FAFC] min-h-screen relative">

    @* 1. Hero Section - 🟢 قمنا بربط أحداث الضغط هنا مع دوال السكرول المخصصة *@
    <AnimalHero OnAdoptRequested="ScrollToCards" OnCategoriesRequested="ScrollToFilters">
        <AnimalFilter SearchText="@searchText"
                      SelectedTypeId="@(selectedTypeId ?? 0)"
                      SelectedAgeRange="@selectedAgeRange"
                      OnSearchChanged="HandleSearch"
                      OnTypeChanged="HandleTypeChange"
                      OnAgeChanged="HandleAgeChange"
                      AnimalTypes="@animalTypes"/>
    </AnimalHero>

    @* 2. Main Content Section *@
    <div id="browse" class="container mx-auto px-6 md:px-20 lg:px-32 py-16">

        @* Results Header *@
        <div class="flex flex-col md:flex-row justify-between items-center mb-12 gap-4">
            <h3 class="text-3xl font-black text-slate-800 tracking-tight">Available Pets</h3>
            <span class="bg-white shadow-md text-slate-700 px-6 py-2 rounded-full font-bold border border-slate-100 text-sm">
                Loaded: <span class="text-[#EA580C]">@(AnimalsList?.Count ?? 0)</span> Pets
            </span>
        </div>

        @* Data Rendering Logic *@
        @if (AnimalsList == null)
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                @for (int i = 0; i < 4; i++)
                {
                    <div class="h-80 bg-slate-200 animate-pulse rounded-[2rem]"></div>
                }
            </div>
            <div class="flex flex-col items-center justify-center py-10">
                <p class="text-slate-500 font-medium">Fetching pets data...</p>
            </div>
        }
        else if (!AnimalsList.Any())
        {
            <div class="text-center py-20 bg-white rounded-[3rem] shadow-sm border border-slate-100">
                <div class="mb-4 text-slate-200">
                    <i class="fas fa-search fa-4x"></i>
                </div>
                <p class="text-slate-400 text-xl font-bold mb-6">No pets found matching your search.</p>

                <button @onclick="ClearFilters"
                        class="px-8 py-3 bg-[#EA580C] text-white rounded-2xl font-bold shadow-lg shadow-orange-600/20 hover:scale-105 transition-all">
                    Reset All Filters
                </button>
            </div>
        }
        else
        {
            @* Animals Grid *@
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
                @foreach (var animal in AnimalsList)
                {
                    <AnimalCard AnimalItem="animal" OnViewProfile="HandleViewAnimalProfile" />
                }
            </div>

            @* 3. Infinite Scroll / Load More Trigger via Alpine.js *@
            @if (hasNextPage)
            {
                <div x-data="{
                     observer: null,
                     init() {
                     setTimeout(()=>
                    {
                    this.observer = new IntersectionObserver(entries => {
                    if (entries[0].isIntersecting && !@isLoadingMore.ToString().ToLower()) {
                    @(() => LoadMore())
                    }
                    }, { rootMargin: '100px' });

                    this.observer.observe(this.$el);
                    }, 300);
                    },
                    destroy() {
                    if(this.observer) this.observer.disconnect();
                    }
                    }"
                    class="flex flex-col items-center justify-center mt-16 mb-10 text-slate-400 font-medium italic">

                    <div class="flex items-center gap-3 bg-white px-6 py-3 rounded-full shadow-sm border border-slate-100">
                        <div class="w-5 h-5 border-2 border-[#EA580C] border-t-transparent rounded-full animate-spin"></div>
                        <span>Loading more awesome pets...</span>
                    </div>
                </div>
            }
            else
            {
                <div class="text-center text-slate-400 font-medium my-16 italic">
                    ✨ You've reached the end of the list!
                </div>
            }
        }
    </div>

    @* 4. Back to Top Floating Button *@
    <button x-data="{ show: false }"
            x-on:scroll.window="show = (window.pageYOffset > 400)"
            x-show="show"
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0 translate-y-10"
            x-transition:enter-end="opacity-100 translate-y-0"
            x-transition:leave="transition ease-in duration-300"
            x-transition:leave-start="opacity-100 translate-y-0"
            x-transition:leave-end="opacity-0 translate-y-10"
            onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
            class="fixed bottom-10 right-6 md:right-10 z-[100] bg-slate-900 text-white p-5 rounded-[1.5rem] shadow-2xl hover:bg-[#EA580C] hover:-translate-y-2 transition-all active:scale-95 group">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 group-hover:animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 10l7-7m0 0l7 7m-7-7v18" />
        </svg>
    </button>
</div>

@code {
    private List<AnimalReadDto>? AnimalsList { get; set; }
    private List<AnimalType>? animalTypes { get; set; }

    private bool isLoadingMore = false;
    private bool hasNextPage = true;
    private const int takeCount = 8;

    // الفلاتر
    private string searchText = string.Empty;
    private int? selectedTypeId;
    private string selectedAgeRange = string.Empty;

    private int? lastAnimalId = null;


    protected override async Task OnInitializedAsync()
    {
        await LoadInitialData();
        animalTypes = await AnimalServices.GetAnimalTypes();
    }

    private async Task LoadInitialData()
    {
        AnimalsList = null;
        hasNextPage = true;
        lastAnimalId = null;

        var result = await AnimalServices.GetAnimalsCursorAsync(lastId: null, take: takeCount, search: searchText, typeId: selectedTypeId);

        if (result != null)
        {
            AnimalsList = result;
            lastAnimalId = result.LastOrDefault()?.AnimalId;
            hasNextPage = result.Count == takeCount;
        }
        else
        {
            AnimalsList = new List<AnimalReadDto>();
            hasNextPage = false;
        }
    }

    private async Task LoadMore()
    {
        if (isLoadingMore || !hasNextPage) return;

        isLoadingMore = true;
        StateHasChanged();

        var nextBatch = await AnimalServices.GetAnimalsCursorAsync(lastId: lastAnimalId, take: takeCount, search: searchText, typeId: selectedTypeId);

        if (nextBatch != null && nextBatch.Any())
        {
            AnimalsList?.AddRange(nextBatch);
            lastAnimalId = AnimalsList?.LastOrDefault()?.AnimalId;
            hasNextPage = nextBatch.Count == takeCount;
        }
        else
        {
            hasNextPage = false;
        }

        isLoadingMore = false;
        StateHasChanged();
    }

    private async Task HandleSearch(string text)
    {
        searchText = text;
        await LoadInitialData();
    }

    private async Task HandleTypeChange(int typeId)
    {
        selectedTypeId = typeId == 0 ? null : typeId;
        await LoadInitialData();
    }

    private async Task HandleAgeChange(string age)
    {
        selectedAgeRange = age;
        await LoadInitialData();
    }

    private async Task ClearFilters()
    {
        searchText = string.Empty;
        selectedTypeId = null;
        selectedAgeRange = string.Empty;
        await LoadInitialData();
    }

    private void HandleViewAnimalProfile(AnimalReadDto animal)
    {
        NavigationManager.NavigateTo($"/animal-details/{animal.AnimalId}");
    }
}