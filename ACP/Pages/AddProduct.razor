@page "/add-product"
@namespace ACP.Pages
@inherits AddProductBase

<main class="flex flex-col justify-center min-h-screen container mx-auto px-6 lg:px-20 py-24">
    <div class="bg-white w-full max-w-3xl mx-auto p-10 rounded-[3rem] shadow-2xl border border-slate-50 animate-fade-in">

        <div class="text-center mb-10">
            <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Add New Inventory Item</h1>
            <p class="text-slate-400 mt-2 font-medium">Register a new product in the system</p>
        </div>
        @* OnValidSubmit="HandleSubmit هذا يكون تحت بس ايرور اوعجني*@
     <EditForm Model="@NewItem">
            <DataAnnotationsValidator />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="md:col-span-2">
                    <label class="text-xs font-bold text-slate-400 uppercase ml-2">Item Name</label>
                    <InputText @bind-Value="NewItem.ItemName" placeholder="Product Name"
                               class="w-full mt-1 px-6 py-4 rounded-2xl border border-slate-100 bg-slate-50 focus:outline-none focus:border-orange-300 transition-all text-sm" />
                </div>

                <div>
                    <label class="text-xs font-bold text-slate-400 uppercase ml-2">SKU (Stock Keeping Unit)</label>
                    <InputText @bind-Value="NewItem.SKU" placeholder="Unique Code"
                               class="w-full mt-1 px-6 py-4 rounded-2xl border border-slate-100 bg-slate-50 focus:outline-none focus:border-orange-300 transition-all text-sm" />
                </div>

                <div>
                    <label class="text-xs font-bold text-slate-400 uppercase ml-2">Category ID</label>
                    <InputNumber @bind-Value="NewItem.CategoryId"
                                 class="w-full mt-1 px-6 py-4 rounded-2xl border border-slate-100 bg-slate-50 focus:outline-none focus:border-orange-300 transition-all text-sm" />
                </div>

                <div>
                    <label class="text-xs font-bold text-slate-400 uppercase ml-2">Cost Price ($)</label>
                    <InputNumber @bind-Value="NewItem.Cost"
                                 class="w-full mt-1 px-6 py-4 rounded-2xl border border-slate-100 bg-slate-50 focus:outline-none focus:border-orange-300 transition-all text-sm" />
                </div>

                <div>
                    <label class="text-xs font-bold text-slate-400 uppercase ml-2">Sell Price ($)</label>
                    <InputNumber @bind-Value="NewItem.SellPrice"
                                 class="w-full mt-1 px-6 py-4 rounded-2xl border border-slate-100 bg-slate-50 focus:outline-none focus:border-orange-300 transition-all text-sm" />
                </div>

                <div>
                    <label class="text-xs font-bold text-slate-400 uppercase ml-2">Initial Quantity (QTY)</label>
                    <InputNumber @bind-Value="NewItem.QTY"
                                 class="w-full mt-1 px-6 py-4 rounded-2xl border border-slate-100 bg-slate-50 focus:outline-none focus:border-orange-300 transition-all text-sm" />
                </div>

                <div class="flex items-center px-4">
                    <label class="flex items-center cursor-pointer gap-3">
                        <InputCheckbox @bind-Value="NewItem.IsReturendable" class="w-5 h-5 accent-orange-500 rounded" />
                        <span class="text-sm font-bold text-slate-600">Is Returnable?</span>
                    </label>
                </div>

                <div class="md:col-span-2">
                    <label class="text-xs font-bold text-slate-400 uppercase ml-2">Description</label>
                    <InputTextArea @bind-Value="NewItem.Description" rows="3" placeholder="Technical details..."
                                   class="w-full mt-1 px-6 py-4 rounded-2xl border border-slate-100 bg-slate-50 focus:outline-none focus:border-orange-300 transition-all text-sm" />
                </div>
            </div>

            <div class="md:col-span-2 bg-slate-50 p-8 rounded-[2rem] border-2 border-dashed border-slate-200">
    <label class="text-sm font-black text-slate-700 uppercase block mb-4">Product Images</label>
    
    <div class="flex flex-col items-center justify-center">
        <label class="w-full flex flex-col items-center px-4 py-6 bg-white text-orange-500 rounded-2xl shadow-sm tracking-wide uppercase border border-orange-100 cursor-pointer hover:bg-orange-500 hover:text-white transition-all">
            <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20"><path d="M16.88 9.1L13.4 5.61C12.7 4.92 11.59 4.92 10.9 5.61L7.42 9.1C6.72 9.79 6.72 10.9 7.42 11.59L10.9 15.08C11.59 15.77 12.7 15.77 13.4 15.08L16.88 11.59C17.58 10.9 17.58 9.79 16.88 9.1z"/><path d="M2 10C2 5.58 5.58 2 10 2C14.42 2 18 5.58 18 10C18 14.42 14.42 18 10 18C5.58 18 2 14.42 2 10ZM10 4C6.69 4 4 6.69 4 10C4 13.31 6.69 16 10 16C13.31 16 16 13.31 16 10C16 6.69 13.31 4 10 4Z"/></svg>
            <span class="mt-2 text-xs font-bold">Select Photos</span>
            @* مكون الـ InputFile الخاص ببلايزر *@
            @* <InputFile OnChange="HandleFileSelected" multiple class="hidden" /> *@
        </label>
    </div>

    @* عرض مصغرات الصور المختارة *@
    @if (NewItem.itemPhoto != null && NewItem.itemPhoto.Any())
    {
        <div class="grid grid-cols-4 md:grid-cols-6 gap-4 mt-6">
            @foreach (var photo in NewItem.itemPhoto)
            {
                <div class="relative group">
                                <img src="@photo.PhotoName" class="w-full h-20 object-cover rounded-xl shadow-sm border border-white" />
                   @* هنا راح يكون الحدف اونكليك *@
                    <button type="button" 
                            class="absolute -top-2 -right-2 bg-red-500 text-white rounded-full p-1 opacity-0 group-hover:opacity-100 transition-all">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12"></path></svg>
                    </button>
                </div>
            }
        </div>
    }
</div>
            <button type="submit"
                    class="w-full mt-10 bg-[#ff4f00] text-white py-5 rounded-3xl font-extrabold text-lg shadow-xl hover:bg-orange-700 transition-all">
                Save Inventory Item
            </button>
        </EditForm>
    </div>
</main>