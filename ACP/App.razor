@using Microsoft.AspNetCore.Components.Authorization

<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(Program).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">

                <NotAuthorized>
                    <AuthorizeView Context="authContext">
                        <Authorized>
                            <div class="flex flex-col items-center justify-center h-screen bg-slate-50">
                                <span class="text-4xl mb-4">📝</span>
                                <h1 class="text-xl font-bold text-slate-700">Complete Your Profile</h1>
                                <p class="text-sm text-slate-400 mt-1">You must complete your profile details to access this page.</p>
                                <a href="/customer-profile" class="mt-4 px-6 py-2 bg-orange-500 text-white rounded-xl font-bold transition-all hover:bg-orange-600">
                                    Go to Profile
                                </a>
                            </div>
                        </Authorized>
                        <NotAuthorized>
                            @{
                                NavigationManager.NavigateTo("/login");
                            }
                        </NotAuthorized>
                    </AuthorizeView>
                </NotAuthorized>

                <Authorizing>
                    <div class="flex items-center justify-center h-screen bg-slate-50">
                        <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-orange-500"></div>
                    </div>
                </Authorizing>

            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <LayoutView Layout="@typeof(MainLayout)">
                <p role="alert">Sorry, there's nothing at this address.</p>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>

@code {
    // حقن الـ NavigationManager لإجراء التحويل التلقائي
    [Inject] private NavigationManager NavigationManager { get; set; } = default!;
}