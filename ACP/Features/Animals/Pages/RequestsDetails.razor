@page "/requests-details/{AnimalId:int}"
@using ACP.Features.Account
@using ACP.Features.Animals
@inject AnimalServices AnimalService
@inject AnimalTransactionClientService TransactionService
@inject IJSRuntime JS
@inject NavigationManager Navigation

<div class="min-h-screen bg-white font-sans text-slate-900 pb-20" dir="ltr">

    <main class="container mx-auto px-4 lg:px-6 pt-10">

        @if (isLoading)
        {
            <div class="flex flex-col items-center justify-center min-h-[400px] gap-4">
                <div class="w-12 h-12 border-4 border-orange-500 border-t-transparent rounded-full animate-spin"></div>
                <p class="text-slate-500 font-medium">Loading...</p>
            </div>
        }
        else
        {
            @* --- 1. Pet Case Study Header --- *@
            <section class="relative overflow-hidden bg-[#1e293b] rounded-[2rem] lg:rounded-[3rem] p-8 lg:p-16 flex flex-col lg:flex-row items-center justify-between gap-10 shadow-2xl mt-16 mb-12 w-full mx-auto">
                <i class="fas fa-paw absolute -right-8 -bottom-12 text-[15rem] text-white/[0.03] -rotate-12 pointer-events-none z-0"></i>

                <div class="relative z-10 text-center lg:text-left flex-1">
                    <span class="bg-[#ea580c] text-white px-4 py-1.5 rounded-lg text-[10px] font-black uppercase tracking-wider">
                        Pet Current Case
                    </span>
                    <h1 class="text-4xl lg:text-6xl font-bold mt-4 text-white">@(animalItem?.Name ?? "No Name")</h1>
                    <p class="text-slate-400 mt-4 text-base lg:text-lg max-w-md italic mx-auto lg:mx-0">
                        "@((animalItem?.Description) ?? "No description available in the database.")"
                    </p>
                </div>

                <div class="relative z-10 grid grid-cols-2 md:grid-cols-4 lg:flex items-center gap-6 lg:gap-0 w-full lg:w-auto">
                    <div class="lg:border-r lg:border-white/10 lg:px-10 text-center">
                        <p class="text-[#ea580c] text-[10px] font-black uppercase mb-1">Gender</p>
                        <p class="text-white text-lg lg:text-2xl font-semibold">@(animalItem?.Gender ?? "N/A")</p>
                    </div>
                    <div class="lg:border-r lg:border-white/10 lg:px-10 text-center">
                        <p class="text-[#ea580c] text-[10px] font-black uppercase mb-1">City</p>
                        <p class="text-white text-lg lg:text-2xl font-semibold">@(animalItem?.City ?? "N/A")</p>
                    </div>
                    <div class="lg:px-10 text-center">
                        <p class="text-[#ea580c] text-[10px] font-black uppercase mb-1">Age</p>
                        <p class="text-white text-lg lg:text-2xl font-semibold">@CalculateAge(animalItem?.BirthDate)</p>
                    </div>
                </div>
            </section>

            @* 🌟 تعديل الشرط: نعتمد فقط على حالة القبول لضمان تبديل الشاشات دون تعليق *@
            @if (isAcceptedState)
            {
                @* --- 2. Accepted Adopter Contact Details (3 Fields Mode) --- *@
                <div class="bg-white rounded-[2rem] lg:rounded-[3rem] p-6 lg:p-16 shadow-[0_10px_40px_rgba(0,0,0,0.04)] mx-auto max-w-[1200px] border border-slate-50">
                    <div class="flex flex-col lg:flex-row justify-between items-center border-b border-slate-100 pb-8 gap-6">
                        <div class="flex items-center gap-6">
                            <div class="w-20 h-20 bg-orange-100 text-[#ea580c] rounded-[1.5rem] flex items-center justify-center text-4xl font-black shadow-inner">
                                @(!string.IsNullOrEmpty(acceptedDetails?.FullName) ? acceptedDetails.FullName[0].ToString() : "A")
                            </div>
                            <div class="text-center lg:text-left">
                                <h2 class="text-3xl lg:text-4xl font-bold text-slate-900">@(acceptedDetails?.FullName ?? "Accepted Applicant")</h2>
                                <p class="text-green-500 font-bold text-sm mt-1 flex items-center justify-center lg:justify-start gap-2">
                                    <i class="fas fa-check-circle"></i> Applicant Accepted • Handover Active
                                </p>
                            </div>
                        </div>
                        <a href="tel:@acceptedDetails?.PhoneNumber" class="w-full lg:w-auto px-10 py-4 bg-slate-900 text-white rounded-2xl font-bold hover:bg-black transition-all flex items-center justify-center gap-3 shadow-lg">
                            <i class="fas fa-phone-alt"></i> Call Adopter
                        </a>
                    </div>

                    @* عرض الـ 3 حقول الحيوية المريحة *@
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mt-10">
                        <div class="bg-slate-50/50 border border-slate-100 rounded-2xl p-6 flex items-center gap-4">
                            <div class="w-12 h-12 bg-white text-[#ea580c] rounded-xl flex items-center justify-center shadow-sm"><i class="fas fa-user"></i></div>
                            <div><p class="text-[#ea580c] text-[10px] font-black uppercase tracking-wider">Full Name</p><p class="font-bold text-slate-700 text-base">@(acceptedDetails?.FullName ?? "N/A")</p></div>
                        </div>

                        <div class="bg-slate-50/50 border border-slate-100 rounded-2xl p-6 flex items-center gap-4">
                            <div class="w-12 h-12 bg-white text-[#ea580c] rounded-xl flex items-center justify-center shadow-sm"><i class="fas fa-mobile-alt"></i></div>
                            <div><p class="text-[#ea580c] text-[10px] font-black uppercase tracking-wider">Phone Number</p><p class="font-bold text-slate-700 text-lg">@(acceptedDetails?.PhoneNumber ?? "No Phone")</p></div>
                        </div>

                        <div class="bg-slate-50/50 border border-slate-100 rounded-2xl p-6 flex items-center gap-4">
                            <div class="w-12 h-12 bg-white text-[#ea580c] rounded-xl flex items-center justify-center shadow-sm"><i class="fas fa-envelope"></i></div>
                            <div><p class="text-[#ea580c] text-[10px] font-black uppercase tracking-wider">Email Address</p><p class="font-bold text-slate-700 text-base break-all">@(acceptedDetails?.Email ?? "No Email")</p></div>
                        </div>
                    </div>

                    @* OTP Final Verification Section *@
                    @if (acceptedDetails?.StatusTransaction == "WaitingForDelivery")
                    {
                    <div class="bg-[#0f172a] rounded-[2rem] p-8 lg:p-12 mt-10 text-center relative z-20">
                        <p class="text-white text-sm mb-4">Enter the One-Time Password (OTP) code to finalize the handover process inside database</p>
                        <div class="flex justify-center gap-2 md:gap-4 mt-4">
                            @for (int i = 0; i < 6; i++)
                            {
                                var index = i;
                                <input id="otp-@index" type="text" inputmode="numeric" maxlength="1" @bind="otpCode[index]" class="w-11 h-16 md:w-16 md:h-20 rounded-xl border-none bg-white text-center text-2xl font-black text-slate-900" oninput="moveNext(this, @index)" onkeydown="moveBack(event, @index)" />
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(otpStatusMessage))
                        {
                            <p class="text-sm mt-4 font-bold text-orange-400">@otpStatusMessage</p>
                        }
                        <button class="mt-6 bg-[#ea580c] hover:bg-[#d44d0b] text-white px-8 py-3 rounded-xl font-bold transition-all" @onclick="SubmitOtpCode">
                            Confirm Code & Complete Order
                        </button>
                    </div>
        }
        else if (acceptedDetails?.StatusTransaction == "InFosterCare")
                    {
                        @* 🔥 إذا أصبحت الحالة في الاستضافة المؤقتة، نعرض رسالة مريحة للمالك بدون حقل الكود *@
                        <div class="bg-emerald-950 border border-emerald-800/30 rounded-[2rem] p-8 lg:p-12 mt-10 text-center relative z-20">
                            <div class="w-16 h-16 bg-emerald-500/10 text-emerald-400 rounded-full flex items-center justify-center text-2xl mx-auto mb-4">
                                <i class="fas fa-home"></i>
                            </div>
                            <h3 class="text-xl font-bold text-emerald-400 mb-2">Pet is Currently in Foster Care</h3>
                            <p class="text-emerald-200/70 text-sm max-w-md mx-auto">
                                The handover was successful! Use the contact details above to follow up with the fosterer or check on your pet's updates.
                            </p>
                        </div>
                    }
                </div>
            }
            else
            {
                @* --- 3. Interested Adopters List --- *@
                <div class="max-w-[1200px] mx-auto">
                    <div class="mb-8 flex flex-col md:flex-row items-center justify-between px-4 gap-4">
                        <h3 class="text-3xl font-bold text-slate-800 tracking-tight">Interested Adopters</h3>
                        <span class="bg-orange-50 text-[#ea580c] px-6 py-2 rounded-full font-black text-xs border border-orange-100">
                            @((applicants != null) ? applicants.Count : 0) REQUESTS
                        </span>
                    </div>

                    @if (applicants == null || !applicants.Any())
                    {
                        <div class="bg-white p-12 rounded-[2rem] text-center border border-dashed border-slate-200">
                            <p class="text-slate-400 font-medium text-lg">No active adoption requests found for this pet in the database.</p>
                        </div>
                    }
                    else
                    {
                        <div class="grid gap-6">
                            @foreach (var app in applicants)
                            {
                                <div class="bg-white rounded-[2rem] p-6 lg:p-10 flex flex-col lg:flex-row items-center gap-8 border border-slate-100 shadow-sm">
                                    <div class="w-20 h-20 bg-slate-50 border border-slate-200 rounded-2xl flex items-center justify-center text-3xl text-slate-400 font-bold">
                                        @(!string.IsNullOrEmpty(app?.FullName) ? app.FullName[0].ToString() : "A")
                                    </div>
                                    <div class="flex-grow text-center lg:text-left space-y-2">
                                        <h4 class="text-2xl font-bold text-slate-800">@(app?.FullName ?? "Unknown Adopter")</h4>
                                        <div class="flex justify-center lg:justify-start gap-6">
                                            <div class="flex items-center gap-2 text-slate-500">
                                                <i class="fas fa-globe text-[#ea580c]"></i>
                                                <span class="text-sm font-semibold">@(app?.Nationality ?? "N/A")</span>
                                            </div>
                                            <div class="flex items-center gap-2 text-slate-500">
                                                <i class="fas fa-comment-alt text-[#ea580c]"></i>
                                                <span class="text-sm">@(app?.ReasonOfApplication ?? "No reason provided.")</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="flex gap-3 w-full lg:w-auto">
                                        <button class="flex-1 lg:flex-none bg-[#ea580c] text-white px-8 py-4 rounded-xl font-bold hover:bg-[#d44d0b] transition-colors" @onclick="() => RequestAcceptance(app)">Accept Request</button>
                                        <button class="flex-1 lg:flex-none bg-white border-2 border-slate-100 text-slate-400 px-8 py-4 rounded-xl font-bold hover:bg-slate-50" @onclick="() => DeclineApplicant(app)">Decline</button>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        }
    </main>

    @* --- 4. Confirmation Popup Modal --- *@
    @if (showConfirmModal)
    {
        <div class="fixed inset-0 z-[2000] flex items-center justify-center p-4 bg-slate-900/60 backdrop-blur-sm">
            <div class="bg-white p-8 lg:p-12 rounded-[2.5rem] text-center max-w-md w-full shadow-2xl">
                <h3 class="text-2xl font-bold text-slate-900 mb-2">Are you sure?</h3>
                <p class="text-slate-500 mb-10 text-sm">Accepting @appToAccept?.FullName's request will update transaction records and share contact info.</p>
                <div class="flex gap-4">
                    <button class="flex-1 py-4 text-slate-400 font-bold" @onclick="CancelAcceptance">Cancel</button>
                    <button class="flex-1 py-4 bg-[#ea580c] text-white rounded-2xl font-bold" @onclick="ConfirmAcceptance">Yes, Accept</button>
                </div>
            </div>
        </div>
    }

</div>

<script>
    function moveNext(el, index) { if (el.value.length === 1 && index < 5) { const next = document.getElementById('otp-' + (index + 1)); if (next) next.focus(); } }
    function moveBack(event, index) { if (event.key === "Backspace" && !event.target.value && index > 0) { const prev = document.getElementById('otp-' + (index - 1)); if (prev) prev.focus(); } }
</script>

@code {
    [Parameter] public int AnimalId { get; set; }

    private AnimalReadDto? animalItem;
    private List<ApplicantDTO> applicants = new();
    private ApplicantDTO? selectedApplicant;
    private ApplicantDTO? appToAccept;
    private ContactDetailsDTO? acceptedDetails = new ContactDetailsDTO(); // حماية ابتدائية

    private int currentTransactionId;
    private string[] otpCode = new string[6];
    private string otpStatusMessage = "";

    private bool isAcceptedState = false;
    private bool showConfirmModal = false;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await FetchRealDataFromDatabase();
    }

    private async Task FetchRealDataFromDatabase()
    {
        isLoading = true;
        animalItem = await AnimalService.GetAnimalByOfCustomerIdAsync(AnimalId);

        // 1. تحقق أولاً: هل هناك شخص مقبول وننتظر الكود؟
        var accepted = await TransactionService.GetAcceptedApplicantDetailsAsync(AnimalId);
        if (accepted != null)
        {
            acceptedDetails = accepted;
            isAcceptedState = true;

            // 🔥 الحل هنا: إعادة تعيين المعرّف من البيانات القادمة من الباكيند مباشرة لحمايتها من الـ Refresh
            currentTransactionId = accepted.TransactionId;
        }
        else
        {
            // 2. إذا لم يكن هناك مقبول، اجلب قائمة الانتظار
            var apiApplicants = await TransactionService.GetApplicantsForAnimalAsync(AnimalId);
            if (apiApplicants != null) applicants = apiApplicants;
            isAcceptedState = false;
        }
        isLoading = false;
    }

    private void RequestAcceptance(ApplicantDTO app)
    {
        appToAccept = app;
        selectedApplicant = app;
        showConfirmModal = true;
    }

    private void CancelAcceptance()
    {
        appToAccept = null;
        showConfirmModal = false;
    }

    private async Task ConfirmAcceptance()
    {
        if (appToAccept == null) return;

        try
        {
            currentTransactionId = appToAccept.TransactionId;

            var response = await TransactionService
                .AcceptApplicantAsync(appToAccept.TransactionId);

            // إذا رجعت البيانات من الباك
            if (response != null && response.Data != null)
            {
                acceptedDetails = response.Data;
            }
            else
            {
                // fallback احتياطي
                acceptedDetails = new ContactDetailsDTO
                {
                    FullName = appToAccept.FullName,
                    PhoneNumber = "No Phone",
                    Email = "No Email"
                };
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error during acceptance: {ex.Message}");

            // حتى لو صار Exception لا تخربين التنقل
            acceptedDetails = new ContactDetailsDTO
            {
                FullName = appToAccept.FullName,
                PhoneNumber = "Error Loading",
                Email = "Error Loading"
            };
        }
        finally
        {
            selectedApplicant = appToAccept;

           
            isAcceptedState = true;

            showConfirmModal = false;
            appToAccept = null;

            StateHasChanged();
        }
    }

    private async Task SubmitOtpCode()
    {
        string fullCode = string.Join("", otpCode);
        if (fullCode.Length < 6)
        {
            otpStatusMessage = "❌ Please enter the complete 6-digit code.";
            StateHasChanged();
            return;
        }

        try
        {
            otpStatusMessage = "⏳ Verifying code...";
            StateHasChanged();

            var confirmRequest = new ConfirmCodeRequest
            {
                TransactionId = currentTransactionId,
                Code = fullCode
            };

            // 1. إرسال الطلب للسيرفر
            var response = await TransactionService.ConfirmDeliveryAsync(confirmRequest);

            // 🚨 2. التحقق الحقيقي والمضمون من نجاح العملية
            // إذا كان الباكيند يعيد كود نجاح (مثلاً true أو Response ممتلئ بحالة نجاح)
            if (response != null)
            {
                otpStatusMessage = "🎉 Handover Confirmed";
                StateHasChanged();

                // ننتظر ثانية ليقرأ المستخدم رسالة النجاح
                await Task.Delay(1000);

                // تفريغ مصفوفة الأرقام
                otpCode = new string[6];

                Navigation.NavigateTo("/my-animals");
            }
            else
            {
                // إذا السيرفر رجع استجابة ممتلئة بـ Null أو تعني الفشل
                otpStatusMessage = "❌ Invalid confirmation code. Please try again.";
            }
        }
        catch (Exception ex)
        {
            // 💥 هنا سيتم التقاط خطأ الـ 400 Bad Request الذي ظهر في الصورة الثالثة!
            Console.WriteLine($"Verification error: {ex.Message}");
            otpStatusMessage = "❌ Incorrect OTP Code. Please verify and try again.";
        }
        finally
        {
            StateHasChanged();
        }
    }
    private async Task DeclineApplicant(ApplicantDTO app)
    {
        try
        {
            await TransactionService.RejectApplicantAsync(app.TransactionId);
            applicants.Remove(app);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error declining applicant: {ex.Message}");
        }
    }

    private string CalculateAge(DateTime? birthDate)
    {
        if (!birthDate.HasValue) return "Unknown";
        var today = DateTime.Today;
        var age = today.Year - birthDate.Value.Year;
        if (birthDate.Value.Date > today.AddYears(-age)) age--;
        return age <= 0 ? "Under 1 Year" : $"{age} Years";
    }
}