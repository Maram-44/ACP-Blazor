@page "/medical-centers"
@using ACP.Components.MedicalCenters
@namespace ACP.Features.MedicalCenters
@using ACP.Features.MedicalCenters.DTOs
<div class="min-h-screen bg-[#FDFDFD]">
    @* 1. Hero Section *@
    <MedicalHero TitlePart1="Premium Care"
                 TitlePart2="For Your Pets"
                 BadgeText="Your Pet's Health is Our Priority ✨" />

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

        @* 2. Filter Section (تمت موازنة المحاذاة وتصغير حجم الكبسولة لتصبح متزنة بصرياً 100%) *@
        <div class="flex items-center justify-center -mt-8 mb-10 relative z-10">
            <div class="w-full max-w-md bg-white rounded-full p-2.5 shadow-md border border-gray-100 flex flex-col items-center justify-center">

                <div class="w-full flex flex-col items-center justify-center">
                    @* عنوان الفلتر النصي الصافي محاذي تماماً للمنتصف *@
                    <label class="w-full text-center text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">
                        📍  FIND BY CITY
                    </label>

                    @* حاوية خيارات موزونة الأطراف والمسافات *@
                    <div class="w-full relative px-2 group flex items-center justify-center">
                        <select @onchange='(e) => HandleFilterChanged((e.Value?.ToString() ?? "all", "all"))'
                                class="w-full bg-slate-50 text-slate-700 font-bold border border-slate-200/70 rounded-full px-6 py-3 focus:outline-none focus:ring-4 focus:ring-orange-500/10 focus:border-orange-500 transition-all duration-300 text-center cursor-pointer appearance-none shadow-inner">
                            <option value="all">All Cities</option>
                            @foreach (var city in AvailableCities)
                            {
                                <option value="@city">@city</option>
                            }
                        </select>

                        @* السهم المنسدل الجمالي متموضع في طرف الكبسولة الداخلي بدقة *@
                        <div class="absolute inset-y-0 right-6 flex items-center pointer-events-none text-orange-500 group-hover:scale-110 transition-transform duration-200">
                            <svg class="w-4 h-4 stroke-current" fill="none" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                            </svg>
                        </div>
                    </div>

                    @* زر التصفير التفاعلي تحتهم مباشرة في السنتر *@
                    @if (selectedCity != "all")
                    {
                        <button @onclick="ResetFilters" class="mt-2 text-xs font-bold text-orange-500 hover:text-orange-600 transition-colors hover:underline">
                            Reset Filter
                        </button>
                    }
                </div>

            </div>
        </div>

        @* 3. Results Section *@
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-20 mt-4">
            @if (IsLoading)
            {
                <div class="col-span-full text-center py-20">
                    <div class="inline-block animate-spin rounded-full h-12 w-12 border-t-4 border-orange-500 border-opacity-50"></div>
                    <p class="mt-4 text-gray-400 font-medium">Fetching medical centers...</p>
                </div>
            }
            else if (FilteredCenters != null && FilteredCenters.Any())
            {
                @foreach (var center in FilteredCenters)
                {
                    var centerImage = !string.IsNullOrEmpty(center.ImagePath)
                    ? center.ImagePath
                    : "https://images.pexels.com/photos/6234610/pexels-photo-6234610.jpeg";

                    var fullLocation = $"{center.City}, {center.Street}";

                    var allServicesText = center.medicalCenterServices != null && center.medicalCenterServices.Any()
                    ? string.Join(" / ", center.medicalCenterServices.Select(s => s.ServiceName))
                    : "General Veterinary Services";

                    <MedicalCenterCard Id="@center.Id"
                                       Title="@center.Name"
                                       Description="@allServicesText"
                                       ImageUrl="@centerImage"
                                       Location="@fullLocation"
                                       PhoneNumber="@center.Phone"
                                       Email="@center.Email"
                                       OnCardClick="() => NavigateToDetails(center.Id)" />
                }
            }
            else
            {
                <div class="col-span-full text-center py-20">
                    <div class="bg-gray-50 rounded-[3rem] p-12 border-2 border-dashed border-gray-200 max-w-md mx-auto">
                        <h3 class="text-xl font-bold text-gray-400">No medical centers found.</h3>
                        <button @onclick="ResetFilters" class="mt-4 text-orange-500 font-bold hover:underline">Reset Filters</button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>


