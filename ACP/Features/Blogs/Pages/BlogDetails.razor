@page "/blog/{Id:int}"
@using ACP.Features.Blogs
@inject BlogHttpService BlogService
@inject NavigationManager Navigation

<main class="pt-32 pb-24 px-4 sm:px-6 lg:px-8 bg-white min-h-screen antialiased font-sans text-slate-900">
    <div class="max-w-6xl mx-auto">

        <button @onclick="GoBack" class="inline-flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-slate-400 hover:text-slate-900 transition-all duration-200 mb-10 group">
            <svg class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"></path>
            </svg>
            Back to Articles
        </button>

        @if (blog == null)
        {
            <div class="flex flex-col items-center justify-center py-24 space-y-4">
                <div class="w-10 h-10 border-4 border-slate-900 border-t-orange-500 rounded-full animate-spin"></div>
                <p class="text-slate-500 font-medium text-sm tracking-wide">Fetching the latest insights...</p>
            </div>
        }
        else
        {
            <div class="max-w-3xl mb-12 text-left pb-6 border-b border-slate-200/60 sm:border-none sm:pb-0">
                <h1 class="text-3xl sm:text-5xl font-black tracking-tight text-slate-950 leading-[1.2] sm:leading-[1.15] break-words">
                    @blog.Title
                </h1>
            </div>

            @if (!string.IsNullOrEmpty(blog.ImagePath))
            {
                <div class="max-w-2xl rounded-3xl overflow-hidden bg-slate-50 border border-slate-100 shadow-sm mb-16 ml-0">
                    <img src="@blog.ImagePath" alt="@blog.Title" class="w-full h-72 sm:h-96 object-cover select-none" />
                </div>
            }

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">

                <div class="lg:col-span-8 space-y-8 text-left">
                    <div class="text-slate-800 font-normal text-base sm:text-lg leading-[1.8] break-words whitespace-pre-wrap font-serif">
                        @blog.Content
                    </div>

                </div>

                <aside class="lg:col-span-4 lg:sticky lg:top-36 space-y-6 bg-slate-50/60 border border-slate-100 p-6 rounded-2xl">
                    <div>
                        <h4 class="text-[10px] font-bold uppercase tracking-wider text-slate-400 mb-1">Published On</h4>
                        <time class="text-sm font-semibold text-slate-700">
                            @blog.PublicationDate.ToString("MMMM dd, yyyy")
                        </time>
                    </div>

                    <div class="h-px bg-slate-200/60"></div>

                    <div class="space-y-3">
                        <div>
                            <h4 class="text-xs font-bold text-slate-900">Was this article helpful?</h4>
                            <p class="text-slate-400 text-xs mt-0.5">Share your feedback to help us sustain quality content.</p>
                        </div>

                        <button @onclick="HandleVote"
                                class="w-full inline-flex items-center justify-center gap-2.5 px-4 py-3 rounded-xl border text-sm font-bold transition-all duration-300 shadow-sm @(blog.IsVoted ? "bg-emerald-500 border-emerald-500 text-white" : "bg-white border-slate-200 text-slate-800 hover:border-slate-900 hover:bg-slate-50")">

                            <svg class="w-4 h-4 transition-transform @(blog.IsVoted ? "scale-110" : "group-hover:-translate-y-0.5")"
                                 fill="@(blog.IsVoted ? "currentColor" : "none")" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6.633 10.25c.806 0 1.533-.446 2.031-1.08a9.041 9.041 0 0 1 2.861-2.4c.723-.384 1.35-.956 1.653-1.715a4.498 4.498 0 0 1 3.223-2.79c.708-.152 1.4.341 1.411 1.066l.019 1.15a4.004 4.004 0 0 0 3.036 3.804 1.503 1.503 0 0 1 1.153 1.45c-.017.58-.2 1.132-.524 1.6a1.503 1.503 0 0 1-1.083.716l-1.002.14a4.005 4.005 0 0 0-3.155 3.518l-.111 1.1a1.503 1.503 0 0 1-1.12 1.327c-.64.162-1.304.246-1.986.246H9.75a4.5 4.5 0 0 1-4.5-4.5V10.25h1.383Z" />
                            </svg>

                            <span>@(blog.IsVoted ? "Voted as Helpful" : "Yes, it was helpful")</span>

                            <span class="inline-flex items-center justify-center px-2 py-0.5 rounded-md text-xs font-medium ml-1 @(blog.IsVoted ? "bg-white/20 text-white" : "bg-slate-100 text-slate-500")">
                                @blog.NumberOfVote
                            </span>
                        </button>
                    </div>
                </aside>

            </div>
        }
    </div>
</main>

@code {
    [Parameter] public int Id { get; set; }
    private ReadBlog? blog;

    protected override async Task OnInitializedAsync()
    {
        blog = await BlogService.GetBlogByIdAsync(Id);

        if (blog == null)
        {
            Navigation.NavigateTo("/blog");
        }
    }

    private async Task HandleVote()
    {
        if (blog == null) return;

        // 1. تحديث فوري وسريع للواجهة أمام المستخدم (Optimistic UI Update)
        if (blog.IsVoted)
        {
            blog.NumberOfVote--;
            blog.IsVoted = false;
        }
        else
        {
            blog.NumberOfVote++;
            blog.IsVoted = true;
        }

        // 2. إرسال الطلب للسيرفر بالخلفية
        var updatedCount = await BlogService.ToggleBlogVoteAsync(blog.Id);

        // 3. تأكيد الأرقام الحقيقية القادمة من السيرفر لضمان دقة البيانات
        if (updatedCount.HasValue)
        {
            blog.NumberOfVote = updatedCount.Value;
        }
        else
        {
            // في حال فشل السيرفر، نعيد الحالة السابقة حماية للبيانات
            if (blog.IsVoted)
            {
                blog.NumberOfVote--;
                blog.IsVoted = false;
            }
            else
            {
                blog.NumberOfVote++;
                blog.IsVoted = true;
            }
        }
    }

    private void GoBack() => Navigation.NavigateTo("/blog");
}