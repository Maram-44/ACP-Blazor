@namespace ACP.Components.HomeComponents

<section class="py-32 bg-slate-50 relative overflow-hidden">
    <div class="container mx-auto px-8 md:px-16 lg:px-24">
        <div class="max-w-3xl mb-20 text-left">
            <h2 class="text-orange-600 font-black tracking-widest uppercase text-sm mb-4">Our Community</h2>
            <h3 class="text-5xl md:text-6xl font-[900] text-slate-900 leading-tight">Built for everyone who <span class="text-slate-400">loves pets.</span></h3>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
            @* الكرت الأول: ملاك الحيوانات *@
            <div class="bg-white p-10 rounded-[3rem] shadow-sm border border-slate-100 hover:-translate-y-3 transition-all duration-500">
                <div class="w-16 h-16 bg-orange-100 rounded-2xl flex items-center justify-center text-3xl mb-8">🏠</div>
                <h4 class="text-2xl font-black mb-4">Pet Owners</h4>
                <p class="text-slate-500 text-sm leading-relaxed">Looking for the best care, tips, and professional guidance for their furry friends.</p>
            </div>

            @* الكرت الثاني: تصفح العيادات واستكشافها *@
            <div class="bg-white p-10 rounded-[3rem] shadow-sm border border-slate-100 hover:-translate-y-3 transition-all duration-500 mt-8 lg:mt-12">
                <div class="w-16 h-16 bg-blue-100 rounded-2xl flex items-center justify-center text-3xl mb-8">🩺</div>
                <h4 class="text-2xl font-black mb-4">Vets Directory</h4>
                <p class="text-slate-500 text-sm leading-relaxed">Explore top certified local veterinary clinics, their services, and expert medical teams easily.</p>
            </div>

            @* الكرت الثالث: المتبنين والمجازفين *@
            <div class="bg-white p-10 rounded-[3rem] shadow-sm border border-slate-100 hover:-translate-y-3 transition-all duration-500">
                <div class="w-16 h-16 bg-green-100 rounded-2xl flex items-center justify-center text-3xl mb-8">🐾</div>
                <h4 class="text-2xl font-black mb-4">Rescuers</h4>
                <p class="text-slate-500 text-sm leading-relaxed">Dedicated souls searching for forever homes for abandoned animals with full transparency.</p>
            </div>

            @* الكرت الرابع الجديد: المدوّنة والتواصل بين الملاك *@
            <div class="bg-white p-10 rounded-[3rem] shadow-sm border border-slate-100 hover:-translate-y-3 transition-all duration-500 mt-8 lg:mt-12">
                <div class="w-16 h-16 bg-purple-100 rounded-2xl flex items-center justify-center text-3xl mb-8">📝</div>
                <h4 class="text-2xl font-black mb-4">Pet Blog</h4>
                <p class="text-slate-500 text-sm leading-relaxed">Share your stories, ask questions, and connect with other pet parents to build a supportive community.</p>
            </div>
        </div>
    </div>
</section>

@code {

}