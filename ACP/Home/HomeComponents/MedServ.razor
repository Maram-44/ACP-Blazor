@namespace ACP.Components.HomeComponents

<section id="medical" class="py-24 bg-white">
    <div class="container mx-auto px-8 md:px-16 lg:px-24">
        @* الحاوية الرئيسية *@
        <div class="bg-slate-900 rounded-[4rem] p-12 md:p-20 text-white flex flex-col lg:flex-row gap-16 items-center shadow-2xl">

            @* الجانب الأيسر: نصوص تعريفية *@
            <div class="lg:w-1/2">
                <div class="flex items-center gap-2 mb-6">
                    <span class="w-12 h-[2px] bg-orange-500"></span>
                    <span class="text-orange-500 font-black uppercase tracking-[0.2em] text-sm">Our Network</span>
                </div>

                <h3 class="text-4xl md:text-5xl font-[1000] mb-8 leading-tight italic tracking-tighter">
                    Expert Veterinary <br> <span class="text-orange-500">Care Directory</span>
                </h3>

                <p class="text-slate-400 text-lg leading-relaxed mb-10">
                    We've curated a list of the most trusted veterinary clinics. Find the nearest professional help and get in touch directly.
                </p>

                @* أيقونات التواصل السريع (للعرض) *@
                <div class="space-y-6">
                    <div class="flex items-center gap-5 group">
                        <div class="w-12 h-12 bg-white/5 rounded-2xl flex items-center justify-center text-xl border border-white/10 group-hover:bg-orange-500 transition-colors">📍</div>
                        <div>
                            <p class="text-slate-100 font-bold">Verified Locations</p>
                            <p class="text-sm text-slate-500">Across all major city districts</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-5 group">
                        <div class="w-12 h-12 bg-white/5 rounded-2xl flex items-center justify-center text-xl border border-white/10 group-hover:bg-orange-500 transition-colors">📞</div>
                        <div>
                            <p class="text-slate-100 font-bold">Direct Contact</p>
                            <p class="text-sm text-slate-500">Instant phone and WhatsApp support</p>
                        </div>
                    </div>
                </div>
            </div>

            @* الجانب الأيمن: بطاقات معلومات العيادات (عرض توضيحي) *@
            <div class="lg:w-1/2 w-full grid gap-4">
                @* بطاقة عيادة مثال 1 *@
                <div class="bg-white/5 border border-white/10 p-6 rounded-3xl hover:bg-white/10 transition-all">
                    <div class="flex justify-between items-start mb-4">
                        <div>
                            <h4 class="text-xl font-black text-orange-500">Paws & Claws Clinic</h4>
                            <p class="text-xs text-slate-400 mt-1 uppercase tracking-widest">General Medicine • Surgery</p>
                        </div>
                        <span class="bg-green-500/20 text-green-500 text-[10px] px-3 py-1 rounded-full font-bold">OPEN NOW</span>
                    </div>
                    <div class="flex items-center gap-4 text-sm text-slate-300">
                        <span>📍 Al-Olaya St, Riyadh</span>
                        <span class="w-1 h-1 bg-slate-600 rounded-full"></span>
                        <span class="font-bold text-white">050 123 4567</span>
                    </div>
                </div>

                @* بطاقة عيادة مثال 2 *@
                <div class="bg-white/5 border border-white/10 p-6 rounded-3xl hover:bg-white/10 transition-all opacity-80 hover:opacity-100">
                    <div class="flex justify-between items-start mb-4">
                        <div>
                            <h4 class="text-xl font-black text-white">Happy Pet Center</h4>
                            <p class="text-xs text-slate-400 mt-1 uppercase tracking-widest">Vaccinations • Grooming</p>
                        </div>
                        <span class="bg-slate-800 text-slate-500 text-[10px] px-3 py-1 rounded-full font-bold">9 AM - 9 PM</span>
                    </div>
                    <div class="flex items-center gap-4 text-sm text-slate-300">
                        <span>📍 King Fahad Rd, Jeddah</span>
                        <span class="w-1 h-1 bg-slate-600 rounded-full"></span>
                        <span class="font-bold text-white">055 987 6543</span>
                    </div>
                </div>

                @* تلميح إضافي *@
                <div class="mt-4 text-center">
                    <p class="text-slate-500 text-xs font-bold uppercase tracking-widest">
                        + More verified clinics available in our full directory
                    </p>
                </div>
            </div>

        </div>
    </div>
</section>

@code {
    // الكود هنا للعرض فقط
}