@namespace ACP.Forms
@using ACP.Models.Animals
@inject NavigationManager Nav
@inject AnimalOprationsServices AnimalOprationsService

@if (Animal == null)
{
    <p class="text-center text-gray-400">
        No animal data available.
    </p>
}
else
{
    <div class="max-w-4xl mx-auto space-y-8 animate-fadeIn">

        <!-- Title -->
        <div class="text-center space-y-2">
            <h2 class="text-3xl font-semibold">
                @(Mode == "Adoption"
                            ? "Review & Confirm Adoption Request"
                            : "Review & Confirm Abandonment Request")
            </h2>

            <p class="text-gray-400">
                Please review the details before submitting your request
            </p>
        </div>


        <!-- Animal Information -->
        <section class="bg-slate-50 rounded-2xl shadow-md p-6 space-y-5 transition duration-300 hover:shadow-lg">

            <h3 class="text-xl font-semibold flex items-center gap-2">
                🐾 Animal Information
            </h3>

            <div class="grid md:grid-cols-2 gap-4 text-sm">

                <p><span class="font-semibold">Name:</span> @Animal.Name</p>
                <p><span class="font-semibold">Gender:</span> @Animal.Gender</p>
                <p><span class="font-semibold">Color:</span> @Animal.Color</p>
                <p><span class="font-semibold">Nationality:</span> @Animal.Nationality</p>
                <p><span class="font-semibold">City:</span> @Animal.City</p>
                <p><span class="font-semibold">Country:</span> @Animal.Country</p>

                <p class="md:col-span-2">
                    <span class="font-semibold">Description & Behavior:</span>
                    @Animal.Description
                </p>

                <p>
                    <span class="font-semibold">Passport:</span>
                    @(string.IsNullOrWhiteSpace(Animal.PassportNumber)
                                    ? "❌ Not Available"
                                    : "✅ Available")
                </p>

            </div>

        </section>


        <!-- Health -->
        <section class="bg-slate-50 rounded-2xl shadow-md p-6 space-y-5 transition duration-300 hover:shadow-lg">

            <h3 class="text-xl font-semibold flex items-center gap-2">
                ❤️ Health Information
            </h3>

            <div>
                <p class="font-semibold mb-2">Vaccinations</p>

                @if (Animal.AnimalVaccination?.Any() == true)
                {
                    <ul class="list-disc ml-6 text-sm space-y-1">
                        @foreach (var v in Animal.AnimalVaccination)
                        {
                            <li>💉 @v.Vaccination</li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-sm text-gray-400">No vaccinations recorded</p>
                }
            </div>

            <div>
                <p class="font-semibold mb-2">Surgeries</p>

                @if (Animal.animalSurgicalOperations?.Any() == true)
                {
                    <ul class="list-disc ml-6 text-sm space-y-1">
                        @foreach (var s in Animal.animalSurgicalOperations)
                        {
                            <li>
                                🩺 @s.SurgicalOperation
                                @if (!string.IsNullOrWhiteSpace(s.OperationStatus))
                                {
                                    <span class="text-xs text-gray-400">
                                        (@s.OperationStatus)
                                    </span>
                                }
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-sm text-gray-400">No surgeries recorded</p>
                }
            </div>

        </section>


        <!-- Images -->
        @if (Animal.animalImages?.Any() == true)
        {
            <section class="bg-slate-50 rounded-2xl shadow-md p-6 space-y-5 transition duration-300 hover:shadow-lg">

                <h3 class="text-xl font-semibold flex items-center gap-2">
                    📸 Animal Images
                </h3>

                <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">

                    @foreach (var img in Animal.animalImages)
                    {
                        <img src="@img.Image"
                             class="h-36 w-full object-cover rounded-xl shadow-sm hover:scale-105 transition" />
                    }

                </div>

            </section>
        }


        <!-- Agreement -->
        <section class="bg-slate-50 rounded-2xl shadow-md p-6 space-y-5 transition duration-300 hover:shadow-lg">

            <h3 class="text-xl font-semibold flex items-center gap-2">
                📄 Agreement
            </h3>

            <p class="text-sm text-gray-500">
                By submitting this request, you agree to the platform’s privacy policy
                and animal welfare terms.
            </p>

            <div class="flex items-start gap-3">

                <input type="checkbox"
                       class="mt-1 w-5 h-5 accent-orange-600 cursor-pointer"
                       @bind="IsAgreed" />

                <label class="text-sm">
                    I agree to the Privacy Policy & Terms
                </label>

            </div>

        </section>


        <!-- Confirm Button -->
        <div class="flex justify-center">

            <button type="button"
                    disabled="@(!IsAgreed || IsSubmitting)"
                    @onclick="SubmitRequest"
                    class="bg-orange-600 text-white px-10 py-5 rounded-full font-black text-lg
                               hover:shadow-2xl hover:bg-orange-700 transition-all
                               flex items-center justify-center gap-3
                               @(IsAgreed ? "" : "opacity-50 cursor-not-allowed")">

                @if (IsSubmitting)
                {
                    <span class="loader"></span>
                    <span>Processing...</span>
                }
                else
                {
                    @(Mode == "Adoption" ? "Confirm Adoption" : "Confirm Abandonment")
                }

            </button>

        </div>

    </div>
}


@if (ShowSuccessPopup)
{
    <div class="fixed inset-0 bg-black/40 flex items-center justify-center z-50">

        <div class="bg-white rounded-3xl shadow-xl max-w-md w-full p-8 relative text-center animate-popup">

            @if (Mode == "Adoption")
            {
                <button class="absolute top-4 right-4 text-gray-400 hover:text-gray-700 text-xl"
                        @onclick="GoToAdoptionAnimals">
                    ✕
                </button>
            }

            <div class="text-6xl text-orange-500 mb-4 animate-star">
                ⭐
            </div>

            <h3 class="text-xl font-bold mb-2">
                @(Mode == "Adoption"
                            ? "Adoption Request Submitted Successfully"
                            : "Rehoming Request Submitted Successfully")
            </h3>

            <p class="text-sm text-gray-500 mb-6">
                You will be contacted via email soon.
            </p>

            <button class="w-full bg-orange-600 text-white py-3 rounded-xl font-semibold hover:bg-orange-700 transition"
                    @onclick="GoHome">
                Back To Home
            </button>

        </div>
    </div>
}


@code {

    [Parameter, EditorRequired]
    public Animal Animal { get; set; } = default!;

    [Parameter]
    public string Mode { get; set; } = "Adoption";

    private bool IsAgreed;
    private bool ShowSuccessPopup;
    private bool IsSubmitting;

    private async Task SubmitRequest()
    {
        IsSubmitting = true;
        await Task.Delay(1200);
        IsSubmitting = false;
        ShowSuccessPopup = true;
    }

    private void GoHome()
    {
        Nav.NavigateTo("/");
    }

    private void GoToAdoptionAnimals()
    {
        Nav.NavigateTo("/animals-for-adoption");
    }
}