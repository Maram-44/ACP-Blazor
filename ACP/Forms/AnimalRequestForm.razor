@namespace ACP.Forms
@using ACP.Models.Animals
@using Microsoft.AspNetCore.Components.Forms
@using ACP.Services

@inject NavigationManager Nav
@inject AnimalServices AnimalServices

<EditForm Model="animal" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />

    <div class="max-w-5xl mx-auto space-y-10 p-6 animate-fadeIn">

        <!-- Title -->
        <div class="text-center space-y-3">
            <h2 class="text-4xl font-bold">
                @(Mode == AnimalRequestMode.Abandonment
                                ? "Rehoming Request"
                                : "Foster Care Request")
            </h2>

            <p class="text-gray-500">
                Provide accurate information about your pet
                <span class="block text-sm text-orange-500">
                    (Make sure your profile is completed first)
                </span>
            </p>
        </div>

        <!-- CARD -->
        <div class="bg-[#f3f4f6] rounded-3xl p-8 border border-gray-200 space-y-10 shadow-sm">

            <!-- Animal Info -->
            <section class="space-y-6">

                <h3 class="text-2xl font-semibold">🐾 Animal Information</h3>

                <div class="grid md:grid-cols-2 gap-6">

                    <InputText @bind-Value="animal.Name"
                               placeholder="Name"
                               class="input" />

                    <InputText @bind-Value="animal.Color"
                               placeholder="Color"
                               class="input" />

                    <InputSelect @bind-Value="animal.Gender"
                                 class="input">

                        <option value="" disabled selected hidden>
                            Select Gender
                        </option>

                        <option>Male</option>
                        <option>Female</option>

                    </InputSelect>

                    <!-- Birth Date -->
                    <InputDate @bind-Value="animal.BirthDate"
                               class="input" />

                    <InputText @bind-Value="animal.PassportNumber"
                               placeholder="Passport Number *"
                               class="input" />

                    <InputSelect @bind-Value="animal.AnimalTypeId"
                                 class="input">

                        <option value="0" disabled selected hidden>
                            Select Animal Type
                        </option>

                        <option value="1">Cat</option>
                        <option value="2">Dog</option>
                        <option value="3">Bird</option>
                        <option value="4">Rabbit</option>

                    </InputSelect>

                    <InputText @bind-Value="animal.Breed"
                               class="input"
                               placeholder="Breed (e.g. Persian, Husky...)" />

                    <InputText @bind-Value="animal.City"
                               placeholder="City *"
                               class="input" />

                    <InputText @bind-Value="animal.Country"
                               placeholder="Country * "
                               class="input" />

                </div>

                <!-- Description -->
                <textarea @bind="animal.Description"
                          placeholder="Description"
                          class="input w-full min-h-[120px] mt-4"></textarea>

                <!-- Image -->
                <div class="space-y-2">

                    <label class="text-sm text-gray-600">
                        Upload Pet Images
                    </label>

                    <InputFile OnChange="HandleImage"
                               Multiple
                               class="input" />

                </div>

            </section>

            <!-- Health -->
            <section class="space-y-6 pt-4">

                <h3 class="text-2xl font-semibold">
                    🩺 Health Information
                </h3>

                <!-- Vaccination -->
                <div class="space-y-3">

                    <label>Is the animal vaccinated?</label>

                    <div class="flex gap-4">

                        <button type="button"
                                class="choice-btn @(isVaccinated == true ? "active" : "")"
                                @onclick="() => isVaccinated = true">
                            Yes
                        </button>

                        <button type="button"
                                class="choice-btn @(isVaccinated == false ? "active" : "")"
                                @onclick="() => isVaccinated = false">
                            No
                        </button>

                    </div>

                    @if (isVaccinated == true)
                    {
                        <label class="text-sm text-gray-600">
                            Vaccination Details
                        </label>

                        <textarea @bind="vaccinationDetails"
                                  class="input w-full min-h-[100px]"
                                  placeholder="Enter vaccination details"></textarea>
                    }

                </div>

                <!-- Surgery -->
                <div class="space-y-3">

                    <label>Any surgical operations?</label>

                    <div class="flex gap-4">

                        <button type="button"
                                class="choice-btn @(hasSurgery == true ? "active" : "")"
                                @onclick="() => hasSurgery = true">
                            Yes
                        </button>

                        <button type="button"
                                class="choice-btn @(hasSurgery == false ? "active" : "")"
                                @onclick="() => hasSurgery = false">
                            No
                        </button>

                    </div>

                    @if (hasSurgery == true)
                    {
                        <label class="text-sm text-gray-600">
                            Surgery Details
                        </label>

                        <textarea @bind="surgeryDetails"
                                  class="input w-full min-h-[100px]"
                                  placeholder="Enter surgery details"></textarea>
                    }

                </div>

            </section>

        </div>

        <!-- Submit -->
        <div class="flex justify-center pt-6">

            <button type="submit"
                    disabled="@(!IsFormValid())"
                    class="submit-btn">

                Submit Request

            </button>

        </div>

        <!-- Popup -->
        @if (showPopup)
        {
            <div class="fixed inset-0 bg-black/40 flex items-center justify-center z-50">

                <div class="bg-white rounded-3xl shadow-xl max-w-md w-full p-8 relative text-center animate-popup">

                    <!-- زر الإغلاق -->
                    <button class="absolute top-4 right-4 text-gray-400 hover:text-gray-700 text-xl"
                            @onclick="GoHome">
                        ✕
                    </button>

                    <!-- أيقونة -->
                    <div class="text-6xl text-orange-500 mb-4 animate-star">
                        ⭐
                    </div>

                    <!-- العنوان -->
                    <h3 class="text-xl font-bold mb-2">
                        Foster Care Request Submitted Successfully
                    </h3>

                    <!-- النص -->
                    <p class="text-sm text-gray-500 mb-6">
                        You will be contacted via email soon.
                    </p>

                    <!-- الزر -->
                    <button class="w-full bg-orange-600 text-white py-3 rounded-xl font-semibold hover:bg-orange-700 transition"
                            @onclick="GoHome">

                        Back To Home

                    </button>

                </div>

            </div>
        }

    </div>
</EditForm>

@code {

    private AnimalUpsertFormModel animal = new()
    {
        BirthDate = DateTime.Today.AddYears(-1)
    };

    private bool? isVaccinated;
    private string? vaccinationDetails;

    private bool? hasSurgery;
    private string? surgeryDetails;

    private bool showPopup = false;

    private void GoHome()
    {
        Nav.NavigateTo("/");
    }

    [Parameter]
    public AnimalRequestMode Mode { get; set; }

    private async Task HandleSubmit()
    {
        var success =
            await AnimalServices.AddNewAnimalWithImages(animal);

        if (success)
        {
            if (Mode == AnimalRequestMode.Abandonment)
            {
                Nav.NavigateTo("/confirm-abandonment");
            }
            else
            {
                showPopup = true;
            }
        }
    }

    private async Task HandleImage(InputFileChangeEventArgs e)
    {
        animal.SelectedImages.Clear();

        foreach (var file in e.GetMultipleFiles())
        {
            animal.SelectedImages.Add(file);
        }

        await Task.CompletedTask;
    }

    private bool IsFormValid()
    {
        if (string.IsNullOrWhiteSpace(animal.Name) ||
            string.IsNullOrWhiteSpace(animal.Description) ||
            string.IsNullOrWhiteSpace(animal.Color) ||
            string.IsNullOrWhiteSpace(animal.City) ||
            string.IsNullOrWhiteSpace(animal.Country) ||
            string.IsNullOrWhiteSpace(animal.Breed) ||
            animal.AnimalTypeId <= 0)
            return false;

        if (isVaccinated == true &&
            string.IsNullOrWhiteSpace(vaccinationDetails))
            return false;

        if (hasSurgery == true &&
            string.IsNullOrWhiteSpace(surgeryDetails))
            return false;

        return true;
    }

    public enum AnimalRequestMode
    {
        Abandonment,
        FosterCare
    }
}