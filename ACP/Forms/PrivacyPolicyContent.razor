@namespace ACP.Forms
@inject NavigationManager Nav

<div class="max-w-4xl mx-auto p-6 space-y-8 animate-fadeIn">

    <!-- Title -->
    <div class="text-center space-y-2">
        <h1 class="text-4xl font-bold">Privacy Policy & Terms</h1>

        <!-- ✅ صار برتقالي -->
        <p class="text-orange-500 font-medium">
            Please read carefully before continuing
        </p>
    </div>

    <!-- CARD -->
    <div class="bg-[#f3f4f6] border border-gray-200 rounded-3xl p-6 shadow-sm space-y-6">

        <!-- Scroll Content -->
        <div class="policy-box">

            <!-- ✅ غيرنا Introduction -->
            <h2>1. Overview</h2>
            <p>
                By using our platform, you agree to follow all rules and policies stated below.
            </p>

            <h2>2. User Responsibility</h2>
            <p>
                You are responsible for providing accurate information when submitting requests.
            </p>

            <h2>3. Animal Welfare</h2>
            <p>
                All users must ensure the safety and proper care of animals at all times.
            </p>

            <h2>4. Privacy</h2>
            <p>
                Your personal information will be securely stored and never shared without consent.
            </p>

            <!-- ✅ التعديل المهم -->
            <h2>5. Disclaimer</h2>
            <p>
                The platform is not responsible for the animal after adoption.
                If the adopter fails to provide updates to the previous owner,
                the platform will take action by restricting the adopter’s access,
                preventing them from submitting future adoption requests.
            </p>

            <h2>6. Agreement</h2>
            <p>
                By accepting, you confirm that you have read and understood all terms.
            </p>

        </div>

        <!-- Agree -->
        <div class="flex items-center gap-3 pt-2">

            <!-- ✅ برتقالي -->
            <input type="checkbox"
                   @bind="isChecked"
                   class="w-5 h-5 accent-orange-600 cursor-pointer" />

            <span class="text-sm">
                I have read and agree to the terms & privacy policy
            </span>
        </div>

    </div>

    <!-- Button -->
    <div class="flex justify-center pt-4">

        <!-- ✅ نفس ستايل أزرارك -->
        <button class="bg-orange-600 text-white px-10 py-4 rounded-full font-bold
                       hover:bg-orange-700 transition disabled:bg-gray-400"
                disabled="@(!isChecked)"
                @onclick="Continue">

            Continue

        </button>

    </div>

</div>

@code {
    private bool isChecked = false;

    private void Continue()
    {
        Nav.NavigateTo("/");
    }
}