@using ACP.Features.Animals
@inject NavigationManager Nav
@inject AccountService AccountService

<nav class="fixed w-full z-[100] top-0 bg-white/80 backdrop-blur-md border-b border-slate-100">
    <div class="max-w-7xl mx-auto px-8 md:px-16 py-4 flex justify-between items-center">

        @* --- Logo --- *@
        <div class="text-2xl font-black text-orange-600 flex items-center gap-2 tracking-tighter shrink-0">
            <a href="/" class="flex items-center gap-2">
                <span class="text-3xl">🐾</span> ALEF
            </a>
        </div>

        @* --- Main Navigation (Simplified) --- *@
        <div class="hidden md:flex items-center gap-10 font-bold text-slate-600 text-sm tracking-tight">
            <a href="/browse-animals" class="hover:text-orange-600 transition">Animals</a>
            <a href="/medical-centers" class="hover:text-orange-600 transition">Clinics</a>
            <a href="/blog " class="hover:text-orange-600 transition">Blog</a>
        </div>

        <AuthorizeView>
            <Authorized>
                @* --- User Profile Dropdown (Contains Everything Now) --- *@
                <div class="relative">
                    <button @onclick="ToggleUserMenu" class="flex items-center gap-3 group focus:outline-none bg-slate-50 p-1.5 pr-4 rounded-full hover:bg-slate-100 transition-all">
                        <div class="w-9 h-9 bg-orange-600 rounded-full flex items-center justify-center text-white font-black shadow-md">
                            @(context.User.Identity?.Name?[0].ToString().ToUpper() ?? "U")
                        </div>
                        <div class="text-left hidden sm:block">
                            <p class="text-sm font-black text-slate-900 flex items-center gap-1">
                                @(context.User.Identity?.Name?.Split('@')[0] ?? "User")
                                <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                            </p>
                        </div>
                    </button>

                    @if (isUserMenuOpen)
                    {
                        <div class="absolute top-full right-0 mt-3 w-72 bg-white border border-slate-100 rounded-[2rem] shadow-[0_20px_50px_rgba(0,0,0,0.12)] py-5 z-[110] overflow-hidden animate-in fade-in zoom-in-95">

                            @* قسم الأكشنز (اللي كان بره ودخلناه هنا) *@
                            <div class="px-6 pb-3">
                                <p class="text-[10px] font-black text-orange-600 uppercase tracking-widest mb-3">Quick Actions</p>
                                <div class="grid grid-cols-2 gap-2">
                                    <a href="/add-animal" class="flex flex-col items-center justify-center p-3 bg-slate-50 rounded-2xl hover:bg-orange-50 transition-colors group/item">
                                        <span class="text-xl mb-1 group-hover/item:scale-110 transition-transform">🐱</span>
                                        <span class="text-[11px] font-bold text-slate-700">Add Pet</span>
                                    </a>
                                    <a href="/add-animal" class="flex flex-col items-center justify-center p-3 bg-slate-50 rounded-2xl hover:bg-green-50 transition-colors group/item">
                                        <span class="text-xl mb-1 group-hover/item:scale-110 transition-transform">🏠</span>
                                        <span class="text-[11px] font-bold text-slate-700">Foster</span>
                                    </a>
                                </div>
                            </div>

                            <div class="h-px bg-slate-50 my-2 mx-6"></div>

                            @* قسم القوائم الشخصية *@
                            <div class="px-2">
                                @* 1. رابط الملف الشخصي - تظهر النقطة الحمراء إذا لم يكتمل الملف *@
                                <a href="/profile" class="flex items-center justify-between px-6 py-3 hover:bg-slate-50 text-slate-700 font-bold transition rounded-xl mx-2">
                                    <div class="flex items-center gap-3">
                                        <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                                        My Profile
                                    </div>

                                    @if (IsProfileIncomplete) @* شرط: لو البيانات ناقصة *@
                                    {
                                        <span class="relative flex h-2 w-2">
                                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                                            <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
                                        </span>
                                    }
                                </a>

                                @* 2. رابط حيواناتي - تظهر النقطة الحمراء إذا انتهت الرعاية المؤقتة وبانتظار الكود *@
                                <a href="/my-animals" class="flex items-center justify-between px-6 py-3 hover:bg-slate-50 text-slate-700 font-bold transition rounded-xl mx-2">
                                    <div class="flex items-center gap-3">
                                        <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path></svg>
                                        My Animals
                                    </div>

                                    @if (IsFosterPeriodEnded) @* شرط: لو انتهت فترة الرعاية ومحتاج كود إرجاع *@
                                    {
                                        <span class="relative flex h-2 w-2">
                                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                                            <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
                                        </span>
                                    }
                                </a>

                                @* 3. رابط طلباتي - تظهر النقطة الحمراء إذا حدث تغيير (قبول أو رفض) للطلبات *@
                                <a href="/my-requests" class="flex items-center justify-between px-6 py-3 hover:bg-slate-50 text-slate-700 font-bold transition rounded-xl mx-2">
                                    <div class="flex items-center gap-3">
                                        <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
                                        My Requests
                                    </div>

                                    @if (HasRequestsUpdate) @* شرط: لو فيه طلب تم قبوله (Approved) وجاهز للتسليم بكود *@
                                    {
                                        <span class="relative flex h-2 w-2">
                                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                                            <span class="relative inline-flex rounded-full h-2 w-2 bg-red-500"></span>
                                        </span>
                                    }
                                </a>
                            </div>

                            <div class="h-px bg-slate-50 my-2 mx-6"></div>

                            <button @onclick="Logout" class="w-full flex items-center gap-3 px-8 py-3 hover:bg-red-50 text-red-600 font-bold transition text-left">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                                Sign Out
                            </button>
                        </div>
                    }
                </div>
            </Authorized>
            <NotAuthorized>
                <a href="/login" class="bg-slate-900 text-white px-8 py-3 rounded-full font-bold text-sm hover:bg-orange-600 transition shadow-lg">
                    Join Us
                </a>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</nav>

@code {
    private bool isUserMenuOpen = false;

    private void ToggleUserMenu()
    {
        isUserMenuOpen = !isUserMenuOpen;
    }

    private async Task Logout()
    {
        // استدعاء دالة الخروج لتنظيف الباكيند والفرونت اند
        await AccountService.LogoutAsync();

        // إعادة توجيه المستخدم يقيناً إلى الصفحة الرئيسية وعمل تحديث كامل لتنظيف الـ State
        Nav.NavigateTo("/", forceLoad: true);
    }

    
        // حقن السيرفس لجلب البيانات وفحص التغييرات حقيقياً
        [Inject] public AnimalTransactionClientService TransactionService { get; set; } = default!;

        // متغيرات التحكم بظهور النقطة الحمراء النابضة في القائمة
        protected bool IsProfileIncomplete { get; set; } = false;
        protected bool IsFosterPeriodEnded { get; set; } = false;
        protected bool HasRequestsUpdate { get; set; } = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
           
            var currentUserProfile = await GetCurrentUserProfileAsync();
            CheckProfileCompleteness(currentUserProfile);

            var requests = await TransactionService.GetMyApplicationsAsync();
            if (requests != null)
            {
                // تشتعل النقطة الحمراء إذا وجد أي طلب مقبول (Approved) وبانتظار الكود
                HasRequestsUpdate = requests.Any(r => r.Status == "Approved");
            }

            // 3. فحص انتهاء فترة الاستضافة (My Animals) مستقبلاً
            // IsFosterPeriodEnded = myAnimals.Any(a => a.FosterEndDate <= DateTime.Today);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating layout notification badges: {ex.Message}");
        }
    }

    /// <summary>
    /// دالة ذكية تمر على جميع خصائص ومكونات الحساب وتكتشف أي حقل فارغ تلقائياً (Reflection)
    /// </summary>
    private void CheckProfileCompleteness(object? userProfile)
    {
        if (userProfile == null)
        {
            IsProfileIncomplete = true;
            return;
        }

        // قراءة جميع الخصائص (Properties) المتواجدة داخل المودل بدون تحديد أسمائها يدوياً
        var properties = userProfile.GetType().GetProperties();

        foreach (var prop in properties)
        {
            var value = prop.GetValue(userProfile);

            // استثناء حقول الـ IDs (مثل Id أو AnimalId) حتى لا تعتبر نواقص إذا كانت فارغة أو صفرية
            if (prop.Name.EndsWith("Id", StringComparison.OrdinalIgnoreCase))
                continue;

            // إذا كانت القيمة null أو نصاً فارغاً أو يحتوي على مسافات فقط
            if (value == null || (value is string str && string.IsNullOrWhiteSpace(str)))
            {
                // بمجرد العثور على نقص واحد، نفعّل النقطة الحمراء ونوقف الفحص فوراً
                IsProfileIncomplete = true;
                return;
            }
        }

        // إذا كانت البيانات مكتملة بالكامل في كل الحقول
        IsProfileIncomplete = false;
    }

    // دالة تجريبية مؤقتة - استبدليها بالطريقة الحقيقية لجلب بيانات حساب المستخدم في مشروعكِ
    private async Task<object?> GetCurrentUserProfileAsync()
    {
        await Task.CompletedTask;
        return null; // تعيد null مؤقتاً لتظهر النقطة الحمراء للتجربة
    }
}